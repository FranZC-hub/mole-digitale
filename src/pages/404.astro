---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Pagina non trovata — Mole Digitale" noindex={true}>
  <section class="section" style="min-height:70vh; display:grid; place-items:center; text-align:center;">
    <div data-reveal>
      <p class="kicker">Errore 404</p>
      <h1 style="font-size:clamp(2.4rem,7vw,4.5rem); margin:.4rem 0 1rem;">
        Questa pagina <span class="grad">non esiste.</span>
      </h1>
      <p class="section-lead" style="max-width:480px; margin:0 auto 2rem;">
        Forse il link è vecchio o c'è un errore di battitura. Torniamo sulla strada giusta.
      </p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; margin-bottom:2rem;">
        <a href="/" class="btn btn-primary btn-magnetic btn-lg">← Torna alla home</a>
        <a href="/demo" class="btn btn-ghost btn-lg">Guarda gli esempi</a>
        <a href="/preventivo" class="btn btn-ghost btn-lg">Calcola il preventivo</a>
      </div>
      <p style="color:var(--muted); font-size:.95rem;">
        Cercavi qualcosa di preciso? <a href="https://wa.me/393662102203?text=Ciao!%20Cercavo%20una%20pagina%20sul%20sito%20ma%20non%20la%20trovo" target="_blank" rel="noopener" style="color:var(--c2); text-decoration:underline;">Scrivici su WhatsApp</a> e ti aiutiamo al volo.
      </p>
    </div>
  </section>
</Layout>
