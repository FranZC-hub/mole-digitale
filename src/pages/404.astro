---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Pagina non trovata — Mole Digitale" noindex={true}>
  <section class="section" style="min-height:70vh; display:grid; place-items:center; text-align:center;">
    <div data-reveal>
      <p class="kicker">Errore 404</p>
      <h1 style="font-size:clamp(2.4rem,7vw,4.5rem); margin:.4rem 0 1rem;">
        Questa pagina <span class="grad">non esiste.</span>
      </h1>
      <p class="section-lead" style="max-width:480px; margin:0 auto 2rem;">
        Forse il link è vecchio o c'è un errore di battitura. Torniamo sulla strada giusta.
      </p>
      <a href="/" class="btn btn-primary btn-magnetic btn-lg">← Torna alla home</a>
    </div>
  </section>
</Layout>
