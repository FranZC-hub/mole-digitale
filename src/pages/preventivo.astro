---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Preventivo gratis — quanto costa il tuo sito | Mole Digitale"
  description="Calcola in 30 secondi quanto costa il tuo sito con Mole Digitale: scegli il pacchetto, aggiungi gli extra e ricevi subito una stima chiara, senza impegno."
>
  <section class="section" style="padding-top:8rem;">
    <div class="section-head" data-reveal>
      <span class="kicker">Preventivo</span>
      <h1>Quanto costa il <span class="grad">tuo sito?</span></h1>
      <p class="section-lead">Scegli il pacchetto e aggiungi solo ciò che ti serve: la stima si aggiorna in tempo reale. Senza impegno — la cifra definitiva te la confermiamo noi, e la prima bozza è gratis.</p>
    </div>

    <div class="prev-wrap">
      <form class="prev-form" id="prevForm" data-reveal>
        <fieldset>
          <legend>1 · Quale pacchetto?</legend>
          <label class="opt pack"><input type="radio" name="tipo" value="390" data-pack="essenziale" checked />
            <span><b class="opt-t">Essenziale</b><small>Onepage · contatti, mappa, WhatsApp</small></span> <b class="opt-p">€390</b></label>
          <label class="opt pack"><input type="radio" name="tipo" value="690" data-pack="attivita" />
            <span><b class="opt-t">Attività <i class="tag">consigliato</i></b><small>Fino a 6 pagine · menu, prenotazioni, SEO locale, galleria pro</small></span> <b class="opt-p">€690</b></label>
          <label class="opt pack"><input type="radio" name="tipo" value="1200" data-pack="ecommerce" />
            <span><b class="opt-t">E-commerce</b><small>Shop con carrello, schede prodotto e pagamenti</small></span> <b class="opt-p">da €1200</b></label>
        </fieldset>

        <fieldset>
          <legend>2 · Pagine extra?</legend>
          <label class="opt"><input type="radio" name="pagine" value="0" checked /> <span>Vanno bene quelle incluse</span> <b>incluse</b></label>
          <label class="opt"><input type="radio" name="pagine" value="120" /> <span>+2 pagine</span> <b>+€120</b></label>
          <label class="opt"><input type="radio" name="pagine" value="240" /> <span>+4 pagine</span> <b>+€240</b></label>
        </fieldset>

        <fieldset>
          <legend>3 · Funzioni extra</legend>
          <label class="opt" data-feat="prenotazioni"><input type="checkbox" name="extra" value="90" /> <span>Prenotazioni / appuntamenti</span> <b class="x-price">+€90</b></label>
          <label class="opt" data-feat="menu"><input type="checkbox" name="extra" value="60" /> <span>Menu / catalogo digitale</span> <b class="x-price">+€60</b></label>
          <label class="opt" data-feat="galleria"><input type="checkbox" name="extra" value="50" /> <span>Galleria foto pro</span> <b class="x-price">+€50</b></label>
          <label class="opt" data-feat="lingue"><input type="checkbox" name="extra" value="150" /> <span>Sito in più lingue</span> <b class="x-price">+€150</b></label>
        </fieldset>

        <fieldset>
          <legend>4 · Hosting &amp; dominio <i class="tag">sempre incluso</i></legend>
          <label class="opt opt-static"><span>Server veloce, dominio, certificato SSL, backup e assistenza tecnica</span> <b>€29/mese + IVA</b></label>
        </fieldset>
      </form>

      <aside class="prev-out" data-reveal>
        <span class="kicker">La tua stima</span>
        <div class="prev-total"><span class="from-tag" id="prevFrom" hidden>da&nbsp;</span><span class="cur">€</span><span id="prevAmount">390</span></div>
        <p class="prev-once">una tantum + IVA</p>
        <ul class="prev-breakdown" id="prevBreak"></ul>
        <p class="prev-canone-line">+ <b>€29/mese + IVA</b> · hosting, dominio, SSL e assistenza</p>
        <p class="prev-note">Stima indicativa: la cifra definitiva te la confermiamo dopo una chiacchierata. Prima bozza gratis, nessun anticipo.</p>
        <a href="/#contatti" class="btn btn-primary btn-block btn-lg btn-magnetic">Richiedi questo preventivo →</a>
        <a id="prevWa" href="https://wa.me/393662102203" target="_blank" rel="noopener" class="btn btn-ghost btn-block">Chiedi su WhatsApp</a>
      </aside>
    </div>
  </section>

  <style>
    .prev-wrap { display:grid; grid-template-columns:1.4fr 1fr; gap:2rem; align-items:start; max-width:1000px; margin:0 auto; }
    .prev-form { display:flex; flex-direction:column; gap:1.4rem; }
    .prev-form fieldset { border:1px solid var(--border); border-radius:var(--radius-sm); padding:1.2rem 1.3rem; }
    .prev-form legend { font-family:'Space Grotesk Variable','Space Grotesk'; font-weight:600; padding:0 .5rem; color:var(--c2); font-size:.95rem; }
    .opt { display:flex; align-items:center; gap:.7rem; padding:.6rem .2rem; cursor:pointer; border-bottom:1px solid rgba(255,255,255,.05); }
    .opt:last-child { border-bottom:0; }
    .opt input { accent-color:var(--c1); width:18px; height:18px; flex:none; }
    .opt span { flex:1; font-size:.98rem; }
    .opt b { color:var(--muted); font-size:.9rem; font-family:'Space Grotesk Variable','Space Grotesk'; }
    /* pacchetti */
    .opt.pack { align-items:flex-start; padding:.8rem .2rem; }
    .opt .opt-t { display:block; font-size:1rem; color:var(--text,#f3f3f7); }
    .opt small { display:block; color:var(--muted-2); font-size:.82rem; margin-top:.18rem; font-weight:400; line-height:1.4; }
    .opt .opt-p { color:var(--c2); font-size:1rem; white-space:nowrap; }
    .tag { font-style:normal; font-size:.64rem; text-transform:uppercase; letter-spacing:.07em; color:var(--c1); border:1px solid var(--c1); padding:.06rem .42rem; border-radius:999px; margin-left:.4rem; vertical-align:middle; font-family:'Space Grotesk Variable','Space Grotesk'; }
    /* extra inclusa nel pacchetto */
    .opt.is-incl { opacity:.72; cursor:default; }
    .opt.is-incl .x-price { color:var(--c1); font-style:italic; }
    .opt-static { cursor:default; }
    .prev-out { position:sticky; top:90px; background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); padding:1.8rem; text-align:center; backdrop-filter:blur(10px); }
    .prev-total { font-family:'Space Grotesk Variable','Space Grotesk'; font-size:3.4rem; font-weight:700; line-height:1; margin:.6rem 0 .2rem; background:var(--grad); -webkit-background-clip:text; background-clip:text; color:transparent; display:inline-flex; align-items:flex-start; gap:.1rem; }
    .prev-total .cur { font-size:1.6rem; margin-top:.4rem; }
    .prev-total .from-tag { font-size:1.5rem; margin-top:.5rem; }
    .prev-once { color:var(--muted); font-size:.9rem; margin-bottom:1rem; }
    .prev-breakdown { list-style:none; text-align:left; margin:0 0 1rem; display:grid; gap:.45rem; font-size:.9rem; border-top:1px solid var(--border); padding-top:1rem; }
    .prev-breakdown li { display:flex; justify-content:space-between; gap:1rem; color:var(--muted); }
    .prev-breakdown li b { color:var(--c2); font-family:'Space Grotesk Variable','Space Grotesk'; white-space:nowrap; }
    .prev-breakdown li.bd-base span, .prev-breakdown li.bd-base b { color:var(--text,#f3f3f7); font-weight:600; }
    .prev-canone-line { color:var(--muted); font-size:.86rem; margin-bottom:1rem; }
    .prev-canone-line b { color:var(--c2); }
    .prev-note { color:var(--muted-2); font-size:.84rem; margin:0 0 1.4rem; }
    .prev-out .btn { margin-bottom:.7rem; }
    @media (max-width:820px){ .prev-wrap { grid-template-columns:1fr; } .prev-out { position:static; } }
  </style>

  <script>
    const form = document.getElementById('prevForm');
    const amountEl = document.getElementById('prevAmount');
    const fromEl = document.getElementById('prevFrom');
    const breakEl = document.getElementById('prevBreak');
    const waEl = document.getElementById('prevWa');
    const CANONE = 29;

    const PACK_LABEL = { 390: 'Essenziale (onepage)', 690: 'Attività (sito completo)', 1200: 'E-commerce' };
    // funzioni già incluse in ciascun pacchetto: non si pagano due volte
    const INCLUDED = { essenziale: [], attivita: ['prenotazioni', 'menu', 'galleria'], ecommerce: ['prenotazioni', 'menu', 'galleria'] };
    const FEAT_LABEL = { prenotazioni: 'Prenotazioni', menu: 'Menu / catalogo', galleria: 'Galleria pro', lingue: 'Più lingue' };

    function calc() {
      const tipoInput = form.querySelector('input[name="tipo"]:checked');
      const tipo = Number(tipoInput.value);
      const pack = tipoInput.dataset.pack;
      const included = INCLUDED[pack] || [];
      const isEcom = pack === 'ecommerce';

      let total = tipo;
      const lines = [{ label: PACK_LABEL[tipo], val: tipo, base: true }];

      // pagine extra
      const pagine = Number(form.querySelector('input[name="pagine"]:checked').value);
      if (pagine) { total += pagine; lines.push({ label: 'Pagine extra', val: pagine }); }

      // funzioni extra (con gestione "incluso nel pacchetto")
      form.querySelectorAll('label[data-feat]').forEach((lab) => {
        const feat = lab.dataset.feat;
        const cb = lab.querySelector('input');
        const priceEl = lab.querySelector('.x-price');
        if (included.includes(feat)) {
          if (!cb.disabled) cb.dataset.auto = cb.checked ? '0' : '1';
          cb.checked = true; cb.disabled = true;
          lab.classList.add('is-incl');
          priceEl.textContent = 'incluso';
        } else {
          if (cb.disabled) { cb.disabled = false; if (cb.dataset.auto === '1') cb.checked = false; delete cb.dataset.auto; }
          lab.classList.remove('is-incl');
          priceEl.textContent = '+€' + cb.value;
          if (cb.checked) { total += Number(cb.value); lines.push({ label: FEAT_LABEL[feat], val: Number(cb.value) }); }
        }
      });

      // output
      fromEl.hidden = !isEcom;
      amountEl.textContent = total;
      breakEl.innerHTML = lines.map((l) =>
        `<li class="${l.base ? 'bd-base' : ''}"><span>${l.label}</span><b>${l.base && isEcom ? 'da €' : '€'}${l.val}</b></li>`
      ).join('');

      const msg = `Ciao! Dal preventivo online: ${PACK_LABEL[tipo]} ${isEcom ? 'da ' : ''}~€${total} + IVA una tantum, più €${CANONE}/mese + IVA di hosting. Possiamo sentirci?`;
      waEl.href = 'https://wa.me/393662102203?text=' + encodeURIComponent(msg);
    }

    form.addEventListener('change', calc);
    calc();
  </script>
</Layout>
