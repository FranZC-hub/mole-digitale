    @keyframes gemfloat{0%,100%{transform:translateY(0) rotate(-1deg)}50%{transform:translateY(-16px) rotate(1deg)}}
    .spark{position:absolute;width:14px;height:14px;background:
      radial-gradient(circle,#fff 0,rgba(255,255,255,0) 60%),
      conic-gradient(from 45deg,transparent,rgba(255,255,255,.9),transparent 30%);opacity:0;
      clip-path:polygon(50% 0,58% 42%,100% 50%,58% 58%,50% 100%,42% 58%,0 50%,42% 42%);animation:twinkle 3.4s ease-in-out infinite}
    .spark.s1{top:18%;left:24%;animation-delay:.1s}.spark.s2{top:30%;right:18%;animation-delay:1s}
    .spark.s3{bottom:24%;left:30%;animation-delay:1.9s}.spark.s4{bottom:30%;right:26%;width:10px;height:10px;animation-delay:2.6s}
    @keyframes twinkle{0%,100%{opacity:0;transform:scale(.4)}50%{opacity:1;transform:scale(1)}}

    /* SECTIONS */
    .lsection{max-width:1180px;margin:0 auto;padding:clamp(3.5rem,8vw,6.5rem) clamp(1.2rem,5vw,3rem)}
