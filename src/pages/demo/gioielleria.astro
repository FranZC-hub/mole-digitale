    .heart{position:absolute;top:.8rem;right:.8rem;width:40px;height:40px;border-radius:50%;border:1px solid var(--line);background:rgba(255,253,250,.9);backdrop-filter:blur(4px);display:grid;place-items:center;cursor:pointer;transition:transform .2s var(--ease),background .2s}
