    /* HERO */
    .lhero{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1.1fr .9fr;gap:clamp(1.5rem,4vw,3.5rem);align-items:center;padding:clamp(7rem,12vw,10rem) clamp(1.2rem,5vw,3rem) clamp(3rem,6vw,5rem)}
