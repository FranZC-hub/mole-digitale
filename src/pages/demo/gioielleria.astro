---
// DEMO standalone — "Lùmina", gioielleria/atelier orafo a Torino. Tema CHIARO / editoriale.
// Sito a sé (non usa il Layout di Mole Digitale). GSAP + Lenis + wishlist + configuratore fede.
import '@fontsource-variable/inter';
import '@fontsource-variable/space-grotesk';
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>Lùmina — Atelier di gioielli a Torino · Collezioni e creazioni su misura</title>
  <meta name="description" content="Lùmina, atelier orafo a Torino: collezioni di gioielli, fedi e anelli di fidanzamento su misura, riparazioni e perizie. Prenota un appuntamento in boutique." />
  <meta name="theme-color" content="#faf7f2" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path d='M12 3l4 5-4 13L8 8l4-5z' fill='%230e6b57'/><path d='M8 8h8' stroke='%23fff' stroke-width='1'/></svg>" />
</head>
<body>
  <a class="demo-flag" href="/">★ Demo realizzata da <b>Mole Digitale</b> · torna al sito ↩</a>

  <header class="lnav" id="lnav">
    <a href="#top" class="lbrand">Lùmina<span aria-hidden="true">◆</span></a>
    <nav class="llinks" id="llinks">
      <a href="#collezioni">Collezioni</a>
      <a href="#sumisura">Su misura</a>
      <a href="#servizi">Servizi</a>
      <a href="#atelier">Atelier</a>
    </nav>
    <div class="lnav-side">
      <button class="wish-btn" id="wishBtn" aria-label="I miei preferiti">
        <svg viewBox="0 0 24 24" width="21" height="21" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M12 20s-7-4.6-9.3-9C1.2 8 2.6 5 5.6 5 7.6 5 9 6.3 12 9c3-2.7 4.4-4 6.4-4 3 0 4.4 3 2.9 6-2.3 4.4-9.3 9-9.3 9z"/></svg>
        <span class="wish-count" id="wishCount" hidden>0</span>
      </button>
      <button class="lnav-toggle" id="navToggle" aria-label="Apri il menu" aria-expanded="false" aria-controls="llinks">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
      </button>
      <a href="#contatti" class="lbtn lbtn-solid">Prenota</a>
    </div>
  </header>

  <main id="main">
  <!-- HERO -->
  <section class="lhero" id="top">
    <div class="lhero-text">
      <p class="leyebrow r">Atelier orafo · Torino dal 1958</p>
      <h1 class="lhero-title">
        <span class="lw">Gioielli</span> <span class="lw">che raccontano</span><br/>
        <span class="lw em">chi sei.</span>
      </h1>
      <p class="lhero-sub r">Pezzi unici disegnati e creati a mano nel nostro laboratorio. Dalle collezioni d'autore alla fede nuziale pensata solo per voi.</p>
      <div class="lhero-cta r">
        <a href="#collezioni" class="lbtn lbtn-solid">Scopri le collezioni</a>
        <a href="#contatti" class="lbtn lbtn-ghost">Prenota un appuntamento</a>
      </div>
      <p class="lhero-sign r"><span class="lsign-rule" aria-hidden="true"></span>Disegnato e forgiato a mano · atelier orafo dal 1958</p>
    </div>
    <div class="lhero-art r">
      <div class="gem-stage">
        <img class="bigdiamond" src="/img/demo-gioielleria/hero.webp" alt="Anello con diamante taglio princess, dettaglio" loading="eager" />
        <span class="spark s1"></span><span class="spark s2"></span><span class="spark s3"></span><span class="spark s4"></span>
      </div>
    </div>
  </section>

  <!-- COLLEZIONI -->
  <section class="lsection" id="collezioni">
    <div class="lhead">
      <span class="lkicker r">Le collezioni</span>
      <h2 class="r">Trova il pezzo <span class="em">che ti somiglia</span></h2>
      <p class="llead r">Salva i preferiti con il cuore: porta in boutique la tua selezione e li proviamo insieme.</p>
    </div>
    <div class="lcats r" id="lcats">
      <button class="lcat is-on" data-cat="all">Tutti</button>
      <button class="lcat" data-cat="anelli">Anelli</button>
      <button class="lcat" data-cat="collane">Collane</button>
      <button class="lcat" data-cat="orecchini">Orecchini</button>
      <button class="lcat" data-cat="fedi">Fedi</button>
    </div>

    <div class="lookbook" id="collGrid">
      <article class="piece r" data-cat="anelli">
        <div class="piece-art"><img src="/img/demo-gioielleria/p-solitario.webp" alt="Anello solitario con diamante ovale su oro bianco" loading="lazy" /></div>
        <button class="heart" data-id="solitario" aria-label="Salva nei preferiti"><svg viewBox="0 0 24 24"><path d="M12 20s-7-4.6-9.3-9C1.2 8 2.6 5 5.6 5 7.6 5 9 6.3 12 9c3-2.7 4.4-4 6.4-4 3 0 4.4 3 2.9 6-2.3 4.4-9.3 9-9.3 9z"/></svg></button>
        <div class="piece-body"><h3>Solitario "Aurora"</h3><span class="piece-mat">Oro bianco 18kt · diamante taglio ovale</span><b class="piece-price">da € 1.890</b></div>
      </article>

      <article class="piece r" data-cat="collane">
        <div class="piece-art"><img src="/img/demo-gioielleria/p-goccia.webp" alt="Collana pendente con diamanti, rubini e zaffiri" loading="lazy" /></div>
        <button class="heart" data-id="goccia" aria-label="Salva nei preferiti"><svg viewBox="0 0 24 24"><path d="M12 20s-7-4.6-9.3-9C1.2 8 2.6 5 5.6 5 7.6 5 9 6.3 12 9c3-2.7 4.4-4 6.4-4 3 0 4.4 3 2.9 6-2.3 4.4-9.3 9-9.3 9z"/></svg></button>
        <div class="piece-body"><h3>Collana "Stella"</h3><span class="piece-mat">Diamanti, rubini e zaffiri · oro bianco</span><b class="piece-price">da € 4.200</b></div>
      </article>

      <article class="piece r" data-cat="orecchini">
        <div class="piece-art"><img src="/img/demo-gioielleria/p-pendenti.webp" alt="Orecchino d'epoca in oro con granati" loading="lazy" /></div>
        <button class="heart" data-id="pendenti" aria-label="Salva nei preferiti"><svg viewBox="0 0 24 24"><path d="M12 20s-7-4.6-9.3-9C1.2 8 2.6 5 5.6 5 7.6 5 9 6.3 12 9c3-2.7 4.4-4 6.4-4 3 0 4.4 3 2.9 6-2.3 4.4-9.3 9-9.3 9z"/></svg></button>
        <div class="piece-body"><h3>Orecchino d'epoca</h3><span class="piece-mat">Oro e granati · pezzo unico vintage</span><b class="piece-price">su richiesta</b></div>
      </article>

      <article class="piece r" data-cat="fedi">
        <div class="piece-art"><img src="/img/demo-gioielleria/p-intreccio.webp" alt="Coppia di fedi nuziali in oro" loading="lazy" /></div>
        <button class="heart" data-id="intreccio" aria-label="Salva nei preferiti"><svg viewBox="0 0 24 24"><path d="M12 20s-7-4.6-9.3-9C1.2 8 2.6 5 5.6 5 7.6 5 9 6.3 12 9c3-2.7 4.4-4 6.4-4 3 0 4.4 3 2.9 6-2.3 4.4-9.3 9-9.3 9z"/></svg></button>
        <div class="piece-body"><h3>Fedi nuziali</h3><span class="piece-mat">Oro giallo e bianco · coppia</span><b class="piece-price">da € 760</b></div>
      </article>

      <article class="piece r" data-cat="anelli">
        <div class="piece-art"><img src="/img/demo-gioielleria/p-veretta.webp" alt="Veretta eternity in oro con rubini e diamanti" loading="lazy" /></div>
        <button class="heart" data-id="veretta" aria-label="Salva nei preferiti"><svg viewBox="0 0 24 24"><path d="M12 20s-7-4.6-9.3-9C1.2 8 2.6 5 5.6 5 7.6 5 9 6.3 12 9c3-2.7 4.4-4 6.4-4 3 0 4.4 3 2.9 6-2.3 4.4-9.3 9-9.3 9z"/></svg></button>
        <div class="piece-body"><h3>Veretta "Eternity"</h3><span class="piece-mat">Oro giallo · rubini e diamanti</span><b class="piece-price">da € 1.690</b></div>
      </article>
    </div>
    <p class="lookbook-hint r" aria-hidden="true"><span>←</span> scorri per sfogliare il lookbook <span>→</span></p>
  </section>

  <!-- IL VIAGGIO DI UN GIOIELLO -->
  <section class="lsection viaggio">
    <div class="lhead">
      <span class="lkicker r">Come nasce</span>
      <h2 class="r">Il viaggio di <span class="em">un gioiello</span></h2>
      <p class="llead r">Dietro ogni pezzo ci sono settimane di lavoro. Ecco cosa succede dal primo schizzo al giorno in cui lo indossi.</p>
    </div>
    <ol class="journey">
      <li class="jstep r">
        <span class="jnum">1</span>
        <svg viewBox="0 0 64 64" aria-hidden="true"><path d="M14 50l4-12 22-22 8 8-22 22-12 4z" fill="none" stroke="#0e6b57" stroke-width="2.5"/><path d="M36 16l8 8" stroke="#0e6b57" stroke-width="2.5"/></svg>
        <h3>Bozzetto</h3><p>Ascoltiamo la vostra idea e la disegniamo a mano, fino a quando non è esattamente come la sognate.</p>
      </li>
      <li class="jstep r">
        <span class="jnum">2</span>
        <svg viewBox="0 0 64 64" aria-hidden="true"><circle cx="32" cy="34" r="16" fill="none" stroke="#0e6b57" stroke-width="2.5"/><path d="M32 18v-6M24 14l-3-4M40 14l3-4" stroke="#0e6b57" stroke-width="2.5"/></svg>
        <h3>Modello in cera</h3><p>Scolpiamo il gioiello nella cera: potete vederlo e provarlo prima ancora che esista in metallo.</p>
      </li>
      <li class="jstep r">
        <span class="jnum">3</span>
        <svg viewBox="0 0 64 64" aria-hidden="true"><path d="M20 44h24l-4-16H24l-4 16z" fill="none" stroke="#0e6b57" stroke-width="2.5"/><path d="M28 28l4-10 4 10" stroke="#0e6b57" stroke-width="2.5"/></svg>
        <h3>Fusione</h3><p>L'oro fuso prende la forma del modello. Da qui nasce il corpo del vostro gioiello.</p>
      </li>
      <li class="jstep r">
        <span class="jnum">4</span>
        <svg viewBox="0 0 64 64" aria-hidden="true"><polygon points="32,16 42,26 32,40 22,26" fill="none" stroke="#0e6b57" stroke-width="2.5"/><circle cx="32" cy="50" r="6" fill="none" stroke="#0e6b57" stroke-width="2.5"/></svg>
        <h3>Incastonatura</h3><p>Le pietre vengono fissate una a una, a mano, perché ogni luce le faccia brillare al meglio.</p>
      </li>
      <li class="jstep r">
        <span class="jnum">5</span>
        <svg viewBox="0 0 64 64" aria-hidden="true"><circle cx="32" cy="32" r="14" fill="none" stroke="#0e6b57" stroke-width="2.5"/><path d="M26 32l4 4 8-9" stroke="#0e6b57" stroke-width="2.5" fill="none"/></svg>
        <h3>Lucidatura</h3><p>Rifinitura e lucidatura a specchio. Poi una piccola scatola, ed è pronto per essere vostro.</p>
      </li>
    </ol>
  </section>

  <!-- SU MISURA / CONFIGURATORE -->
  <section class="lsection sumisura" id="sumisura">
    <div class="lhead">
      <span class="lkicker r">Su misura</span>
      <h2 class="r">Disegniamo <span class="em">la vostra fede</span></h2>
      <p class="llead r">Scegli il metallo, aggiungi il diamante: una bozza del vostro anello, in tempo reale. Poi lo creiamo a mano per voi.</p>
    </div>
    <div class="config r">
      <div class="config-preview">
        <svg viewBox="0 0 280 280" class="ring-svg" role="img" aria-label="Anteprima fede">
          <ellipse cx="140" cy="232" rx="74" ry="14" fill="rgba(0,0,0,.06)"/>
          <circle class="ring-band" cx="140" cy="138" r="84" fill="none" stroke-width="26"/>
          <circle class="ring-sheen" cx="140" cy="138" r="84" fill="none" stroke="rgba(255,255,255,.7)" stroke-width="6" stroke-dasharray="60 460" stroke-linecap="round" transform="rotate(-58 140 138)"/>
          <g class="ring-gem" id="ringGem" style="display:none">
            <polygon points="140,30 156,44 140,66 124,44" fill="#bfe6db"/>
            <polygon points="124,44 140,66 140,30" fill="#fff" opacity=".5"/>
            <polyline points="124,44 156,44" stroke="#fff" stroke-width="1.5" fill="none"/>
          </g>
        </svg>
      </div>
      <div class="config-controls">
        <div class="cfg-field">
          <span class="cfg-label">Metallo</span>
          <div class="metals" id="metals">
            <button class="metal is-on" data-m="giallo"  data-price="890"  style="--c1:#e9c45f;--c2:#b6892f"><i></i>Oro giallo</button>
            <button class="metal" data-m="bianco"  data-price="940"  style="--c1:#e7eaee;--c2:#b3bac2"><i></i>Oro bianco</button>
            <button class="metal" data-m="rosa"    data-price="920"  style="--c1:#f1c3b2;--c2:#cf937e"><i></i>Oro rosa</button>
            <button class="metal" data-m="platino" data-price="1490" style="--c1:#eef1f4;--c2:#a7afb8"><i></i>Platino</button>
          </div>
        </div>
        <div class="cfg-field">
          <span class="cfg-label">Diamante</span>
          <label class="switch"><input type="checkbox" id="diamond" /><span class="switch-ui"></span> Aggiungi diamante incastonato <em>+ € 450</em></label>
        </div>
        <div class="cfg-field">
          <span class="cfg-label">Incisione interna</span>
          <input type="text" id="engrave" maxlength="22" placeholder="es. 14·09·2026 · per sempre" class="cfg-input" />
          <small class="cfg-engrave">Anteprima: <span id="engravePrev">—</span></small>
        </div>
        <div class="cfg-out">
          <div><span>Prezzo indicativo (a fede)</span><b id="cfgPrice">€ 890</b></div>
          <a href="#contatti" class="lbtn lbtn-solid">Richiedi questa fede</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVIZI -->
  <section class="lsection" id="servizi">
    <div class="lhead">
      <span class="lkicker r">In laboratorio</span>
      <h2 class="r">Non solo <span class="em">vendita</span></h2>
    </div>
    <div class="serv-grid">
      <div class="serv r"><span class="serv-ic">⚒️</span><h3>Riparazioni</h3><p>Saldature, rifacimento griffe, sostituzione chiusure. Ridiamo vita ai gioielli di famiglia.</p></div>
      <div class="serv r"><span class="serv-ic">✍️</span><h3>Incisioni</h3><p>Date, nomi, frasi: a mano o al laser, all'interno della fede o sul ciondolo.</p></div>
      <div class="serv r"><span class="serv-ic">🔎</span><h3>Perizie</h3><p>Valutazione gemmologica e stima certificata di diamanti e pietre preziose.</p></div>
      <div class="serv r"><span class="serv-ic">📏</span><h3>Misura anelli</h3><p>Allargare o stringere un anello senza rovinarlo. Misurazione precisa in boutique.</p></div>
      <div class="serv r"><span class="serv-ic">🧵</span><h3>Infilatura perle</h3><p>Rinnovo del filo e della chiusura per collane di perle e pietre dure.</p></div>
      <div class="serv r"><span class="serv-ic">♻️</span><h3>Rifusione oro</h3><p>Trasformiamo il vostro oro vecchio in un gioiello nuovo, disegnato con voi.</p></div>
    </div>
  </section>

  <!-- ATELIER -->
  <section class="lsection atelier" id="atelier">
    <div class="atelier-grid">
      <div class="atelier-art r">
        <svg viewBox="0 0 360 320" role="img" aria-label="Il banco dell'orafo">
          <rect x="0" y="0" width="360" height="320" rx="18" fill="#0e6b57"/>
          <rect x="0" y="232" width="360" height="88" fill="#0a5546"/>
          <ellipse cx="180" cy="232" rx="150" ry="18" fill="rgba(0,0,0,.12)"/>
          <circle cx="120" cy="150" r="46" fill="none" stroke="#e9c45f" stroke-width="8"/>
          <circle cx="120" cy="150" r="46" fill="none" stroke="rgba(255,255,255,.5)" stroke-width="3" stroke-dasharray="30 200" stroke-linecap="round" transform="rotate(-50 120 150)"/>
          <g stroke="#cdeae1" stroke-width="6" stroke-linecap="round"><line x1="210" y1="118" x2="276" y2="184"/><line x1="276" y1="184" x2="300" y2="176"/></g>
          <circle cx="206" cy="114" r="9" fill="#e9c45f"/>
          <g fill="#fff"><circle cx="250" cy="120" r="2.5"/><circle cx="280" cy="150" r="2"/><circle cx="160" cy="120" r="2"/></g>
        </svg>
      </div>
      <div class="atelier-text">
        <span class="lkicker r">L'atelier</span>
        <h2 class="r">Le mani <span class="em">prima della macchina</span></h2>
        <p class="r">Dal 1958, tre generazioni di orafi al banco. Disegniamo, fondiamo, incastoniamo e lucidiamo ogni pezzo qui, a Torino — non altrove, non in serie.</p>
        <p class="r">Quando entri da Lùmina non compri un oggetto: porti a casa qualcosa che esiste solo per te.</p>
        <a href="#contatti" class="lbtn lbtn-ghost">Vieni a conoscerci</a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIANZA -->
  <section class="lsection lbigquote">
    <figure class="bigquote r">
      <span class="bq-mark" aria-hidden="true">&ldquo;</span>
      <blockquote>Ci hanno disegnato le fedi partendo da uno schizzo su un tovagliolo. Le guardiamo ancora ogni giorno e ci ricordano <em>chi siamo</em>.</blockquote>
      <figcaption><span class="bq-stars">★★★★★</span><b>Chiara &amp; Marco</b> · sposi dal 2024</figcaption>
    </figure>
  </section>

  <!-- FAQ -->
  <section class="lsection lfaq" id="faq">
    <div class="lhead">
      <span class="lkicker r">Domande frequenti</span>
      <h2 class="r">Prima di <span class="em">venire</span></h2>
    </div>
    <div class="faq r">
      <details class="faq-i"><summary>Si può pagare a rate?<span class="faq-x" aria-hidden="true"></span></summary><div class="faq-a">Sì. Per gli acquisti e le creazioni su misura offriamo pagamenti dilazionati senza interessi su più mesi. Ne parliamo insieme in boutique trovando la soluzione più comoda.</div></details>
      <details class="faq-i"><summary>I diamanti sono certificati?<span class="faq-x" aria-hidden="true"></span></summary><div class="faq-a">Ogni diamante importante è accompagnato da certificato gemmologico (GIA o IGI) che ne attesta caratura, colore, purezza e taglio. Per le pietre più piccole forniamo la nostra garanzia scritta.</div></details>
      <details class="faq-i"><summary>Quanto tempo serve per un pezzo su misura?<span class="faq-x" aria-hidden="true"></span></summary><div class="faq-a">In media da 3 a 6 settimane, a seconda della complessità. Per le fedi nuziali consigliamo di muoversi con almeno due mesi di anticipo rispetto alla data.</div></details>
      <details class="faq-i"><summary>Fate spedizioni e resi?<span class="faq-x" aria-hidden="true"></span></summary><div class="faq-a">Spediamo in tutta Italia con corriere assicurato. Hai 14 giorni per il reso sui pezzi di collezione (i lavori su misura, essendo unici, non sono rimborsabili ma li rifiniamo finché non sei soddisfatto).</div></details>
      <details class="faq-i"><summary>Posso portare il mio oro per rifarlo?<span class="faq-x" aria-hidden="true"></span></summary><div class="faq-a">Certo, è una delle cose che amiamo di più. Fondiamo il tuo oro di famiglia e lo trasformiamo in un gioiello nuovo disegnato con te, scalando il valore del metallo dal preventivo.</div></details>
      <details class="faq-i"><summary>Riparate gioielli non acquistati da voi?<span class="faq-x" aria-hidden="true"></span></summary><div class="faq-a">Sì. Saldature, rifacimento griffe, sostituzione chiusure, misura anelli e infilatura perle: portaci il pezzo e ti diamo subito un preventivo gratuito.</div></details>
    </div>
  </section>

  <!-- DOVE SIAMO -->
  <section class="lsection ldove">
    <div class="dove-grid">
      <div class="dove-info r">
        <span class="lkicker">La boutique</span>
        <h2>Ti aspettiamo <span class="em">a Torino</span></h2>
        <div class="open-badge" id="openStatus"><span class="dot"></span><b>—</b><span></span></div>
        <ul class="dove-list">
          <li><b>Indirizzo</b>Via Lagrange 14, 10123 Torino</li>
          <li><b>Orari</b>Mar–Sab 10:00–19:00 · Dom e Lun chiuso</li>
          <li><b>Come arrivare</b>Metro Porta Nuova · pieno centro pedonale</li>
          <li><b>Su misura</b>Consulenze dedicate solo su appuntamento</li>
        </ul>
        <a class="lbtn lbtn-ghost" href="https://www.google.com/maps/search/?api=1&query=Via+Lagrange+14+Torino" target="_blank" rel="noopener">🗺️ Apri in Google Maps</a>
      </div>
      <div class="dove-map r">
        <svg viewBox="0 0 400 300" class="mapsvg" role="img" aria-label="Mappa stilizzata della zona della boutique">
          <rect width="400" height="300" fill="#eef6f2"/>
          <g stroke="#d6e7df" stroke-width="14" stroke-linecap="round"><path d="M-10 80H410"/><path d="M-10 210H410"/><path d="M110 -10V310"/><path d="M290 -10V310"/></g>
          <g stroke="#dcebe4" stroke-width="5"><path d="M-10 145H410"/><path d="M200 -10V310"/><path d="M50 -10V310"/></g>
          <path d="M-10 250C120 210 180 300 410 235" stroke="#bfe0d4" stroke-width="18" fill="none" stroke-linecap="round"/>
          <g><circle cx="200" cy="145" r="26" fill="rgba(14,107,87,.16)"/><path d="M200 121a14 14 0 00-14 14c0 9 14 24 14 24s14-15 14-24a14 14 0 00-14-14z" fill="#0e6b57"/><circle cx="200" cy="135" r="5" fill="#fff"/></g>
        </svg>
        <span class="dove-pin">📍 Via Lagrange 14</span>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="lsection lcta" id="contatti">
    <div class="lcta-inner r">
      <span class="lkicker">Prenota appuntamento</span>
      <h2>Vieni a trovarci<br/><span class="em">in boutique.</span></h2>
