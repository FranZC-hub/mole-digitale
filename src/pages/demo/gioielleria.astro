    .lnav-toggle{display:none;background:none;border:0;color:var(--ink);cursor:pointer;width:42px;height:42px;border-radius:10px}

    .lbtn{display:inline-flex;align-items:center;justify-content:center;gap:.45rem;font-weight:600;font-size:.95rem;padding:.78rem 1.4rem;border-radius:999px;cursor:pointer;border:1px solid transparent;transition:transform .2s var(--ease),background .2s,box-shadow .2s,border-color .2s;font-family:var(--sans);white-space:nowrap}
    .lbtn-solid{background:var(--emer);color:#fff;box-shadow:0 12px 26px -14px var(--emer)}
    .lbtn-solid:hover{background:var(--emer-d);transform:translateY(-2px)}
    .lbtn-ghost{background:transparent;border-color:var(--line);color:var(--ink)}
