    .wish-note{text-align:center;font-size:.78rem;color:var(--muted);margin-top:.7rem}

    /* nascosto per costruzione (opacity+visibility): il solo translate non bastava
       quando il toast è vuoto/basso e spuntava come pillola nera su mobile */
    .ltoast{position:fixed;left:50%;bottom:24px;transform:translate(-50%,140%);opacity:0;visibility:hidden;pointer-events:none;background:var(--ink);color:#fff;padding:.75rem 1.2rem;border-radius:999px;font-size:.9rem;font-weight:600;z-index:500;box-shadow:var(--shadow);transition:transform .35s var(--ease),opacity .3s,visibility .3s}
    .ltoast.on{transform:translate(-50%,0);opacity:1;visibility:visible}

    /* LOOKBOOK */
    .lookbook{display:flex;gap:1.4rem;overflow-x:auto;scroll-snap-type:x mandatory;padding:.5rem .2rem 1.3rem;scroll-padding-left:.2rem;scrollbar-width:thin;scrollbar-color:var(--emer) var(--line)}
    .lookbook::-webkit-scrollbar{height:8px}
    .lookbook::-webkit-scrollbar-thumb{background:var(--emer);border-radius:999px}
    .lookbook::-webkit-scrollbar-track{background:var(--line);border-radius:999px}
    .lookbook .piece{flex:0 0 clamp(258px,76vw,316px);scroll-snap-align:start}
    .lookbook-hint{text-align:center;color:var(--muted);font-size:.85rem;letter-spacing:.04em;margin-top:.3rem}
    .lookbook-hint span{color:var(--emer);font-weight:700}

    /* VIAGGIO */
    .journey{list-style:none;display:grid;grid-template-columns:repeat(5,1fr);gap:1rem}
    .jstep{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);padding:1.8rem 1.1rem 1.4rem;text-align:center;position:relative;transition:transform .3s var(--ease),box-shadow .3s}
    .jstep:hover{transform:translateY(-5px);box-shadow:var(--shadow)}
    .jnum{margin:0 auto .7rem;width:30px;height:30px;border-radius:50%;background:var(--emer);color:#fff;display:grid;place-items:center;font-family:var(--disp);font-weight:600;font-size:.92rem}
    .jstep svg{width:50px;height:50px;margin:.4rem auto .8rem}
    .jstep h3{font-size:1.04rem;margin-bottom:.3rem}
    .jstep p{color:var(--muted);font-size:.84rem;line-height:1.45}

    /* BIG QUOTE */
    .lbigquote{max-width:880px}
    .bigquote{text-align:center;position:relative;padding:1rem}
    .bq-mark{font-family:var(--disp);font-size:5rem;color:var(--emer);opacity:.22;line-height:.5;display:block}
    .bigquote blockquote{font-family:var(--disp);font-size:clamp(1.4rem,3.4vw,2.25rem);line-height:1.35;font-weight:500;margin:.2rem auto 1.4rem}
    .bigquote blockquote em{font-style:italic;color:var(--emer)}
    .bigquote figcaption{color:var(--muted);font-size:.95rem}
    .bq-stars{display:block;color:var(--gold);letter-spacing:.15em;margin-bottom:.5rem}
    .bigquote figcaption b{color:var(--ink)}

    /* FAQ */
    .lfaq{max-width:880px}
    .faq{display:flex;flex-direction:column;gap:.8rem}
    .faq-i{background:var(--card);border:1px solid var(--line);border-radius:14px;overflow:hidden;transition:border-color .25s,box-shadow .25s}
    .faq-i[open]{border-color:var(--emer);box-shadow:var(--shadow)}
    .faq-i summary{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:1.1rem 1.3rem;cursor:pointer;font-family:var(--disp);font-size:1.06rem;color:var(--ink);list-style:none}
    .faq-i summary::-webkit-details-marker{display:none}
    /* toggle FAQ: chevron che ruota (firma editoriale Lùmina) */
    .faq-x{position:relative;width:11px;height:11px;flex:none;border-right:2px solid var(--emer);border-bottom:2px solid var(--emer);transform:rotate(45deg);transition:transform .35s var(--ease);margin:-3px 6px 0 0}
    .faq-i[open] .faq-x{transform:rotate(-135deg)}
    .faq-a{padding:0 1.3rem 1.2rem;color:var(--muted);font-size:.96rem}

    /* DOVE SIAMO */
    .dove-grid{display:grid;grid-template-columns:.95fr 1.05fr;gap:clamp(1.5rem,4vw,3rem);align-items:center}
    .dove-map{position:relative;border-radius:var(--radius);overflow:hidden;border:1px solid var(--line);aspect-ratio:4/3;box-shadow:var(--shadow)}
    .mapsvg{width:100%;height:100%;object-fit:cover}
    .dove-pin{position:absolute;left:1rem;bottom:1rem;background:rgba(255,255,255,.92);backdrop-filter:blur(6px);border:1px solid var(--line);padding:.4rem .8rem;border-radius:999px;font-size:.85rem;color:var(--emer);font-weight:600}
    .dove-info h2{margin:.3rem 0 1rem}
    .dove-list{list-style:none;display:flex;flex-direction:column;gap:.7rem;margin:1.2rem 0 1.6rem}
    .dove-list li{color:var(--muted);font-size:.96rem}
    .dove-list b{display:block;color:var(--ink);font-family:var(--disp);font-size:.95rem;margin-bottom:.1rem}
    .open-badge{display:inline-flex;align-items:center;gap:.55rem;padding:.5rem .9rem;border-radius:999px;border:1px solid var(--line);font-size:.9rem;color:var(--muted);background:var(--card)}
    .open-badge .dot{width:9px;height:9px;border-radius:50%;background:#cf5b5b;box-shadow:0 0 8px #cf5b5b;flex:none}
    .open-badge.is-open .dot{background:var(--emer);box-shadow:0 0 8px var(--emer)}
    .open-badge b{color:var(--ink)}

    /* LEAD FORM (su sfondo scuro CTA) */
    .lead{display:flex;flex-direction:column;gap:.9rem;max-width:560px;margin:0 auto 1.2rem;text-align:left}
    .lead-row{display:grid;grid-template-columns:1fr 1fr;gap:.9rem}
    .lead label{display:flex;flex-direction:column;gap:.35rem;font-size:.72rem;letter-spacing:.06em;text-transform:uppercase;color:#cfc8c0}
    .lead input,.lead select{padding:.75rem .9rem;border-radius:12px;border:1px solid rgba(255,255,255,.16);background:rgba(255,255,255,.06);color:#fff;font-family:var(--sans);font-size:.95rem}
    .lead input::placeholder{color:#9b948c}
    .lead input:focus,.lead select:focus{outline:none;border-color:#7cc3b1}
    .lead select option{color:#1b1916}
    .lead-submit{margin-top:.3rem;width:100%}
    .lead-priv{font-size:.76rem;color:#cfc8c0;text-align:center}
    .lead-done{max-width:520px;margin:0 auto 1.2rem;text-align:center;background:rgba(124,195,177,.12);border:1px solid rgba(124,195,177,.5);border-radius:16px;padding:2rem;color:#fff}
    .lead-check{display:inline-grid;place-items:center;width:54px;height:54px;border-radius:50%;background:#7cc3b1;color:#0a3f34;font-size:1.6rem;margin-bottom:.8rem}
    .lead-done h3{font-size:1.4rem;margin-bottom:.4rem}
    .lead-done p{color:#cfc8c0}
    .resv-sep{color:#cfc8c0;font-size:.85rem;margin:.2rem 0 1.1rem}

    /* WhatsApp float */
    /* versione discreta in tinta atelier: smeraldo del brand, niente verde acceso */
    .wa-float{position:fixed;right:18px;bottom:18px;z-index:350;width:56px;height:56px;border-radius:50%;background:var(--emer);color:#fff;display:grid;place-items:center;box-shadow:0 12px 28px -10px rgba(14,107,87,.55);border:1px solid rgba(255,255,255,.25);transition:transform .25s var(--ease),background .25s}
    .wa-float:hover{transform:scale(1.08) translateY(-2px);background:var(--emer-d)}
    .wa-float::after{content:'';position:absolute;inset:0;border-radius:50%;border:1px solid var(--emer);animation:wapulse 3s ease-out infinite}
    @keyframes wapulse{0%{transform:scale(1);opacity:.7}100%{transform:scale(1.6);opacity:0}}

    /* reveal */
    .r{opacity:0;transform:translateY(26px)}

    @media (max-width:960px){
      .lhero{grid-template-columns:1fr;text-align:center}
      .lhero-art{order:-1}.leyebrow,.lhero-cta,.lhero-sign{justify-content:center}.lhero-sub{margin-left:auto;margin-right:auto}
      /* su telefono i due CTA si impilano a piena larghezza (niente a-capo storto) */
      .lhero-cta{flex-direction:column;align-items:stretch;max-width:340px;margin-left:auto;margin-right:auto}
      .lhero-cta .lbtn{width:100%}
      .config{grid-template-columns:1fr}
      .atelier-grid{grid-template-columns:1fr}.atelier-art{order:-1}
      .serv-grid{grid-template-columns:1fr 1fr}
      .journey{grid-template-columns:repeat(2,1fr)}
      .dove-grid{grid-template-columns:1fr}
    }
    @media (max-width:680px){
      /* .llinks (che spinge il gruppo a destra col suo margin-left:auto) qui sparisce:
         il margin passa al gruppo destro, così Prenota resta attaccato al bordo */
      .llinks{display:none}.lnav-side{margin-left:auto}.lnav-toggle{display:grid;place-items:center}
      .lnav-side>.lbtn-solid{padding:.5rem .9rem;font-size:.82rem}
      .lnav.open .llinks{display:flex;position:absolute;top:100%;left:0;right:0;flex-direction:column;gap:1.1rem;background:rgba(250,247,242,.98);backdrop-filter:blur(14px);border-bottom:1px solid var(--line);padding:1.2rem clamp(1.2rem,5vw,3rem) 1.5rem;margin:0}
      .serv-grid{grid-template-columns:1fr}.metals{grid-template-columns:1fr}
      .journey{grid-template-columns:1fr;gap:1.3rem}
      .lead-row{grid-template-columns:1fr}
    }
    @media (prefers-reduced-motion:reduce){
      .r{opacity:1!important;transform:none!important}
      .bigdiamond,.spark,.wa-float::after{animation:none!important}
    }
  </style>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import Lenis from 'lenis';
    import 'lenis/dist/lenis.css';
    gsap.registerPlugin(ScrollTrigger);

    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const lnav = document.getElementById('lnav');
    const onScroll = (y) => lnav.classList.toggle('solid', y > 40);

    const toggle = document.getElementById('navToggle');
    toggle.addEventListener('click', () => { const o = lnav.classList.toggle('open'); toggle.setAttribute('aria-expanded', String(o)); });
    document.querySelectorAll('#llinks a').forEach((a) => a.addEventListener('click', () => lnav.classList.remove('open')));
    document.addEventListener('click', (e) => { if (lnav.classList.contains('open') && !lnav.contains(e.target)) { lnav.classList.remove('open'); toggle.setAttribute('aria-expanded', 'false'); } });

    /* ---- Wishlist ---- */
    const wish = new Map();
    const $ = (s) => document.querySelector(s);
    const drawer = $('#drawer'), overlay = $('#overlay');
    const itemsEl = $('#wishItems'), emptyEl = $('#wishEmpty');
    const countEl = $('#wishCount'), toast = $('#toast');
    let toastT;
    const showToast = (m) => { toast.textContent = m; toast.classList.add('on'); clearTimeout(toastT); toastT = setTimeout(() => toast.classList.remove('on'), 1700); };
    let lastFocus = null;
    const openWish = () => { lastFocus = document.activeElement; drawer.classList.add('on'); overlay.classList.add('on'); $('#closeWish').focus(); };
    const closeWish = () => { drawer.classList.remove('on'); overlay.classList.remove('on'); if (lastFocus && lastFocus.focus) lastFocus.focus(); };
    $('#wishBtn').addEventListener('click', openWish);
    $('#closeWish').addEventListener('click', closeWish);
    overlay.addEventListener('click', closeWish);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { closeWish(); lnav.classList.remove('open'); } });

    function renderWish() {
      itemsEl.innerHTML = '';
      wish.forEach((it, id) => {
        const row = document.createElement('div');
        row.className = 'wish-line';
        row.innerHTML = `<div class="wl-art"><img src="${it.img}" alt=""></div>
          <div><div class="wl-name">${it.name}</div><div class="wl-mat">${it.mat}</div></div>
          <button class="wl-rm" data-r="${id}">togli</button>`;
        itemsEl.appendChild(row);
      });
      const n = wish.size;
      emptyEl.style.display = n ? 'none' : 'flex';
      itemsEl.style.display = n ? 'block' : 'none';
      if (n) { countEl.hidden = false; countEl.textContent = n; } else countEl.hidden = true;
    }
    document.querySelectorAll('.heart').forEach((h) => {
      h.addEventListener('click', () => {
        const card = h.closest('.piece'); const id = h.dataset.id;
        if (wish.has(id)) { wish.delete(id); h.classList.remove('on'); }
        else {
          h.classList.add('on');
          wish.set(id, {
            name: card.querySelector('h3').textContent,
            mat: card.querySelector('.piece-mat').textContent,
            img: card.querySelector('.piece-art img').getAttribute('src'),
          });
          showToast('Aggiunto ai preferiti ♥');
        }
        renderWish();
      });
    });
    itemsEl.addEventListener('click', (e) => {
      const id = e.target.dataset.r; if (!id) return;
      wish.delete(id); renderWish();
      const h = document.querySelector(`.heart[data-id="${id}"]`); if (h) h.classList.remove('on');
    });

    /* ---- Filtro collezioni ---- */
    document.querySelectorAll('.lcat').forEach((c) => c.addEventListener('click', () => {
      document.querySelectorAll('.lcat').forEach((x) => x.classList.remove('is-on'));
      c.classList.add('is-on');
      const cat = c.dataset.cat;
      document.querySelectorAll('.piece').forEach((p) => { p.style.display = (cat === 'all' || p.dataset.cat === cat) ? '' : 'none'; });
    }));

    /* ---- Configuratore fede ---- */
    const ringBand = document.querySelector('.ring-band');
    const ringGem = document.getElementById('ringGem');
    const cfgPrice = document.getElementById('cfgPrice');
    const diamond = document.getElementById('diamond');
    const engrave = document.getElementById('engrave');
    const engravePrev = document.getElementById('engravePrev');
    let basePrice = 890;
    const updatePrice = () => { cfgPrice.textContent = '€ ' + (basePrice + (diamond.checked ? 450 : 0)).toLocaleString('it-IT'); };
    document.querySelectorAll('.metal').forEach((m) => m.addEventListener('click', () => {
      document.querySelectorAll('.metal').forEach((x) => x.classList.remove('is-on'));
      m.classList.add('is-on');
      basePrice = +m.dataset.price;
      ringBand.style.stroke = m.style.getPropertyValue('--c1');
      updatePrice();
    }));
    diamond.addEventListener('change', () => { ringGem.style.display = diamond.checked ? '' : 'none'; updatePrice(); });
    engrave.addEventListener('input', () => { engravePrev.textContent = engrave.value.trim() ? '“' + engrave.value + '”' : '—'; });
    ringBand.style.stroke = '#e9c45f';
    updatePrice();

    /* ---- Form appuntamento (demo) ---- */
    const leadForm = document.getElementById('leadForm');
    const leadDone = document.getElementById('leadDone');
    if (leadForm) leadForm.addEventListener('submit', (e) => {
      e.preventDefault();
      leadForm.hidden = true; leadDone.hidden = false;
      leadDone.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth', block: 'center' });
    });

    /* ---- "Aperto adesso" ---- */
    (function () {
      const el = document.getElementById('openStatus'); if (!el) return;
      // Lùmina: Mar–Sab 10:00–19:00 (Dom e Lun chiuso)
      const sched = [null, null, [600, 1140], [600, 1140], [600, 1140], [600, 1140], [600, 1140]];
      const days = ['domenica', 'lunedì', 'martedì', 'mercoledì', 'giovedì', 'venerdì', 'sabato'];
      const fmt = (m) => String(Math.floor(m / 60)).padStart(2, '0') + ':' + String(m % 60).padStart(2, '0');
      const now = new Date(), d = now.getDay(), mins = now.getHours() * 60 + now.getMinutes(), t = sched[d];
      let open = false, txt = '';
      if (t && mins >= t[0] && mins < t[1]) { open = true; txt = '· chiude alle ' + fmt(t[1]); }
      else if (t && mins < t[0]) { txt = '· apre oggi alle ' + fmt(t[0]); }
      else { for (let i = 1; i <= 7; i++) { const s = sched[(d + i) % 7]; if (s) { txt = '· ' + (i === 1 ? 'apre domani' : 'apre ' + days[(d + i) % 7]) + ' alle ' + fmt(s[0]); break; } } }
      el.classList.toggle('is-open', open);
      el.querySelector('b').textContent = open ? 'Aperto adesso' : 'Chiuso ora';
      el.querySelector('span:last-child').textContent = ' ' + txt;
    })();

    if (!reduced) {
      const lenis = new Lenis({ lerp: 0.1 });
      const raf = (t) => { lenis.raf(t); requestAnimationFrame(raf); };
      requestAnimationFrame(raf);
      lenis.on('scroll', ({ scroll }) => { onScroll(scroll); ScrollTrigger.update(); });
      document.querySelectorAll('a[href^="#"]').forEach((a) => {
        const h = a.getAttribute('href'); if (!h || h === '#') return;
        const t = document.querySelector(h);
        if (t) a.addEventListener('click', (e) => { e.preventDefault(); lenis.scrollTo(t, { offset: -84 }); closeWish(); });
      });

      const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
      tl.from('.lhero-title .lw', { yPercent: 110, opacity: 0, stagger: 0.08, duration: 0.9 }, 0.1)
        .to('.lhero-text .r', { opacity: 1, y: 0, stagger: 0.12, duration: 0.8 }, 0.45)
        .fromTo('.lhero-art', { opacity: 0, scale: 0.85 }, { opacity: 1, scale: 1, duration: 1.1, ease: 'back.out(1.5)' }, 0.4);
      gsap.set('.lhero-text .r', { y: 18 });

      // reveal "a sipario" (clip wipe), firma editoriale di Lùmina
      gsap.utils.toArray('.lsection .r, .sumisura .r').forEach((el) => {
        gsap.fromTo(el,
          { opacity: 0, y: 26, clipPath: 'inset(0 0 100% 0)' },
          { opacity: 1, y: 0, clipPath: 'inset(0 0 0% 0)', duration: 0.95, ease: 'power3.out',
            scrollTrigger: { trigger: el, start: 'top 88%' } });
      });
    } else {
      window.addEventListener('scroll', () => onScroll(window.scrollY), { passive: true });
    }
  </script>
</body>
</html>
