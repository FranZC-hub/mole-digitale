    .ring-band{stroke:var(--ring1,#e9c45f);transition:stroke .4s var(--ease)}
    .config-controls{display:flex;flex-direction:column;gap:1.5rem}
    .cfg-field{display:flex;flex-direction:column;gap:.7rem}
    .cfg-label{font-size:.76rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);font-weight:600}
