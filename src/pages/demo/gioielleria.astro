    .piece:hover .piece-art svg{transform:scale(1.08) rotate(-2deg)}
    .piece:hover .piece-art img{transform:scale(1.06)}
    .tone-emer{background:linear-gradient(140deg,#eaf4f0,#dcebe6)}
    .tone-blush{background:linear-gradient(140deg,#f7ebef,#f0dee4)}
