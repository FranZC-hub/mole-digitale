    .switch em{color:var(--gold);font-style:normal;font-weight:600}
    .cfg-input{padding:.75rem 1rem;border-radius:12px;border:1px solid var(--line);background:var(--card);font-family:var(--sans);font-size:.95rem;color:var(--ink)}
