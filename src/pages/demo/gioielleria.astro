    .heart:hover svg{stroke:var(--blush)}
    .heart.on svg{fill:var(--blush);stroke:var(--blush);animation:pop .35s var(--ease)}
    @keyframes pop{0%{transform:scale(.6)}55%{transform:scale(1.25)}100%{transform:scale(1)}}
    .piece-body{padding:1.1rem 1.2rem 1.3rem}
    .piece-body h3{font-size:1.22rem;margin-bottom:.25rem}
    .piece-mat{display:block;color:var(--muted);font-size:.86rem;margin-bottom:.6rem}
