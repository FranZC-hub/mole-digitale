    .lhero-art{display:grid;place-items:center}
    .gem-stage{position:relative;width:min(420px,82vw);aspect-ratio:1;display:grid;place-items:center;
      background:radial-gradient(circle at 50% 45%,#eef7f4,#faf7f2 68%);border-radius:50%}
