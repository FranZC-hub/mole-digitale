---
// DEMO standalone — "Hashi", ristorante sushi a Torino. Tema scuro minimale rosso/nero (giapponese).
// STRUTTURA distinta: hero scuro con motivo hinomaru, MENU a categorie con listino piatti, sezione omakase.
// Responsive solo flusso (grid/flex/clamp), niente badge absolute decorativi. Sito a sé.
import '@fontsource-variable/jost';
import '@fontsource-variable/inter';

const menu = [
  { name: 'Nigiri', jp: '握り', items: [
    ['Salmone', 'Riso e salmone norvegese', '2,50€'],
    ['Tonno', 'Riso e tonno rosso', '3,00€'],
    ['Branzino', 'Riso e branzino', '2,80€'],
    ['Anguilla', 'Unagi e salsa kabayaki', '3,50€'],
  ] },
  { name: 'Uramaki', jp: '巻き', items: [
    ['California', 'Granchio, avocado, tobiko', '6,00€'],
    ['Spicy salmon', 'Salmone e salsa piccante', '6,50€'],
    ['Ebi tempura', 'Gambero in tempura, avocado', '7,00€'],
    ['Veggie', 'Avocado, cetriolo, mango', '5,50€'],
  ] },
  { name: 'Sashimi', jp: '刺身', items: [
    ['Salmone', '5 tagli freschi', '9,00€'],
    ['Tonno', '5 tagli di tonno rosso', '11,00€'],
    ['Misto', '9 tagli misti dello chef', '14,00€'],
  ] },
  { name: 'Special roll', jp: '特選', items: [
    ['Dragon roll', 'Anguilla, avocado, tobiko', '12,00€'],
    ['Rainbow roll', 'California ricoperto di sashimi', '13,00€'],
    ['Black roll', 'Riso nero, salmone, mango', '12,50€'],
  ] },
];
const reviews = [
  { n: 'Andrea M.', txt: 'Pesce freschissimo e tagli precisi. Il dragon roll è il migliore che abbia mai mangiato a Torino.' },
  { n: 'Yuki T.', txt: 'Atmosfera curata e autentica, omakase da chiudere gli occhi. Qui il sushi è una cosa seria.' },
  { n: 'Laura B.', txt: 'Eleganza e qualità senza il prezzo folle. Delivery puntuale e packaging bellissimo. Top.' },
];
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>Hashi — Sushi restaurant a Torino</title>
  <meta name="description" content="Hashi, sushi restaurant a Torino: nigiri, uramaki, sashimi e special roll preparati al momento con pesce freschissimo. Omakase, asporto e delivery. Prenota un tavolo." />
  <meta name="theme-color" content="#141110" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><circle cx='12' cy='12' r='7' fill='%23d6452f'/></svg>" />
</head>
<body>
  <a class="demo-flag" href="/siti-web-ristoranti-giapponesi-torino">★ Demo di <b>Mole Digitale</b> · Vuoi un sito così? <b>Scopri di più →</b></a>

  <header class="sunav" id="sunav">
    <a href="#top" class="subrand"><span class="subrand-dot" aria-hidden="true"></span>Hashi<span class="subrand-jp" aria-hidden="true">鮨</span></a>
    <nav class="sulinks" id="sulinks">
      <a href="#menu">Menu</a>
      <a href="#omakase">Omakase</a>
      <a href="#recensioni">Recensioni</a>
      <a href="#contatti">Prenota</a>
    </nav>
    <button class="sunav-toggle" id="suToggle" aria-label="Apri il menu" aria-expanded="false" aria-controls="sulinks"><svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg></button>
    <a href="#contatti" class="subtn subtn-solid">Prenota</a>
  </header>

  <main id="main">
  <!-- HERO -->
  <section class="suhero" id="top">
    <div class="suhero-disc" aria-hidden="true"></div>
    <div class="suhero-text">
      <span class="sukick r">鮨 · Sushi restaurant · Torino</span>
      <h1 class="r">L’arte del sushi,<br/>nel <span class="sumark">battito</span> della città.</h1>
      <p class="suhero-sub r">Pesce selezionato ogni mattina, tagli preparati al momento, rispetto della tradizione. Un’esperienza giapponese nel cuore di Torino.</p>
      <div class="suhero-cta r">
        <a href="#contatti" class="subtn subtn-solid subtn-lg">Prenota un tavolo</a>
        <a href="#menu" class="subtn subtn-ghost subtn-lg">Scopri il menu</a>
      </div>
      <ul class="suhero-trust r"><li>★ 4,9 su Google</li><li>● Pesce fresco ogni giorno</li><li>● Asporto & delivery</li></ul>
    </div>
    <div class="suhero-media r"><img src="/img/demo-sushi/hero.webp" alt="Selezione di sushi e sashimi del ristorante Hashi" /></div>
  </section>

  <!-- MENU -->
  <section class="susection" id="menu">
    <div class="suhead r"><span class="sukick2">Il menu</span><h2>Una carta che <span class="sumark">cambia col mare</span></h2><p>Una selezione dei nostri piatti. La disponibilità varia in base al pescato del giorno.</p></div>
    <div class="sumenu">
      {menu.map((cat) => (
        <div class="sucat r">
          <div class="sucat-h"><h3>{cat.name}</h3><span class="sucat-jp" aria-hidden="true">{cat.jp}</span></div>
          <ul class="suitems">
            {cat.items.map((it) => (
              <li class="suitem">
                <div class="suitem-l"><b>{it[0]}</b><span>{it[1]}</span></div>
                <span class="suitem-dots" aria-hidden="true"></span>
                <span class="suitem-p">{it[2]}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <p class="sumenu-note r">+ Antipasti, zuppe, tempura e dolci giapponesi nel menu completo in sala.</p>
  </section>

  <!-- OMAKASE / FILOSOFIA -->
  <section class="suomakase" id="omakase">
    <div class="suoma-grid">
      <div class="suoma-media r"><img src="/img/demo-sushi/s1.webp" alt="Lo chef prepara il sushi al banco di Hashi" /></div>
      <div class="suoma-text">
        <span class="sukick2 r">Omakase</span>
        <h2 class="r">«Mi affido <span class="sumark">allo chef</span>»</h2>
        <p class="r">È questo il significato di <em>omakase</em>: lasci che sia lo chef a guidarti, piatto dopo piatto, in un percorso di stagione costruito sul pescato migliore della giornata.</p>
        <ul class="subullets r">
          <li><b>Percorso degustazione</b> di 12 portate, dal crudo al caldo</li>
          <li><b>Banco sushi</b> davanti allo chef, per vivere ogni gesto</li>
          <li><b>Solo su prenotazione</b>, per pochi coperti a sera</li>
        </ul>
        <a href="#contatti" class="subtn subtn-solid r">Prenota l’omakase</a>
      </div>
    </div>
  </section>

  <!-- INFO BAND -->
  <section class="suband">
    <div class="suband-in r">
      <div class="suband-col"><b>Pranzo</b><span>Lun–Ven · combo bento da 12€</span></div>
      <div class="suband-col"><b>Cena</b><span>Tutti i giorni · 19:00–23:30</span></div>
      <div class="suband-col"><b>Asporto & delivery</b><span>Ordina, ti portiamo il Giappone a casa</span></div>
    </div>
  </section>

  <!-- RECENSIONI -->
  <section class="susection" id="recensioni">
    <div class="suhead suhead-c r"><span class="sukick2">Dicono di noi</span><h2>Palati <span class="sumark">conquistati</span></h2></div>
    <div class="surevs">
      {reviews.map((r) => (
        <blockquote class="surev r"><div class="sustars">★★★★★</div><p>«{r.txt}»</p><b>— {r.n}</b></blockquote>
      ))}
    </div>
  </section>

  <!-- CTA / CONTATTI -->
  <section class="sucta" id="contatti">
    <div class="sucta-in r">
      <div class="sucta-text">
        <span class="sukick2">Prenota ora</span>
        <h2>Riserva il tuo <span class="sumark">tavolo</span></h2>
        <p>Compila e confermiamo la tua prenotazione via messaggio. Per l’omakase, prenota con qualche giorno d’anticipo.</p>
        <p class="sucta-note">📍 Via Mazzini 14, Torino · Mar–Dom 12:00–14:30 / 19:00–23:30</p>
      </div>
      <form class="suform" onsubmit="return false">
        <label>Il tuo nome<input type="text" placeholder="Mario Rossi" autocomplete="name" /></label>
        <div class="suform-row">
          <label>Data<input type="text" placeholder="Es. 18 set" /></label>
          <label>Ora<input type="text" placeholder="Es. 20:30" /></label>
          <label>Persone<input type="text" placeholder="2" /></label>
        </div>
        <label>Telefono<input type="tel" placeholder="333 000 0000" autocomplete="tel" /></label>
        <button class="subtn subtn-solid subtn-lg subtn-block" type="submit">Prenota il tavolo →</button>
        <p class="suform-note">🔒 È una demo: nessun dato viene inviato.</p>
      </form>
    </div>
  </section>
  </main>

  <footer class="sufoot"><div><b>Hashi 鮨</b> · Sushi restaurant a Torino</div><div>Demo · <a href="/">Mole Digitale</a></div></footer>

  <a class="wa-fab" href="https://wa.me/390110000000" target="_blank" rel="noopener" aria-label="Scrivici su WhatsApp"><svg viewBox="0 0 24 24" width="26" height="26" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.8 4.9-1.3A10 10 0 1 0 12 2zm0 18a8 8 0 0 1-4.1-1.1l-.3-.2-2.9.8.8-2.8-.2-.3A8 8 0 1 1 12 20zm4.5-6c-.2-.1-1.4-.7-1.6-.8s-.4-.1-.5.1-.6.8-.8 1-.3.2-.5.1a6.5 6.5 0 0 1-3.2-2.8c-.2-.4.2-.4.6-1.2.1-.1 0-.3 0-.4l-.7-1.7c-.2-.5-.4-.4-.5-.4h-.5a1 1 0 0 0-.7.3 3 3 0 0 0-.9 2.2 5.2 5.2 0 0 0 1.1 2.7 11.9 11.9 0 0 0 4.6 4c2.3 1 2.3.7 2.7.6a2.5 2.5 0 0 0 1.6-1.1 2 2 0 0 0 .1-1.1z"/></svg></a>

  <style is:global>
    :root{
      --bg:#141110;--bg2:#1b1614;--card:#1e1815;--ink:#f4ede4;--muted:#a89a8d;
      --red:#d6452f;--red-l:#e8694f;--red-d:#b3331f;--line:rgba(255,255,255,.1);--soft:0 24px 50px -26px rgba(0,0,0,.75);
      --disp:'Jost Variable',system-ui,sans-serif;--sans:'Inter Variable',system-ui,sans-serif;--e:cubic-bezier(.2,.7,.2,1);
    }
    *{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth;scroll-padding-top:84px;overflow-x:clip}
    @media (prefers-reduced-motion:reduce){html{scroll-behavior:auto}}
    body{background:var(--bg);color:var(--ink);font-family:var(--sans);line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
    img{display:block;max-width:100%}a{color:inherit;text-decoration:none}
    h1,h2,h3{font-family:var(--disp);font-weight:500;line-height:1.1;letter-spacing:.01em}
    .sumark{color:var(--red-l)}

    .demo-flag{position:fixed;top:0;left:0;right:0;z-index:300;text-align:center;font-size:.8rem;padding:.4rem;background:rgba(20,17,16,.92);backdrop-filter:blur(8px);border-bottom:1px solid var(--line);color:var(--muted)}
    .demo-flag b{color:var(--red-l)}

    .sunav{position:fixed;top:27px;left:0;right:0;z-index:200;display:flex;align-items:center;gap:1.2rem;padding:.85rem clamp(1rem,4vw,2.6rem);transition:background .35s var(--e),box-shadow .35s}
    .sunav.solid{background:rgba(20,17,16,.82);backdrop-filter:blur(14px);border-bottom:1px solid var(--line)}
    .subrand{font-family:var(--disp);font-size:1.5rem;font-weight:600;display:inline-flex;align-items:center;gap:.5rem;letter-spacing:.06em}
    .subrand-dot{width:10px;height:10px;border-radius:50%;background:var(--red)}
    .subrand-jp{color:var(--red-l);font-size:1.1rem}
    .sulinks{display:flex;gap:1.7rem;margin-left:auto}
    .sulinks a{font-size:.92rem;color:var(--ink);position:relative;transition:color .2s;letter-spacing:.04em}
    .sulinks a::after{content:'';position:absolute;left:0;bottom:-5px;height:1px;width:0;background:var(--red);transition:width .3s var(--e)}
    .sulinks a:hover{color:var(--red-l)}.sulinks a:hover::after{width:100%}
    .sunav-toggle{display:none;background:none;border:0;color:var(--ink);cursor:pointer;width:44px;height:44px;border-radius:12px;place-items:center;margin-left:auto}

    .subtn{display:inline-flex;align-items:center;justify-content:center;gap:.45rem;font-weight:600;font-size:.92rem;padding:.7rem 1.4rem;border-radius:2px;cursor:pointer;border:1px solid transparent;transition:transform .2s var(--e),background .2s,color .2s;white-space:nowrap;font-family:var(--disp);letter-spacing:.04em}
    .subtn-solid{background:var(--red);color:#fff}.subtn-solid:hover{background:var(--red-d);transform:translateY(-3px)}
    .subtn-ghost{border-color:var(--line);color:var(--ink)}.subtn-ghost:hover{border-color:var(--red);color:var(--red-l);transform:translateY(-3px)}
    .subtn-lg{padding:.95rem 1.8rem;font-size:1rem}.subtn-block{width:100%}

    /* HERO */
    .suhero{position:relative;max-width:1180px;margin:0 auto;display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(1.6rem,4vw,3.5rem);align-items:center;padding:7.5rem clamp(1.2rem,5vw,3rem) 3.5rem;overflow:hidden}
    .suhero-disc{position:absolute;top:14%;right:-6%;width:min(46vw,440px);aspect-ratio:1;border-radius:50%;background:radial-gradient(circle at 50% 50%,rgba(214,69,47,.5),rgba(214,69,47,0) 70%);z-index:0;pointer-events:none}
    .suhero-text,.suhero-media{position:relative;z-index:1}
    .sukick{display:inline-block;font-family:var(--disp);font-size:.85rem;letter-spacing:.18em;text-transform:uppercase;color:var(--red-l);margin-bottom:1.3rem}
    .suhero h1{font-size:clamp(2.6rem,6.5vw,4.8rem);margin-bottom:1.2rem;font-weight:400}
    .suhero-sub{font-size:1.12rem;color:var(--muted);max-width:46ch;margin-bottom:1.8rem}
    .suhero-cta{display:flex;gap:.8rem;flex-wrap:wrap}
    .suhero-trust{list-style:none;display:flex;gap:1.4rem;flex-wrap:wrap;margin-top:1.8rem;color:var(--muted);font-size:.88rem}
    .suhero-media{border-radius:4px;overflow:hidden;box-shadow:var(--soft);aspect-ratio:1;border:1px solid var(--line)}
    .suhero-media img{width:100%;height:100%;object-fit:cover}

    .susection{max-width:1180px;margin:0 auto;padding:clamp(3.5rem,8vw,6rem) clamp(1.2rem,5vw,3rem)}
    .suhead{max-width:660px;margin-bottom:clamp(2rem,4vw,3rem)}
    .suhead-c{margin-left:auto;margin-right:auto;text-align:center}
    .sukick2{display:inline-block;font-family:var(--disp);font-size:.76rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--red-l);border:1px solid var(--line);padding:.35rem .9rem;border-radius:999px;margin-bottom:1rem}
    .suhead h2,.suomakase h2,.sucta h2{font-size:clamp(2rem,4.8vw,3.2rem);font-weight:400}.suhead p{color:var(--muted);margin-top:.8rem;font-size:1.05rem}

    /* MENU */
    .sumenu{display:grid;grid-template-columns:1fr 1fr;gap:clamp(1.6rem,4vw,3rem) clamp(2rem,5vw,4rem)}
    .sumenu>*{min-width:0}
    .sucat-h{display:flex;align-items:baseline;justify-content:space-between;gap:.6rem;padding-bottom:.8rem;margin-bottom:1rem;border-bottom:1px solid var(--line)}
    .sucat-h h3{font-size:1.5rem;font-weight:500}
    .sucat-jp{font-size:1.5rem;color:var(--red);opacity:.8}
    .suitems{list-style:none;display:grid;gap:1rem}
    .suitem{display:flex;align-items:baseline;gap:.6rem}
    .suitem-l{min-width:0}.suitem-l b{font-weight:600;font-size:1.05rem}.suitem-l span{display:block;font-size:.86rem;color:var(--muted)}
    .suitem-dots{flex:1;border-bottom:1px dotted var(--line);transform:translateY(-4px);min-width:14px}
    .suitem-p{font-family:var(--disp);font-weight:600;color:var(--red-l);white-space:nowrap}
    .sumenu-note{margin-top:1.8rem;text-align:center;color:var(--muted);font-size:.92rem}

    /* OMAKASE */
    .suomakase{background:var(--bg2);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
    .suoma-grid{max-width:1180px;margin:0 auto;padding:clamp(3.5rem,8vw,6rem) clamp(1.2rem,5vw,3rem);display:grid;grid-template-columns:1fr 1.05fr;gap:clamp(1.6rem,4vw,3.5rem);align-items:center}
    .suoma-grid>*{min-width:0}
    .suoma-media{border-radius:4px;overflow:hidden;box-shadow:var(--soft);aspect-ratio:4/3;border:1px solid var(--line)}
    .suoma-media img{width:100%;height:100%;object-fit:cover}
    .suoma-text p{color:var(--muted);margin:1rem 0}.suoma-text em{color:var(--ink);font-style:italic}
    .subullets{list-style:none;display:grid;gap:.7rem;margin-bottom:1.5rem}
    .subullets li{position:relative;padding-left:1.6rem;color:var(--muted)}
    .subullets li::before{content:'●';position:absolute;left:0;color:var(--red);font-size:.7rem;top:.35em}.subullets b{color:var(--ink)}

    /* BAND */
    .suband{background:var(--red)}
    .suband-in{max-width:1180px;margin:0 auto;padding:1.8rem clamp(1.2rem,5vw,3rem);display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;color:#fff;text-align:center}
    .suband-col{min-width:0;padding:0 1rem}
    .suband-col+.suband-col{border-left:1px solid rgba(255,255,255,.25)}
    .suband-col b{font-family:var(--disp);font-size:1.15rem;display:block;letter-spacing:.04em}
    .suband-col span{font-size:.86rem;color:rgba(255,255,255,.9)}

    /* RECENSIONI */
    .surevs{display:grid;grid-template-columns:repeat(3,1fr);gap:1.3rem}
    .surevs>*{min-width:0}
    .surev{background:var(--card);border:1px solid var(--line);border-radius:4px;padding:1.7rem;display:flex;flex-direction:column;gap:.8rem}
    .sustars{color:var(--red);letter-spacing:2px}.surev p{flex:1;font-size:1.02rem}.surev b{color:var(--ink);font-family:var(--disp);font-weight:500}

    /* CTA */
    .sucta{background:linear-gradient(150deg,#1f1714,#0f0c0b)}
    .sucta-in{max-width:1100px;margin:0 auto;padding:clamp(3rem,7vw,5.5rem) clamp(1.2rem,5vw,3rem);display:grid;grid-template-columns:1fr 1fr;gap:clamp(2rem,5vw,4rem);align-items:center}
    .sucta-in>*{min-width:0}
    .sucta-text>p{color:var(--muted);margin:.8rem 0 1.2rem;max-width:42ch}
    .sucta-note{font-size:.9rem;color:var(--muted)}
    .suform{background:var(--card);border:1px solid var(--line);border-radius:6px;padding:clamp(1.4rem,3vw,2rem);box-shadow:var(--soft);display:flex;flex-direction:column;gap:.9rem}
    .suform-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:.8rem}.suform-row>*{min-width:0}
    .suform label{display:flex;flex-direction:column;gap:.35rem;font-size:.82rem;font-weight:600;color:var(--muted)}
    .suform input{min-width:0;width:100%;padding:.8rem .9rem;border:1px solid var(--line);border-radius:3px;font-family:var(--sans);font-size:1rem;background:var(--bg);color:var(--ink)}
    .suform input:focus{outline:2px solid var(--red);border-color:transparent}
    .suform-note{font-size:.76rem;color:var(--muted);text-align:center;font-weight:400}

    .sufoot{max-width:1180px;margin:0 auto;padding:2rem clamp(1.2rem,5vw,3rem);display:flex;justify-content:space-between;gap:1rem;flex-wrap:wrap;color:var(--muted);font-size:.86rem;border-top:1px solid var(--line)}
    .sufoot b{color:var(--ink);font-family:var(--disp)}.sufoot a{color:var(--red-l)}

    .wa-fab{position:fixed;right:18px;bottom:18px;z-index:160;width:52px;height:52px;border-radius:50%;display:grid;place-items:center;background:#25d366;color:#fff;box-shadow:0 14px 30px -10px rgba(37,211,102,.7);transition:transform .2s var(--e)}
    .wa-fab:hover{transform:scale(1.08)}

    .r{opacity:0;transform:translateY(22px);transition:opacity .7s var(--e),transform .7s var(--e)}
    .r.in{opacity:1;transform:none}
    @media (prefers-reduced-motion:reduce){.r{opacity:1;transform:none;transition:none}}

    @media (max-width:900px){
      .sulinks{display:none}
      .sunav.suopen .sulinks{display:flex;position:absolute;top:100%;left:0;right:0;flex-direction:column;gap:1.1rem;background:rgba(20,17,16,.98);backdrop-filter:blur(14px);border-bottom:1px solid var(--line);padding:1.2rem clamp(1.2rem,5vw,3rem) 1.5rem}
      .sunav-toggle{display:grid}
      .sunav>.subtn-solid{padding:.5rem 1rem;font-size:.82rem}
      .suhero{grid-template-columns:1fr;padding-top:6.5rem}.suhero-media{order:-1;aspect-ratio:16/11}
      .sumenu{grid-template-columns:1fr}
      .suoma-grid{grid-template-columns:1fr}.suoma-media{order:-1;aspect-ratio:16/10}
      .surevs{grid-template-columns:1fr}
      .suband-in{grid-template-columns:1fr}.suband-col+.suband-col{border-left:0;border-top:1px solid rgba(255,255,255,.25);padding-top:1rem;margin-top:1rem}
      .sucta-in{grid-template-columns:1fr}
    }
    @media (max-width:560px){
      .suform-row{grid-template-columns:1fr 1fr}
    }
  </style>

  <script>
    const sunav = document.getElementById('sunav');
    addEventListener('scroll', () => sunav.classList.toggle('solid', scrollY > 30), { passive: true });
    const st = document.getElementById('suToggle');
    st.addEventListener('click', () => { const o = sunav.classList.toggle('suopen'); st.setAttribute('aria-expanded', String(o)); });
    document.querySelectorAll('.sulinks a').forEach((a) => a.addEventListener('click', () => sunav.classList.remove('suopen')));
    document.addEventListener('click', (e) => { if (sunav.classList.contains('suopen') && !sunav.contains(e.target)) { sunav.classList.remove('suopen'); st.setAttribute('aria-expanded', 'false'); } });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { sunav.classList.remove('suopen'); st.setAttribute('aria-expanded', 'false'); } });
    const io = new IntersectionObserver((es) => es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } }), { threshold: 0.1 });
    document.querySelectorAll('.r').forEach((el) => io.observe(el));
  </script>
</body>
</html>
