    }

    /* === Sezioni informative (utente + cliente) === */
    /* come arrivare / accessibilità nella card "Dove siamo" */
    .vmini{list-style:none;margin-top:1.1rem;display:grid;gap:.5rem}
    .vmini li{font-size:.88rem;color:var(--muted);display:flex;gap:.5rem}
    .vmini li span{color:var(--gold-2);font-weight:600;min-width:74px}

    /* cosa è incluso nel biglietto */
    .tincl{list-style:none;margin:.1rem 0 1rem;display:grid;gap:.35rem}
    .tincl li{font-size:.85rem;color:var(--muted)}

    /* buono a sapersi (servizi) */
    .servizi{padding-top:clamp(1rem,3vw,2rem)}
    .srow{display:grid;grid-template-columns:repeat(6,1fr);gap:1rem}
    .sitem{display:flex;flex-direction:column;align-items:center;text-align:center;gap:.28rem;
      background:var(--card);border:1px solid var(--line);border-radius:var(--radius);padding:1.4rem .8rem;transition:border-color .3s,transform .3s var(--ease)}
    .sitem:hover{border-color:var(--gold-2);transform:translateY(-4px)}
    .sico{font-size:1.7rem;line-height:1}
    .sitem b{color:var(--ink);font-family:'Inter Variable';font-weight:700;font-size:.97rem}
    .sitem span:last-child{color:var(--muted);font-size:.8rem}

    /* band scuole/gruppi + sostieni */
    .two-band{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem}
    .band{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);padding:2rem 1.9rem}
    .band h3{font-size:1.5rem;margin:.3rem 0 .7rem}
    .band p{color:var(--muted);margin-bottom:1.4rem;max-width:46ch}
    .band-gold{background:linear-gradient(180deg,rgba(205,162,78,.12),rgba(205,162,78,.03));border-color:rgba(205,162,78,.42)}

    /* FAQ (accordion nativo) */
    .faq{display:grid;gap:.7rem;max-width:820px}
    .faq details{background:var(--card);border:1px solid var(--line);border-radius:12px;overflow:hidden}
    .faq summary{cursor:pointer;padding:1rem 1.2rem;font-weight:600;color:var(--ink);list-style:none;
      display:flex;justify-content:space-between;align-items:center;gap:1rem;transition:color .2s}
    .faq summary::-webkit-details-marker{display:none}
    .faq summary::after{content:'+';color:var(--gold-2);font-size:1.35rem;line-height:1;transition:transform .25s var(--ease)}
    .faq details[open] summary::after{transform:rotate(45deg)}
    .faq summary:hover{color:var(--gold-2)}
    .faq details p{padding:0 1.2rem 1.1rem;color:var(--muted);font-size:.92rem}

    /* barra biglietti fissa (solo mobile) */
    .mobilebar{display:none}

    @media (max-width:900px){
      .srow{grid-template-columns:repeat(2,1fr)}
      .two-band{grid-template-columns:1fr}
      .mobilebar{display:flex;align-items:center;justify-content:space-between;gap:.8rem;
        position:fixed;left:.7rem;right:.7rem;bottom:.7rem;z-index:250;
        background:linear-gradient(135deg,var(--gold-2),var(--gold));color:#1c1405;
        padding:.85rem 1.2rem;border-radius:14px;box-shadow:0 16px 34px -12px rgba(0,0,0,.85);font-weight:700}
      .mobilebar i{font-style:normal;font-weight:600;opacity:.78;font-size:.82rem}
      .mobilebar b{white-space:nowrap}
      body .wa-fab{bottom:80px}
      #main{padding-bottom:4.6rem}
      .mfoot{margin-bottom:4.6rem}
      .toast{bottom:5.2rem}
    }

    /* === Accessibilità & rifiniture utili === */
    /* salta al contenuto (tastiera) */
    .skip{position:fixed;top:-100px;left:50%;transform:translateX(-50%);z-index:600;background:var(--gold-2);color:#1c1405;
      padding:.6rem 1.1rem;border-radius:0 0 10px 10px;font-weight:700;transition:top .2s var(--ease)}
    .skip:focus{top:0;outline:none}
    /* focus visibile coerente */
    a:focus-visible,button:focus-visible,select:focus-visible,summary:focus-visible,input:focus-visible{
      outline:2px solid var(--gold-2);outline-offset:3px;border-radius:6px}
    /* indicatore "aperto ora" */
    .open-now{display:flex;align-items:center;gap:.5rem;margin-top:1.1rem;font-size:.9rem;font-weight:600;color:var(--muted)}
    .open-now::before{content:'';width:9px;height:9px;border-radius:50%;background:var(--muted)}
    .open-now.is-open{color:#86d191}
    .open-now.is-open::before{background:#5ec46e;box-shadow:0 0 10px #5ec46e;animation:pulse 2s ease-in-out infinite}
    .open-now.is-closed{color:#e3a0a0}
    .open-now.is-closed::before{background:#d36b6b}
    @keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
    /* mappa diventa link */
    a.vmap{cursor:pointer;transition:border-color .25s,color .25s}
    a.vmap:hover{border-color:var(--gold-2);color:var(--gold-2)}
    /* footer: link rapidi */
    .mfoot-nav{display:flex;flex-wrap:wrap;gap:1.3rem;padding:1.2rem 0;border-top:1px solid var(--line)}
    .mfoot-nav a{color:var(--muted);font-size:.9rem;transition:color .2s}
    .mfoot-nav a:hover{color:var(--gold-2)}
    /* footer: recapiti (demo) */
    .mfoot-contact{padding:1.2rem 0 0;color:var(--muted);font-size:.88rem}
    .mfoot-contact span{color:var(--gold-d);font-style:italic;font-size:.8rem}

    /* collezione: card cliccabili + lightbox */
    .ccard{cursor:pointer}
    .lightbox{position:fixed;inset:0;z-index:700;display:grid;place-items:center;padding:1.2rem}
    .lightbox[hidden]{display:none}
    .lb-backdrop{position:absolute;inset:0;background:rgba(5,3,1,.82);backdrop-filter:blur(6px);animation:lbFade .3s ease}
    .lb-card{position:relative;z-index:1;max-width:760px;width:100%;background:var(--card);border:1px solid var(--line);
      border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow);animation:lbIn .35s var(--ease)}
    .lb-card img{width:100%;max-height:58vh;object-fit:cover;display:block}
    /* WhatsApp FAB */
    .wa-fab{position:fixed;right:18px;bottom:18px;z-index:250;width:52px;height:52px;border-radius:50%;display:grid;place-items:center;background:#25d366;color:#fff;box-shadow:0 14px 30px -10px rgba(37,211,102,.7);transition:transform .2s var(--ease)}
    .wa-fab:hover{transform:scale(1.08)}
    .lb-card figcaption{padding:1.4rem 1.7rem 1.8rem}
    .lb-card figcaption .kick{margin-bottom:.6rem}
    .lb-card h3{font-size:clamp(1.5rem,3vw,2.1rem);margin-bottom:.5rem;color:var(--gold-2)}
    .lb-card figcaption p:last-child{color:var(--muted)}
    .lb-close{position:absolute;top:.7rem;right:.7rem;z-index:2;width:40px;height:40px;border-radius:50%;border:1px solid var(--line);
      background:rgba(13,10,7,.6);color:var(--ink);cursor:pointer;font-size:1rem;backdrop-filter:blur(6px);transition:background .2s,border-color .2s,color .2s}
    .lb-close:hover{border-color:var(--gold-2);color:var(--gold-2)}
    @keyframes lbIn{from{opacity:0;transform:translateY(18px) scale(.98)}to{opacity:1;transform:none}}
