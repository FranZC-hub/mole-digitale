    @media (prefers-reduced-motion:reduce){html{scroll-behavior:auto}.r{opacity:1;transform:none;filter:none;transition:none}}

    @media (max-width:900px){
      .feature{grid-template-columns:1fr}.feature-img{order:-1}
      .visita-grid{grid-template-columns:1fr}
      .mlinks{position:absolute;top:100%;left:0;right:0;flex-direction:column;gap:1rem;display:none;
        background:rgba(13,10,7,.98);backdrop-filter:blur(14px);border-bottom:1px solid var(--line);padding:1.1rem clamp(1.2rem,5vw,3rem) 1.4rem}
      .mlinks.open{display:flex}
      .mtoggle{display:grid;place-items:center;margin-left:auto;margin-right:.2rem}
      .mcta{display:none}
    }

    /* === Animazioni: storia + futuro moderno === */
    /* polvere d'oro */
    .dust{position:fixed;inset:0;z-index:0;pointer-events:none;opacity:.6}
    #main{position:relative;z-index:1}
    .mfoot{position:relative;z-index:1}
    /* hero cinematografico (ken-burns) */
    .hero-bg{transform:scale(1.2);transform-origin:center;will-change:transform}
    /* bagliore oro sui titoli accento */
    .gold{text-shadow:0 0 30px rgba(230,200,120,.35)}
    .brand span{text-shadow:0 0 18px rgba(230,200,120,.4)}
    /* fregio geroglifico animato */
    .frieze{overflow:hidden;border-block:1px solid var(--line);background:rgba(0,0,0,.25);padding:.6rem 0;position:relative;z-index:1}
    .frieze-track{display:inline-block;white-space:nowrap;font-family:'Segoe UI Historic','Noto Sans Egyptian Hieroglyphs','Aegyptus',serif;
      font-size:1.7rem;color:var(--gold);opacity:.7;letter-spacing:.5rem;animation:frieze 44s linear infinite;will-change:transform}
    @keyframes frieze{from{transform:translateX(0)}to{transform:translateX(-50%)}}
    /* nome in geroglifici (cartiglio) */
    .nome-sec{text-align:center}
    .csub{color:var(--muted);margin-top:.6rem}
    .cartiglio-wrap{display:flex;flex-direction:column;align-items:center;gap:1.8rem}
    .cartiglio{position:relative;display:inline-flex;align-items:center;justify-content:center;min-width:240px;min-height:128px;
      padding:1rem 2.8rem;border:3px solid var(--gold);border-radius:90px;background:rgba(0,0,0,.32);
      box-shadow:0 0 50px -12px rgba(205,162,78,.45),inset 0 0 34px -12px rgba(205,162,78,.35)}
    .cartiglio::after{content:'';position:absolute;bottom:-17px;left:50%;transform:translateX(-50%);width:40px;height:17px;
      border:3px solid var(--gold);border-top:0;border-radius:0 0 10px 10px}
    .glyphs{font-family:'Segoe UI Historic','Noto Sans Egyptian Hieroglyphs','Aegyptus',serif;
      font-size:clamp(2.3rem,6vw,3.6rem);color:var(--gold-2);letter-spacing:.12rem;line-height:1;
      text-shadow:0 0 24px rgba(230,200,120,.55);min-height:1.1em;transition:opacity .2s}
    .name-in{background:#120d07;border:1px solid var(--line);border-radius:999px;color:var(--ink);font-family:'Inter Variable';
      font-size:1.05rem;padding:.8rem 1.6rem;text-align:center;letter-spacing:.18em;text-transform:uppercase;width:min(340px,90%)}
    .name-in:focus{outline:none;border-color:var(--gold-2);box-shadow:0 0 0 3px rgba(205,162,78,.22)}
    /* barra avanzamento scroll */
    .progress{position:fixed;top:0;left:0;height:3px;width:0;z-index:400;background:linear-gradient(90deg,var(--gold),var(--gold-2));box-shadow:0 0 12px rgba(205,162,78,.85)}
    /* raggi di luce dorata che attraversano l'hero */
    .hero-rays{position:absolute;inset:0;z-index:1;pointer-events:none;opacity:.6;mix-blend-mode:screen;
      background:linear-gradient(102deg,transparent 34%,rgba(232,200,120,.10) 50%,transparent 66%);background-size:220% 100%;animation:rays 10s ease-in-out infinite}
    @keyframes rays{0%,100%{background-position:0 0}50%{background-position:100% 0}}
    /* rivelazione immagini a tendina (clip-path) */
    .ccard-img img,.feature-img img{clip-path:inset(0 0 100% 0);transition:clip-path 1.1s var(--ease),transform .6s var(--ease)}
    .r.in .ccard-img img,.feature-img.in img{clip-path:inset(0 0 0 0)}
    /* reveal a cascata nelle griglie */
    .cgrid .ccard:nth-child(2){transition-delay:.09s}.cgrid .ccard:nth-child(3){transition-delay:.18s}
    .cgrid .ccard:nth-child(4){transition-delay:.27s}.cgrid .ccard:nth-child(5){transition-delay:.36s}.cgrid .ccard:nth-child(6){transition-delay:.45s}
    .mgrid .mcard:nth-child(2){transition-delay:.1s}.mgrid .mcard:nth-child(3){transition-delay:.2s}
    /* bagliore oro su hover delle card */
    .ccard,.mcard{position:relative}
    .ccard::after,.mcard::after{content:'';position:absolute;inset:0;border-radius:inherit;pointer-events:none;opacity:0;transition:opacity .35s;
      box-shadow:0 0 34px -6px rgba(205,162,78,.55),inset 0 0 0 1px rgba(232,200,120,.5)}
    .ccard:hover::after,.mcard:hover::after{opacity:1}
    /* cartiglio che "respira" */
    @keyframes cartGlow{0%,100%{box-shadow:0 0 42px -14px rgba(205,162,78,.4),inset 0 0 30px -12px rgba(205,162,78,.3)}50%{box-shadow:0 0 66px -10px rgba(205,162,78,.7),inset 0 0 42px -10px rgba(205,162,78,.5)}}
    .cartiglio{animation:cartGlow 3.6s ease-in-out infinite}
    @media (prefers-reduced-motion:reduce){
