    @media (prefers-reduced-motion:reduce){.open-now.is-open::before{animation:none}.lb-card,.lb-backdrop{animation:none}}

    /* biglietti: sezione dedicata */
    .biglietti-sec .bgrid{display:grid;grid-template-columns:1.5fr .9fr;gap:1.6rem;align-items:start}
    .btypes{display:grid;gap:.8rem}
    .btype{display:grid;grid-template-columns:1fr auto auto;align-items:center;gap:1.2rem;
      background:var(--card);border:1px solid var(--line);border-radius:14px;padding:1rem 1.3rem;transition:border-color .25s}
    .btype.sel{border-color:var(--gold-2)}
    .btype-info b{display:block;font-family:'Inter Variable';font-weight:700;font-size:1.02rem}
    .btype-info span{color:var(--muted);font-size:.82rem}
    .bprice{font-family:'Playfair Display Variable','Playfair Display';font-size:1.3rem;color:var(--gold-2);min-width:62px;text-align:right}
    .bdate{display:flex;flex-direction:column;gap:.5rem;background:var(--card);border:1px solid var(--line);border-radius:14px;padding:1rem 1.3rem;font-size:.88rem;color:var(--muted)}
    .bdate input{padding:.7rem .8rem;border-radius:10px;border:1px solid var(--line);background:#120d07;color:var(--ink);font-family:'Inter Variable';font-size:.95rem;color-scheme:dark}
    .bsummary{background:linear-gradient(180deg,#1a130a,#120d07);border:1px solid var(--line);border-radius:var(--radius);padding:1.6rem;position:sticky;top:100px}
    .bsummary h3{color:var(--gold-2);font-size:1.3rem;margin-bottom:1rem}
    .brecap{list-style:none;display:grid;gap:.5rem;margin-bottom:.3rem;font-size:.92rem;min-height:1.5rem}
    .brecap li{display:flex;justify-content:space-between;gap:1rem}
    .brecap li b{color:var(--ink);font-family:'Inter Variable'}
    .brecap-empty{color:var(--muted)}
    @media (max-width:900px){.biglietti-sec .bgrid{grid-template-columns:1fr}.bsummary{position:static}}
    @media (max-width:560px){.btype{grid-template-columns:1fr auto}.btype .qbox{grid-column:1 / -1;justify-self:start;margin-top:.3rem}}
  </style>

  <script>
    import Lenis from 'lenis';
    import 'lenis/dist/lenis.css';
    (() => {
      const $ = (s) => document.querySelector(s);
      const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

      // --- Scroll fluido (Lenis) + parallasse hero + barra avanzamento ---
      const heroBg = $('.hero-bg'), prog = $('#progress');
      const onScroll = (scroll) => {
        if (heroBg) heroBg.style.transform = 'translateY(' + (scroll * 0.1) + 'px) scale(1.2)';
        if (prog) { const hMax = document.documentElement.scrollHeight - innerHeight; prog.style.width = (hMax > 0 ? (scroll / hMax) * 100 : 0) + '%'; }
      };
      let lenis = null;
      if (!reduced) {
        lenis = new Lenis({ lerp: 0.085, smoothWheel: true });
        lenis.on('scroll', (e) => onScroll(e.animatedScroll));
        const raf = (t) => { lenis.raf(t); requestAnimationFrame(raf); };
        requestAnimationFrame(raf);
      } else {
        addEventListener('scroll', () => onScroll(window.scrollY), { passive: true });
      }
      onScroll(0);
      // ancore con scroll morbido
      document.querySelectorAll('a[href^="#"]').forEach((a) => {
        const id = a.getAttribute('href');
        if (!id || id.length < 2) return;
        a.addEventListener('click', (e) => {
          const t = document.querySelector(id); if (!t) return;
          e.preventDefault();
          if (lenis) lenis.scrollTo(t, { offset: -70 }); else t.scrollIntoView({ behavior: 'smooth' });
        });
      });

      // selezione biglietti: più tipi insieme, con riepilogo e totale
      const bTypes = [...document.querySelectorAll('.btype')];
      const bRecap = $('#bRecap'), bTot = $('#tkTotal');
      const fmt = (n) => '€' + n.toFixed(2).replace('.', ',');
      const qtyOf = (t) => parseInt(t.querySelector('.qn').textContent, 10) || 0;
      const renderTickets = () => {
        let total = 0; const items = [];
        bTypes.forEach((t) => {
          const q = qtyOf(t); if (q < 1) return;
          const price = parseFloat(t.dataset.price), name = t.querySelector('b').textContent;
          total += q * price;
          items.push('<li><span>' + q + '× ' + name + '</span><b>' + (price === 0 ? 'gratis' : fmt(q * price)) + '</b></li>');
        });
        bRecap.innerHTML = items.length ? items.join('') : '<li class="brecap-empty">Seleziona i biglietti</li>';
        bTot.textContent = fmt(total);
      };
      bTypes.forEach((t) => {
        const n = t.querySelector('.qn');
        const set = (v) => { const q = Math.max(0, Math.min(20, v)); n.textContent = q; t.classList.toggle('sel', q > 0); renderTickets(); };
        t.querySelector('.qp').addEventListener('click', () => set(qtyOf(t) + 1));
        t.querySelector('.qm').addEventListener('click', () => set(qtyOf(t) - 1));
      });
      if (bTypes[0]) { bTypes[0].querySelector('.qn').textContent = '2'; bTypes[0].classList.add('sel'); }
      renderTickets();
      const bDate = $('#bDate');
      if (bDate) { const today = new Date().toISOString().slice(0, 10); bDate.min = today; if (!bDate.value) bDate.value = today; }
      // toast
      const toast = $('#toast'); let tt;
      const showToast = (m) => { toast.textContent = m; toast.classList.add('on'); clearTimeout(tt); tt = setTimeout(() => toast.classList.remove('on'), 1900); };
      $('#tkBuy').addEventListener('click', () => showToast('Demo: qui partirebbe l’acquisto online 🎟️'));
      document.querySelectorAll('[data-demo]').forEach((b) => b.addEventListener('click', () => showToast('Demo: in un sito reale qui partirebbe la richiesta ✦')));
      // iscrizione newsletter (demo)
      const nf = document.getElementById('newsForm');
      if (nf) nf.addEventListener('submit', (e) => { e.preventDefault(); showToast('Demo: iscrizione registrata, grazie ✦'); nf.reset(); });

      // "aperto ora" calcolato sull'orario corrente (Lun 9–14, Mar–Dom 9–18:30)
      const openEl = $('#openNow');
      if (openEl) {
        const HRS = { 0:[9,18.5], 1:[9,14], 2:[9,18.5], 3:[9,18.5], 4:[9,18.5], 5:[9,18.5], 6:[9,18.5] };
        const fmtH = (x) => { const h = Math.floor(x), m = Math.round((x - h) * 60); return h + ':' + String(m).padStart(2, '0'); };
        const now = new Date(), d = now.getDay(), t = now.getHours() + now.getMinutes() / 60, [o, c] = HRS[d];
        if (t >= o && t < c) {
          openEl.textContent = 'Aperto ora · chiude alle ' + fmtH(c);
          openEl.classList.add('is-open');
        } else {
          openEl.textContent = (t < o)
            ? 'Chiuso · apre oggi alle ' + fmtH(o)
            : 'Chiuso · riapre domani alle ' + fmtH(HRS[(d + 1) % 7][0]);
          openEl.classList.add('is-closed');
        }
      }
      // menu mobile
      const tg = $('#mtoggle'), ml = $('#mlinks');
      const closeMenu = () => { ml.classList.remove('open'); tg.setAttribute('aria-expanded', 'false'); };
      tg.addEventListener('click', () => { const o = ml.classList.toggle('open'); tg.setAttribute('aria-expanded', String(o)); });
      ml.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));
      document.addEventListener('click', (e) => { if (ml.classList.contains('open') && !e.target.closest('#menav')) closeMenu(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });

      // polvere d'oro (canvas)
      const dust = $('#dust');
      if (dust && !reduced) {
        const ctx = dust.getContext('2d');
        let w, h;
        const resize = () => { w = dust.width = innerWidth; h = dust.height = innerHeight; };
        resize(); addEventListener('resize', resize);
        const parts = Array.from({ length: 64 }, () => ({ x: Math.random()*innerWidth, y: Math.random()*innerHeight, r: Math.random()*1.6+0.4, s: Math.random()*0.25+0.06, o: Math.random()*0.5+0.15, p: Math.random()*Math.PI*2 }));
        const draw = () => {
          ctx.clearRect(0, 0, w, h);
          for (const a of parts) {
            a.y -= a.s; a.p += 0.01; a.x += Math.sin(a.p) * 0.25;
            if (a.y < -6) { a.y = h + 6; a.x = Math.random() * w; }
            ctx.beginPath(); ctx.arc(a.x, a.y, a.r, 0, Math.PI * 2);
            ctx.fillStyle = 'rgba(232,200,120,' + a.o + ')'; ctx.fill();
          }
          requestAnimationFrame(draw);
        };
        draw();
      }

      // contatori animati
      const fmtN = (n, sep) => sep ? String(n).replace(/\B(?=(\d{3})+(?!\d))/g, sep) : String(n);
      const cio = new IntersectionObserver((es) => es.forEach((en) => {
        if (!en.isIntersecting) return; cio.unobserve(en.target);
        const el = en.target, to = parseInt(el.dataset.to, 10), sep = el.dataset.sep || '', suf = el.dataset.suffix || '';
        if (reduced) { el.textContent = fmtN(to, sep) + suf; return; }
        const t0 = performance.now();
        const step = (now) => { const p = Math.min((now - t0) / 1600, 1); const e = 1 - Math.pow(1 - p, 3); el.textContent = fmtN(Math.round(e * to), sep) + suf; if (p < 1) requestAnimationFrame(step); };
        requestAnimationFrame(step);
      }), { threshold: 0.6 });
      document.querySelectorAll('.count').forEach((el) => cio.observe(el));

      // nome in geroglifici (glifi verificati che renderizzano)
      const MAP = {A:'𓄿',B:'𓃀',C:'𓎡',D:'𓂧',E:'𓇋',F:'𓆑',G:'𓎼',H:'𓎛',I:'𓇩',J:'𓆓',K:'𓎡',L:'𓃭',M:'𓅓',N:'𓈖',O:'𓍯',P:'𓊨',Q:'𓏘',R:'𓂋',S:'𓋴',T:'𓏏',U:'𓅱',V:'𓆑',W:'𓅨',X:'𓐍',Y:'𓏭',Z:'𓊃'};
      const nameIn = $('#nameIn'), glyphs = $('#glyphs');
      if (nameIn && glyphs) {
        const renderName = () => { glyphs.textContent = [...nameIn.value.toUpperCase()].map((c) => MAP[c] || (c === ' ' ? ' ' : '')).join(' '); };
        nameIn.addEventListener('input', renderName); renderName();
      }

      // lightbox collezione
      const lb = $('#lightbox'), lbImg = $('#lbImg'), lbTitle = $('#lbTitle'), lbDesc = $('#lbDesc'), lbClose = $('#lbClose');
      let lastFocus = null;
      const openLb = (card) => {
        lbImg.src = card.dataset.img; lbImg.alt = card.dataset.nome;
        lbTitle.textContent = card.dataset.nome; lbDesc.textContent = card.dataset.desc;
        lastFocus = card; lb.hidden = false; document.body.style.overflow = 'hidden';
        if (lenis) lenis.stop(); lbClose.focus();
      };
      const closeLb = () => {
        lb.hidden = true; document.body.style.overflow = '';
        if (lenis) lenis.start(); if (lastFocus) lastFocus.focus();
      };
      document.querySelectorAll('.ccard').forEach((card) => {
        card.addEventListener('click', () => openLb(card));
        card.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openLb(card); } });
      });
      lb.querySelectorAll('[data-close]').forEach((el) => el.addEventListener('click', closeLb));
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !lb.hidden) closeLb(); });

      // reveal
      const io = new IntersectionObserver((es) => es.forEach((en) => { if (en.isIntersecting) { en.target.classList.add('in'); io.unobserve(en.target); } }), { threshold: 0.12 });
      document.querySelectorAll('.r').forEach((el) => io.observe(el));
    })();
  </script>
</body>
</html>
