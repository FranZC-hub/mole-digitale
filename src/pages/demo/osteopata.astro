---
// DEMO standalone — "Àsse", studio di osteopatia a Torino. Tema CHIARO clinico-caldo (slate + sabbia).
// Responsive solo flusso (flex/grid/clamp), niente badge absolute. Sito a sé.
import '@fontsource-variable/manrope';

const perchi = [
  { ic: 'spine',   t: 'Mal di schiena',        d: 'Lombalgia, sciatalgia e rigidità: alla ricerca della causa, non solo del sintomo.' },
  { ic: 'neck',    t: 'Cervicale e mal di testa', d: 'Tensioni cervicali, cefalee e dolori che partono dal collo.' },
  { ic: 'run',     t: 'Dolori sportivi',       d: 'Recupero da infortuni, sovraccarichi e preparazione alla performance.' },
  { ic: 'heart',   t: 'Gravidanza e post-parto', d: 'Accompagnamento dolce per i cambiamenti del corpo, in sicurezza.' },
  { ic: 'child',   t: 'Neonati e bambini',     d: 'Coliche, plagiocefalia e disturbi della crescita, con tocco delicato.' },
  { ic: 'posture', t: 'Postura e tensioni',    d: 'Disturbi posturali, stress e tensioni accumulate dalla vita sedentaria.' },
];
const steps = [
  { n: '01', t: 'Valutazione', d: 'Anamnesi e test di mobilità per individuare la vera origine del problema, non solo dove fa male.' },
  { n: '02', t: 'Trattamento manuale', d: 'Tecniche dolci e mirate per ridare equilibrio, mobilità e respiro al tuo corpo.' },
  { n: '03', t: 'Esercizi e prevenzione', d: 'Consigli ed esercizi su misura, così il risultato dura nel tempo.' },
];
const reviews = [
  { n: 'Luca M.', av: 'L', txt: 'Dopo anni di mal di schiena, finalmente qualcuno che ha cercato la causa. Tre sedute e sto un’altra persona.' },
  { n: 'Giorgia P.', av: 'G', txt: 'Mi ha seguita in gravidanza con dolcezza e competenza. Mi sono sentita in mani sicure dal primo minuto.' },
  { n: 'Andrea S.', av: 'A', txt: 'Da sportivo lo considero parte del team. Spiega tutto con chiarezza e gli esercizi funzionano davvero.' },
];
const faq = [
  { q: 'Serve la prescrizione del medico?', a: 'No, all’osteopata si può accedere liberamente. Se necessario, collaboriamo con il tuo medico o fisioterapista.' },
  { q: 'Quante sedute servono?', a: 'Dipende dal caso: spesso bastano 3–4 sedute. Già dalla prima valutazione ti diamo un’idea chiara del percorso.' },
  { q: 'Il trattamento è doloroso?', a: 'No. Lavoriamo con tecniche dolci e rispettose del corpo. L’obiettivo è ridurre il dolore, non aumentarlo.' },
  { q: 'Trattate anche neonati e donne in gravidanza?', a: 'Sì, con tecniche specifiche e delicate. L’osteopatia è particolarmente indicata in questi momenti.' },
];
function icon(n) {
  const w = (p) => `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">${p}</svg>`;
  const m = {
    spine: '<path d="M12 3v18"/><path d="M12 5.5h3M12 9h3.5M12 12.5h3.5M12 16h3M9 7h-3M9 10.5H5.5M9 14H5.5"/>',
    neck: '<circle cx="12" cy="6" r="2.5"/><path d="M12 8.5c-1 1.5-1 3-1 4.5M12 8.5c1 1.5 1 3 1 4.5M7 17c1-2.5 3-4 5-4s4 1.5 5 4"/>',
    run: '<circle cx="14" cy="5" r="2"/><path d="M13 9l-3 2 1 4M10 11l-3 1M14 15l-1 5M14 15l3 2M10.5 8.5 13 9"/>',
    heart: '<path d="M12 20s-6-4-8-8a4.5 4.5 0 0 1 8-2 4.5 4.5 0 0 1 8 2c-2 4-8 8-8 8z"/>',
    child: '<circle cx="12" cy="6" r="2.3"/><path d="M9 21v-5l-1.5-1 1-4.5h5l1 4.5L13 16v5"/>',
    posture: '<path d="M5 21c1-5 3-8 7-8M5 21h6M12 13c0-3 1-5 4-6M16 5l1 3-3 1"/>',
  };
  return w(m[n] || m.spine);
}
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>Àsse — Studio di osteopatia a Torino</title>
  <meta name="description" content="Àsse, studio di osteopatia a Torino: mal di schiena, cervicale, dolori sportivi, gravidanza e bambini. Tecniche dolci, valutazione completa, osteopata D.O." />
  <meta name="theme-color" content="#34607a" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path d='M12 3v18M12 6h3M12 10h3M12 14h3' fill='none' stroke='%2334607a' stroke-width='2' stroke-linecap='round'/></svg>" />
</head>
<body>
  <a class="demo-flag" href="/siti-web-osteopati-torino">★ Demo di <b>Mole Digitale</b> · Vuoi un sito così? <b>Scopri di più →</b></a>

  <header class="osnav" id="osnav">
    <a href="#top" class="osbrand"><span class="osbrand-mark" aria-hidden="true"></span>Àsse</a>
    <nav class="oslinks" id="oslinks">
      <a href="#perchi">Per chi</a>
      <a href="#percorso">Il percorso</a>
      <a href="#recensioni">Recensioni</a>
      <a href="#contatti">Contatti</a>
    </nav>
    <button class="osnav-toggle" id="osToggle" aria-label="Apri il menu" aria-expanded="false" aria-controls="oslinks"><svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg></button>
    <a href="#contatti" class="osbtn osbtn-solid">Prenota</a>
  </header>

  <main id="main">
  <!-- HERO -->
  <section class="oshero" id="top">
    <div class="oshero-text">
      <span class="oskick r"><span class="osdot"></span>Studio di osteopatia · Torino</span>
      <h1 class="r">Torna a muoverti<br/><span class="osmark">senza dolore</span>.</h1>
      <p class="oshero-sub r">Osteopatia che guarda al corpo nel suo insieme. Cerchiamo la causa del tuo dolore — non solo dove fa male — con tecniche dolci e mirate.</p>
      <div class="oshero-cta r">
        <a href="#contatti" class="osbtn osbtn-solid osbtn-lg">Prenota una valutazione</a>
        <a href="#perchi" class="osbtn osbtn-ghost osbtn-lg">Per chi è</a>
      </div>
      <ul class="oshero-trust r"><li>✦ Osteopata D.O. registrato</li><li>✦ Valutazione completa</li><li>★ 4,9 su Google</li></ul>
    </div>
    <div class="oshero-media r"><img src="/img/demo-osteopata/hero.webp" alt="Seduta di osteopatia presso lo studio Àsse" /></div>
  </section>

  <!-- STAT STRIP -->
  <section class="osstats">
    <div class="osstats-in">
      <div class="r"><b>10+</b><span>anni di esperienza</span></div>
      <div class="r"><b>6.000+</b><span>trattamenti</span></div>
      <div class="r"><b>95%</b><span>riduzione del dolore</span></div>
      <div class="r"><b>4,9★</b><span>su Google</span></div>
    </div>
  </section>

  <!-- PER CHI -->
  <section class="ossection" id="perchi">
    <div class="oshead">
      <span class="oskick2 r">Per chi</span>
      <h2 class="r">L’osteopatia può <span class="osmark">aiutarti</span></h2>
      <p class="oslead r">Non solo schiena. Il corpo è un sistema connesso: trattiamo la causa, ovunque si nasconda.</p>
    </div>
    <div class="osgrid">
      {perchi.map((t) => (
        <article class="oscard r">
          <span class="oscard-ic" set:html={icon(t.ic)} aria-hidden="true"></span>
          <h3>{t.t}</h3>
          <p>{t.d}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- PERCORSO -->
  <section class="ossection osperc-sec" id="percorso">
    <div class="oshead"><span class="oskick2 r">Il percorso</span><h2 class="r">Come <span class="osmark">lavoriamo</span></h2><p class="oslead r">Un metodo chiaro, in tre passi, per risultati che durano.</p></div>
    <ol class="ostl">
      {steps.map((s) => (
        <li class="ostl-step r">
          <span class="ostl-node">{s.n}</span>
          <div class="ostl-body"><h3>{s.t}</h3><p>{s.d}</p></div>
        </li>
      ))}
    </ol>
  </section>

  <!-- PERCHE / FEATURE -->
  <section class="ossection osfeat" id="perche">
    <div class="osfeat-grid">
      <div class="osfeat-media r"><img src="/img/demo-osteopata/o1.webp" alt="Trattamento osteopatico manuale sulla schiena" /></div>
      <div class="osfeat-text">
        <span class="oskick2 r">Perché Àsse</span>
        <h2 class="r">Il corpo è <span class="osmark">un insieme</span></h2>
        <p class="r">Un dolore al ginocchio può nascere dall’anca; una cervicale, da una vecchia distorsione. Per questo guardiamo a tutto te, e non solo al punto dolente.</p>
        <ul class="osbullets r">
          <li><b>Valutazione globale</b> di postura, mobilità e abitudini</li>
          <li><b>Tecniche dolci</b> e personalizzate, mai invasive</li>
          <li><b>Esercizi a casa</b> per consolidare i risultati</li>
        </ul>
        <a href="#contatti" class="osbtn osbtn-solid r">Prenota la valutazione</a>
      </div>
    </div>
  </section>

  <!-- RECENSIONI -->
  <section class="ossection" id="recensioni">
    <div class="oshead"><span class="oskick2 r">Dicono di noi</span><h2 class="r">Persone che <span class="osmark">stanno meglio</span></h2></div>
    <div class="osgrid osgrid-3">
      {reviews.map((r) => (
        <blockquote class="osrev r"><div class="osstars">★★★★★</div><p>«{r.txt}»</p><footer><span class="osav">{r.av}</span><b>{r.n}</b></footer></blockquote>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section class="ossection osfaq-sec">
    <div class="oshead"><span class="oskick2 r">Domande frequenti</span><h2 class="r">Le risposte, <span class="osmark">subito</span></h2></div>
    <div class="osfaq r">
      {faq.map((f, i) => (
        <details class="osq" open={i === 0}><summary>{f.q}<span class="osq-ic" aria-hidden="true"></span></summary><div class="osq-a"><p>{f.a}</p></div></details>
      ))}
    </div>
  </section>

  <!-- MAPPA DEL CORPO (widget firma) -->
  <section class="ossection osmap-sec" id="mappa">
    <div class="oshead oshead-c"><span class="oskick2 r">Dove ti fa male?</span><h2 class="r">Tocca il punto <span class="osmark">che ti preoccupa</span></h2><p class="oslead r">Ti diciamo cosa può essere e come lo trattiamo.</p></div>
    <div class="osmap r" id="osMap">
      <svg viewBox="0 0 120 260" class="osmap-body" aria-hidden="true">
        <g fill="#cfdde6" stroke="#9db4c2" stroke-width="1.5">
          <circle cx="60" cy="26" r="16"/>
          <path d="M45 46 h30 l6 34 -6 60 4 70 h-14 l-4 -62 h-2 l-4 62 h-14 l4 -70 -6 -60 z"/>
          <path d="M45 50 l-16 40 8 26 8 -22 M75 50 l16 40 -8 26 -8 -22"/>
        </g>
        <g class="osmap-spots">
          <circle cx="60" cy="24" r="9" data-z="testa" tabindex="0" role="button" aria-label="Testa"/>
          <circle cx="60" cy="54" r="9" data-z="collo" tabindex="0" role="button" aria-label="Collo e spalle"/>
          <circle cx="60" cy="102" r="9" data-z="schiena" tabindex="0" role="button" aria-label="Schiena lombare"/>
          <circle cx="60" cy="142" r="9" data-z="anca" tabindex="0" role="button" aria-label="Anca e bacino"/>
          <circle cx="52" cy="196" r="9" data-z="ginocchio" tabindex="0" role="button" aria-label="Ginocchio"/>
        </g>
      </svg>
      <div class="osmap-panel">
        <div class="osmap-hint" id="osMapHint">👆 Tocca un punto sul corpo</div>
        <div class="osmap-info" hidden>
          <h3 id="osMapT"></h3>
          <p id="osMapD"></p>
          <p class="osmap-how"><b>Come lo trattiamo:</b> <span id="osMapH"></span></p>
          <a href="#contatti" class="osbtn osbtn-solid">Prenota la valutazione →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTATTI -->
  <section class="oscta" id="contatti">
    <div class="oscta-in r">
      <div class="oscta-text">
        <span class="oskick2">Prenota ora</span>
        <h2>Il primo passo è <span class="osmark2">capire</span></h2>
        <p>Scrivici per prenotare la tua valutazione: ti rispondiamo entro poche ore e troviamo insieme l’orario più comodo.</p>
        <div class="oscta-side">
          <a href="tel:+390110000000" class="osbtn osbtn-solid osbtn-lg">📞 011 000 0000</a>
          <a href="#contatti" class="osbtn osbtn-ghost-l osbtn-lg">WhatsApp</a>
        </div>
        <p class="oscta-note">📍 Corso Vittorio 18, Torino · Lun–Ven 9:00–19:00</p>
      </div>
      <form class="osform" onsubmit="return false">
        <label>Il tuo nome<input type="text" placeholder="Mario Rossi" autocomplete="name" /></label>
        <label>Telefono<input type="tel" placeholder="333 000 0000" autocomplete="tel" /></label>
        <label>Motivo della visita
          <select><option>Mal di schiena</option><option>Cervicale / mal di testa</option><option>Dolori sportivi</option><option>Gravidanza / post-parto</option><option>Neonati e bambini</option><option>Postura e tensioni</option></select>
        </label>
        <button class="osbtn osbtn-solid osbtn-lg osbtn-block" type="submit">Richiedi appuntamento →</button>
        <p class="osform-note">🔒 È una demo: nessun dato viene inviato.</p>
      </form>
    </div>
  </section>
  </main>

  <footer class="osfoot"><div><b>Àsse</b> · Studio di osteopatia a Torino</div><div>Demo · <a href="/">Mole Digitale</a></div></footer>

  <a class="wa-fab" href="https://wa.me/390110000000" target="_blank" rel="noopener" aria-label="Scrivici su WhatsApp"><svg viewBox="0 0 24 24" width="26" height="26" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.8 4.9-1.3A10 10 0 1 0 12 2zm0 18a8 8 0 0 1-4.1-1.1l-.3-.2-2.9.8.8-2.8-.2-.3A8 8 0 1 1 12 20zm4.5-6c-.2-.1-1.4-.7-1.6-.8s-.4-.1-.5.1-.6.8-.8 1-.3.2-.5.1a6.5 6.5 0 0 1-3.2-2.8c-.2-.4.2-.4.6-1.2.1-.1 0-.3 0-.4l-.7-1.7c-.2-.5-.4-.4-.5-.4h-.5a1 1 0 0 0-.7.3 3 3 0 0 0-.9 2.2 5.2 5.2 0 0 0 1.1 2.7 11.9 11.9 0 0 0 4.6 4c2.3 1 2.3.7 2.7.6a2.5 2.5 0 0 0 1.6-1.1 2 2 0 0 0 .1-1.1z"/></svg></a>

  <style is:global>
    :root{
      --bg:#f3f6f8;--bg2:#e7eef2;--card:#ffffff;--ink:#1f2a33;--muted:#5e6b76;
      --slate:#34607a;--slate-d:#234657;--sand:#cf9b5c;--sand-d:#b07e3c;--line:rgba(31,42,51,.12);--soft:0 18px 44px -24px rgba(30,50,65,.5);
      --sans:'Manrope Variable',system-ui,sans-serif;--e:cubic-bezier(.2,.7,.2,1);
    }
    *{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth;scroll-padding-top:84px;overflow-x:clip}
    @media (prefers-reduced-motion:reduce){html{scroll-behavior:auto}}
    body{background:var(--bg);color:var(--ink);font-family:var(--sans);line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
    img{display:block;max-width:100%}a{color:inherit;text-decoration:none}
    h1,h2,h3{font-family:var(--sans);font-weight:800;line-height:1.08;letter-spacing:-.02em}
    .osmark{color:var(--slate)}.osmark2{color:var(--sand)}

    .demo-flag{position:fixed;top:0;left:0;right:0;z-index:300;text-align:center;font-size:.8rem;padding:.4rem;background:rgba(243,246,248,.92);backdrop-filter:blur(8px);border-bottom:1px solid var(--line);color:var(--muted)}
    .demo-flag b{color:var(--slate)}

    .osnav{position:fixed;top:27px;left:0;right:0;z-index:200;display:flex;align-items:center;gap:1.2rem;padding:.85rem clamp(1rem,4vw,2.6rem);transition:background .35s var(--e),box-shadow .35s}
    .osnav.solid{background:rgba(243,246,248,.92);backdrop-filter:blur(14px);border-bottom:1px solid var(--line)}
    .osbrand{font-size:1.5rem;font-weight:800;display:inline-flex;align-items:center;gap:.5rem;letter-spacing:-.02em}
    .osbrand-mark{width:14px;height:14px;border-radius:4px;background:var(--slate);box-shadow:3px 3px 0 var(--sand)}
    .oslinks{display:flex;gap:1.6rem;margin-left:auto}
    .oslinks a{font-size:.95rem;font-weight:600;color:var(--ink);position:relative;transition:color .2s}
    .oslinks a::after{content:'';position:absolute;left:0;bottom:-5px;height:2px;width:0;background:var(--slate);transition:width .3s var(--e)}
    .oslinks a:hover{color:var(--slate)}.oslinks a:hover::after{width:100%}
    .osnav-toggle{display:none;background:none;border:0;color:var(--ink);cursor:pointer;width:44px;height:44px;border-radius:12px;place-items:center;margin-left:auto}

    .osbtn{display:inline-flex;align-items:center;justify-content:center;gap:.45rem;font-weight:700;font-size:.92rem;padding:.7rem 1.3rem;border-radius:12px;cursor:pointer;border:1px solid transparent;transition:transform .2s var(--e),background .2s;white-space:nowrap}
    .osbtn-solid{background:var(--slate);color:#fff;box-shadow:0 12px 26px -12px var(--slate)}.osbtn-solid:hover{background:var(--slate-d);transform:translateY(-3px)}
    .osbtn-ghost{border-color:var(--line);color:var(--ink)}.osbtn-ghost:hover{border-color:var(--slate);color:var(--slate);transform:translateY(-3px)}
    .osbtn-ghost-l{border-color:rgba(255,255,255,.55);color:#fff}.osbtn-ghost-l:hover{background:rgba(255,255,255,.14)}
    .osbtn-lg{padding:.95rem 1.7rem;font-size:1rem}.osbtn-block{width:100%}

    .oshero{max-width:1180px;margin:0 auto;display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(1.6rem,4vw,3.5rem);align-items:center;padding:7.5rem clamp(1.2rem,5vw,3rem) 3.5rem}
    .oskick{display:inline-flex;align-items:center;gap:.5rem;font-size:.8rem;letter-spacing:.12em;text-transform:uppercase;color:var(--slate);margin-bottom:1.2rem;font-weight:700}
    .osdot{width:8px;height:8px;border-radius:50%;background:var(--sand)}
    .oshero h1{font-size:clamp(2.5rem,6vw,4.5rem);margin-bottom:1.3rem}
    .oshero-sub{font-size:1.15rem;color:var(--muted);max-width:48ch;margin-bottom:1.8rem}
    .oshero-cta{display:flex;gap:.8rem;flex-wrap:wrap}
    .oshero-trust{list-style:none;display:flex;gap:1.2rem;flex-wrap:wrap;margin-top:1.8rem;color:var(--slate);font-size:.9rem;font-weight:700}
    .oshero-media{border-radius:18px;overflow:hidden;box-shadow:var(--soft);aspect-ratio:4/5;border:6px solid #fff;outline:1px solid var(--line)}
    .oshero-media img{width:100%;height:100%;object-fit:cover}

    .osstats{background:var(--slate)}
    .osstats-in{max-width:1180px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;padding:2.2rem clamp(1.2rem,5vw,3rem);color:#fff}
    .osstats-in>div{text-align:center;border-left:1px solid rgba(255,255,255,.22)}.osstats-in>div:first-child{border-left:none}
    .osstats b{font-size:clamp(1.7rem,3.4vw,2.5rem);display:block;font-weight:800}
    .osstats span{font-size:.84rem;opacity:.88}

    .ossection{max-width:1180px;margin:0 auto;padding:clamp(3.5rem,8vw,6.5rem) clamp(1.2rem,5vw,3rem)}
    .oshead{max-width:680px;margin:0 auto clamp(2.2rem,4vw,3.4rem);text-align:center}
    .oskick2{display:inline-block;font-size:.76rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--sand-d);background:rgba(207,155,92,.16);padding:.35rem .8rem;border-radius:999px;margin-bottom:1rem}
    .oshead h2,.osfeat h2,.oscta h2{font-size:clamp(1.9rem,4.4vw,3rem)}
    .oslead{color:var(--muted);font-size:1.1rem;margin-top:.9rem}

    .osgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.3rem}
    .osgrid>*{min-width:0}
    .oscard{background:var(--card);border:1px solid var(--line);border-left:3px solid var(--slate);border-radius:14px;padding:1.7rem;transition:transform .25s var(--e),box-shadow .25s}
    .oscard:hover{transform:translateY(-5px);box-shadow:var(--soft);border-left-color:var(--sand)}
    .oscard-ic{display:grid;place-items:center;width:50px;height:50px;border-radius:12px;background:rgba(52,96,122,.1);color:var(--slate);margin-bottom:1rem}
    .oscard-ic svg{width:27px;height:27px}
    .oscard h3{font-size:1.25rem;margin-bottom:.35rem}.oscard p{color:var(--muted);font-size:.95rem}

    .osperc-sec{background:var(--bg2)}
    /* percorso: timeline orizzontale connessa */
    .ostl{list-style:none;display:grid;grid-template-columns:repeat(3,1fr);gap:1.4rem;position:relative;max-width:1000px;margin:0 auto}
    .ostl>*{min-width:0}
    .ostl::before{content:'';position:absolute;top:28px;left:16%;right:16%;height:2px;background:repeating-linear-gradient(90deg,var(--slate) 0 7px,transparent 7px 15px);z-index:0}
    .ostl-step{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;text-align:center}
    .ostl-node{display:grid;place-items:center;width:56px;height:56px;border-radius:50%;background:var(--slate);color:#fff;font-weight:800;font-size:1.15rem;margin-bottom:1.1rem;box-shadow:0 0 0 7px var(--bg2)}
    .ostl-body h3{font-size:1.25rem;margin-bottom:.4rem}.ostl-body p{color:var(--muted);font-size:.96rem;max-width:34ch}

    .osfeat-grid{display:grid;grid-template-columns:1fr 1.05fr;gap:clamp(1.6rem,4vw,3.5rem);align-items:center}
    .osfeat-grid>*{min-width:0}
    .osfeat-media{border-radius:18px;overflow:hidden;box-shadow:var(--soft);aspect-ratio:4/3;border:6px solid #fff;outline:1px solid var(--line)}
    .osfeat-media img{width:100%;height:100%;object-fit:cover}
    .osfeat-text p{color:var(--muted);margin:1rem 0}
    .osbullets{list-style:none;display:grid;gap:.7rem;margin-bottom:1.5rem}
    .osbullets li{position:relative;padding-left:1.7rem;color:var(--muted)}
    .osbullets li::before{content:'✦';position:absolute;left:0;color:var(--sand)}.osbullets b{color:var(--ink)}

    .osgrid-3{grid-template-columns:repeat(3,1fr)}
    .osrev{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:1.6rem;display:flex;flex-direction:column;gap:.8rem}
    .osstars{color:var(--sand);letter-spacing:2px}.osrev p{flex:1}
    .osrev footer{display:flex;align-items:center;gap:.6rem}
    .osav{display:grid;place-items:center;width:38px;height:38px;border-radius:50%;background:var(--slate);color:#fff;font-weight:800;flex:none}

    .osfaq{max-width:780px;margin:0 auto;display:grid;gap:.8rem}
    .osq{background:var(--card);border:1px solid var(--line);border-radius:14px;overflow:hidden}
    .osq summary{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:1.1rem 1.3rem;cursor:pointer;font-weight:700;font-size:1.05rem;list-style:none}
    .osq summary::-webkit-details-marker{display:none}
    .osq-ic{position:relative;width:16px;height:16px;flex:none}
    .osq-ic::before,.osq-ic::after{content:'';position:absolute;background:var(--slate);border-radius:2px;transition:transform .3s var(--e)}
    .osq-ic::before{top:7px;left:0;width:16px;height:2px}.osq-ic::after{left:7px;top:0;width:2px;height:16px}
    .osq[open] .osq-ic::after{transform:scaleY(0)}
    .osq-a{padding:0 1.3rem 1.2rem;color:var(--muted)}

    .oscta{background:linear-gradient(150deg,var(--slate),var(--slate-d))}
    .oscta-in{max-width:1100px;margin:0 auto;padding:clamp(3rem,7vw,5.5rem) clamp(1.2rem,5vw,3rem);display:grid;grid-template-columns:1fr 1fr;gap:clamp(2rem,5vw,4rem);align-items:center;color:#fff}
    .oscta-in>*{min-width:0}
    .oscta .oskick2{background:rgba(255,255,255,.18);color:#fff}
    .oscta-text>p{color:rgba(255,255,255,.9);margin:.8rem 0 1.6rem;max-width:42ch}
    .oscta-side{display:flex;gap:.8rem;flex-wrap:wrap}.oscta-note{margin-top:1.4rem;font-size:.9rem;color:rgba(255,255,255,.85)}
    .osform{background:#fff;border-radius:18px;padding:clamp(1.4rem,3vw,2rem);box-shadow:0 40px 80px -40px rgba(0,0,0,.5);display:flex;flex-direction:column;gap:.9rem;color:var(--ink)}
    .osform label{display:flex;flex-direction:column;gap:.35rem;font-size:.85rem;font-weight:700}
    .osform input,.osform select{min-width:0;width:100%;padding:.8rem .9rem;border:1px solid var(--line);border-radius:10px;font-family:var(--sans);font-size:1rem;background:var(--bg);color:var(--ink)}
    .osform input:focus,.osform select:focus{outline:2px solid var(--slate);border-color:transparent}
    .osform-note{font-size:.78rem;color:var(--muted);text-align:center;font-weight:500}

    .osfoot{max-width:1180px;margin:0 auto;padding:2rem clamp(1.2rem,5vw,3rem);display:flex;justify-content:space-between;gap:1rem;flex-wrap:wrap;color:var(--muted);font-size:.88rem;border-top:1px solid var(--line)}
    .osfoot b{color:var(--ink)}.osfoot a{color:var(--slate)}

    /* mappa del corpo */
    .osmap-sec{background:var(--bg2);background-image:linear-gradient(rgba(52,96,122,.05) 1px,transparent 1px),linear-gradient(90deg,rgba(52,96,122,.05) 1px,transparent 1px);background-size:28px 28px}
    .osmap{max-width:760px;margin:0 auto;display:grid;grid-template-columns:200px 1fr;gap:clamp(1.4rem,4vw,2.5rem);align-items:center}
    .osmap>*{min-width:0}
    .osmap-body{width:100%;max-width:200px;margin:0 auto;display:block}
    .osmap-spots circle{fill:rgba(207,155,92,.35);stroke:var(--sand-d);stroke-width:2;cursor:pointer;transition:fill .2s,r .2s}
    .osmap-spots circle:hover,.osmap-spots circle:focus-visible{fill:var(--sand)}
    .osmap-spots circle.on{fill:var(--slate);stroke:var(--slate-d)}
    .osmap-panel{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:1.6rem;min-height:180px;display:grid;align-content:center}
    .osmap-hint{color:var(--muted);text-align:center;font-weight:600}
    .osmap-info h3{font-size:1.35rem;margin-bottom:.4rem}
    .osmap-info p{color:var(--muted);font-size:.96rem;margin-bottom:.7rem}
    .osmap-how b{color:var(--ink)}
    .osmap-info .osbtn{margin-top:.4rem}
    @media (max-width:640px){.osmap{grid-template-columns:1fr}.osmap-body{max-width:150px}}
    .wa-fab{position:fixed;right:18px;bottom:18px;z-index:160;width:52px;height:52px;border-radius:50%;display:grid;place-items:center;background:#25d366;color:#fff;box-shadow:0 14px 30px -10px rgba(37,211,102,.7);transition:transform .2s var(--e)}
    .wa-fab:hover{transform:scale(1.08)}

    /* reveal "direzionale": entra da sinistra come il percorso in timeline */
    .r{opacity:0;transform:translateX(-34px);transition:opacity .6s var(--e),transform .6s var(--e)}
    .r.in{opacity:1;transform:none}
    .ostl .r:nth-child(2){transition-delay:.12s}.ostl .r:nth-child(3){transition-delay:.24s}
    .osgrid .r:nth-child(2){transition-delay:.06s}.osgrid .r:nth-child(3){transition-delay:.12s}
    .osgrid .r:nth-child(4){transition-delay:.18s}.osgrid .r:nth-child(5){transition-delay:.24s}.osgrid .r:nth-child(6){transition-delay:.3s}
    @media (prefers-reduced-motion:reduce){.r{opacity:1;transform:none;transition:none}}

    @media (max-width:900px){
      .oslinks{display:none}
      .osnav.osopen .oslinks{display:flex;position:absolute;top:100%;left:0;right:0;flex-direction:column;gap:1.1rem;background:rgba(243,246,248,.98);backdrop-filter:blur(14px);border-bottom:1px solid var(--line);padding:1.2rem clamp(1.2rem,5vw,3rem) 1.5rem}
      .osnav-toggle{display:grid}
      .osnav>.osbtn-solid{padding:.5rem .9rem;font-size:.82rem}
      .oshero{grid-template-columns:1fr;padding-top:6.5rem}.oshero-media{order:-1;aspect-ratio:16/11}
      .ostl{grid-template-columns:1fr;gap:1.8rem;max-width:420px}.ostl::before{display:none}
      .osfeat-grid{grid-template-columns:1fr}.osfeat-media{order:-1;aspect-ratio:16/10}
      .oscta-in{grid-template-columns:1fr}
      .osstats-in{grid-template-columns:1fr 1fr;gap:1.4rem 1rem}.osstats-in>div:nth-child(3){border-left:none}
    }
    @media (max-width:560px){
      .osgrid,.osgrid-3{grid-template-columns:1fr}
      .oshero-trust{gap:.4rem 1.1rem}
    }
  </style>

  <script>
    import { demoNav, demoReveal, demoAccordion } from '../../scripts/demo-common.js';
    demoNav('os');
    demoReveal(0.12);
    document.querySelectorAll('.osq').forEach((d) => d.addEventListener('toggle', () => { if (d.open) document.querySelectorAll('.osq').forEach((o) => { if (o !== d) o.open = false; }); }));
    // Mappa del corpo interattiva
    const OSZ = {
      testa: { t: 'Mal di testa e cefalee', d: 'Spesso nascono da tensioni cervicali o della mandibola, non dalla testa stessa.', h: 'tecniche craniali dolci e lavoro sul tratto cervicale.' },
      collo: { t: 'Collo e spalle', d: 'La zona dove postura, stress e ore al computer si fanno sentire per primi.', h: 'mobilizzazioni dolci e riequilibrio della muscolatura profonda.' },
      schiena: { t: 'Schiena lombare', d: 'Lombalgia e sciatalgia: il motivo più frequente per cui si arriva da noi.', h: 'valutazione globale di bacino e appoggio, poi trattamento manuale mirato.' },
      anca: { t: 'Anca e bacino', d: 'Un bacino non allineato può causare dolori anche lontano: schiena, ginocchio, piede.', h: 'riequilibrio del bacino e lavoro sulla catena muscolare posteriore.' },
      ginocchio: { t: 'Ginocchio', d: 'Spesso il ginocchio «paga» per problemi di anca o appoggio del piede.', h: 'analisi dell’appoggio e trattamento dell’intera catena, non solo del punto dolente.' },
    };
    const osMap = document.getElementById('osMap');
    if (osMap) {
      const info = osMap.querySelector('.osmap-info'), hint = document.getElementById('osMapHint');
      const pick = (c) => {
        osMap.querySelectorAll('.osmap-spots circle').forEach((o) => o.classList.toggle('on', o === c));
        const z = OSZ[c.dataset.z];
        document.getElementById('osMapT').textContent = z.t;
        document.getElementById('osMapD').textContent = z.d;
        document.getElementById('osMapH').textContent = z.h;
        hint.hidden = true; info.hidden = false;
      };
      osMap.querySelectorAll('.osmap-spots circle').forEach((c) => {
        c.addEventListener('click', () => pick(c));
        c.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); pick(c); } });
      });
    }

    // Statistiche first-party (nessun cookie, niente IP): conta la visita alla demo
    try { if (!navigator.webdriver && !["localhost","127.0.0.1"].includes(location.hostname)) {
      let sref = ""; try { const u = new URL(document.referrer); if (u.host !== location.host) sref = u.host; } catch (_) {}
      fetch("/stats.php?p=" + encodeURIComponent(location.pathname) + "&r=" + encodeURIComponent(sref), { keepalive: true }).catch(() => {});
    } } catch (_) {}
  </script>
</body>
</html>
