---
// DEMO standalone — "Aureo", compro oro a Torino. Tema SCURO / oro, cinematografico.
// Sito a sé (non usa il Layout di Mole Digitale). GSAP + Lenis + calcolatore valutazione.
import '@fontsource-variable/inter';
import '@fontsource-variable/playfair-display';

// Quotazioni indicative (€/grammo) usate dal calcolatore e dal ticker.
const quote = [
  { k: 'Oro 24kt (999)', v: '76,40 €/g' },
  { k: 'Oro 22kt (916)', v: '69,80 €/g' },
  { k: 'Oro 18kt (750)', v: '57,30 €/g' },
  { k: 'Oro 14kt (585)', v: '44,20 €/g' },
  { k: 'Oro 9kt (375)',  v: '28,60 €/g' },
  { k: 'Argento 925',    v: '0,82 €/g'  },
  { k: 'Sterline oro',   v: '430,00 €'  },
  { k: 'Marenghi 20₣',   v: '345,00 €'  },
];
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>Aureo — Compro Oro a Torino · Valutazione gratuita e pagamento immediato</title>
  <meta name="description" content="Aureo, compro oro a Torino: valutazione gratuita e senza impegno, pagamento immediato in contanti, massima riservatezza. Calcola subito quanto vale il tuo oro." />
  <meta name="theme-color" content="#0e0b07" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><rect x='3' y='9' width='18' height='8' rx='1.5' fill='%23e8c372'/><rect x='6' y='5' width='12' height='5' rx='1.2' fill='%23d4af37'/></svg>" />
</head>
<body>

  <a class="demo-flag" href="/">★ Demo realizzata da <b>Mole Digitale</b> · torna al sito ↩</a>

  <!-- Ticker quotazioni -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker-row">
      {[...quote, ...quote].map((q) => (
        <span class="tk"><i></i>{q.k} <b>{q.v}</b></span>
      ))}
    </div>
  </div>

  <!-- NAV -->
  <header class="anav" id="anav">
    <a href="#top" class="abrand">
      <span class="ingot" aria-hidden="true"></span>
      Aureo<em>.</em>
    </a>
    <nav class="alinks" id="alinks">
      <a href="#calcola">Quanto vale</a>
      <a href="#come">Come funziona</a>
      <a href="#compriamo">Cosa compriamo</a>
      <a href="#fiducia">Perché noi</a>
      <a href="#contatti">Contatti</a>
    </nav>
    <button class="anav-toggle" id="navToggle" aria-label="Apri il menu" aria-expanded="false" aria-controls="alinks">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
    </button>
    <a href="#calcola" class="abtn abtn-solid amag">Valuta ora</a>
  </header>

  <main id="main">
  <!-- HERO -->
  <section class="ahero" id="top">
    <div class="ahero-bg" aria-hidden="true">
      <img src="/img/demo-oro/hero.webp" alt="" />
      <div class="ahero-shade"></div>
    </div>
    <div class="ahero-inner">
      <div class="ahero-text">
        <p class="aeyebrow hl"><span class="dot"></span> Compro oro · Torino · dal 2004</p>
        <h1 class="ahero-title">
          <span class="al"><span class="aw">Il tuo oro</span></span>
          <span class="al"><span class="aw it">vale di più.</span></span>
          <span class="al"><span class="aw">Te lo dimostriamo.</span></span>
        </h1>
        <p class="ahero-sub hl">Valutazione <b>gratuita e senza impegno</b>, davanti ai tuoi occhi. Se ti convince, paghiamo <b>subito in contanti</b>. Niente attese, niente sorprese.</p>
        <div class="ahero-cta hl">
          <a href="#calcola" class="abtn abtn-solid amag">Calcola quanto vale</a>
          <a href="tel:+390110000000" class="abtn abtn-ghost">📞 011 000 0000</a>
        </div>
        <ul class="ahero-trust hl">
          <li><span class="seal" aria-hidden="true">✓</span>Iscritti OAM</li>
          <li><span class="seal" aria-hidden="true">✓</span>Bilancia certificata</li>
          <li><span class="seal" aria-hidden="true">✓</span>Massima riservatezza</li>
        </ul>
      </div>
    </div>
    <a href="#calcola" class="ascroll" aria-hidden="true"><span></span></a>
  </section>

  <!-- CALCOLATORE -->
  <section class="asection acalc" id="calcola">
    <div class="ahead">
      <span class="akicker r">Valutazione istantanea</span>
      <h2 class="r">Scopri <span class="it">quanto vale</span></h2>
      <p class="alead r">Sposta il peso, scegli i carati: ti diamo subito una stima. La valutazione vera, in negozio, è gratis e senza impegno.</p>
    </div>

    <div class="calc-card r">
      <div class="calc-controls">
        <div class="calc-field">
          <div class="calc-label"><span>Metallo</span></div>
          <div class="seg" id="metalSeg">
            <button class="seg-b is-on" data-metal="oro">Oro</button>
            <button class="seg-b" data-metal="argento">Argento</button>
          </div>
        </div>

        <div class="calc-field" id="karatField">
          <div class="calc-label"><span>Caratura</span></div>
          <div class="seg seg-wrap" id="karatSeg">
            <button class="seg-b" data-g="28.60">9kt</button>
            <button class="seg-b" data-g="44.20">14kt</button>
            <button class="seg-b is-on" data-g="57.30">18kt</button>
            <button class="seg-b" data-g="69.80">22kt</button>
            <button class="seg-b" data-g="76.40">24kt</button>
          </div>
        </div>

        <div class="calc-field">
          <div class="calc-label"><span>Peso</span><b id="gramOut">20 g</b></div>
          <input type="range" id="gram" min="1" max="300" value="20" step="1" aria-label="Peso in grammi" />
          <div class="calc-presets">
            <button data-set="5">Anellino · 5g</button>
            <button data-set="12">Bracciale · 12g</button>
            <button data-set="35">Collana · 35g</button>
            <button data-set="80">Lotto · 80g</button>
          </div>
        </div>
      </div>

      <div class="calc-out">
        <span class="calc-out-lbl">Valutazione stimata</span>
        <div class="calc-amount"><span id="amount">€ 1.146</span></div>
        <span class="calc-range" id="range">tra € 1.089 e € 1.203</span>
        <a href="#contatti" class="abtn abtn-solid amag calc-cta">Fissa la valutazione gratuita</a>
        <p class="calc-note">Stima indicativa su quotazioni del giorno. Nessun impegno.</p>
      </div>
    </div>
  </section>

  <!-- TRASPARENZA -->
  <section class="asection atrasp">
    <div class="ahead">
      <span class="akicker r">Massima trasparenza</span>
      <h2 class="r">Quanto prendi <span class="it">davvero</span></h2>
      <p class="alead r">Niente cifre gonfiate al telefono e poi tagliate al banco. Si parte dalla quotazione ufficiale del giorno: questo è quello che vedi succedere, passo per passo.</p>
    </div>
    <div class="trasp r">
      <div class="trasp-step">
        <span class="trasp-pct">100%</span>
        <b>Quotazione del giorno</b>
        <span class="trasp-d">Il valore di mercato del tuo oro, aggiornato a oggi.</span>
        <div class="trasp-bar"><i style="width:100%"></i></div>
      </div>
      <div class="trasp-arrow" aria-hidden="true">→</div>
      <div class="trasp-step is-ours">
        <span class="trasp-pct">95%*</span>
        <b>La nostra valutazione</b>
        <span class="trasp-d">Tra le più alte di Torino: tratteniamo solo il minimo per la lavorazione.</span>
        <div class="trasp-bar"><i style="width:95%"></i></div>
      </div>
      <div class="trasp-arrow" aria-hidden="true">→</div>
      <div class="trasp-step">
        <span class="trasp-pct">subito</span>
        <b>In contanti, in mano</b>
        <span class="trasp-d">Accetti? Ricevi i soldi all'istante, con regolare ricevuta.</span>
        <div class="trasp-bar"><i style="width:95%"></i></div>
      </div>
    </div>
    <p class="trasp-note r">* Percentuale media indicativa: la valutazione reale dipende da purezza, peso e quotazione del momento.</p>
  </section>

  <!-- COME FUNZIONA -->
  <section class="asection acome" id="come">
    <div class="ahead">
      <span class="akicker r">Semplice e trasparente</span>
      <h2 class="r">Tre passi, <span class="it">zero pensieri</span></h2>
    </div>
    <div class="steps">
      <article class="step r">
        <span class="step-n">01</span>
        <div class="step-ic" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 7l9-4 9 4-9 4-9-4z"/><path d="M3 7v6l9 4 9-4V7"/></svg>
        </div>
        <h3>Porti i tuoi oggetti</h3>
        <p>Oro, gioielli anche rotti, monete, argento, orologi. Vieni in negozio quando vuoi, senza appuntamento.</p>
      </article>
      <article class="step r">
        <span class="step-n">02</span>
        <div class="step-ic" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 3v3M5 9h14M5 9l-2 6a4 4 0 008 0L5 9zM19 9l-2 6a4 4 0 008 0l-2-6M12 6v15M8 21h8"/></svg>
        </div>
        <h3>Pesiamo e valutiamo</h3>
        <p>Bilancia certificata e test sui carati <b>davanti a te</b>. Ti spieghiamo ogni numero: capisci esattamente quanto vale.</p>
      </article>
      <article class="step r">
        <span class="step-n">03</span>
        <div class="step-ic" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="3"/><path d="M6 12h.01M18 12h.01"/></svg>
        </div>
        <h3>Ti paghiamo subito</h3>
        <p>Se accetti, ricevi i <b>contanti immediatamente</b> (o bonifico, come preferisci). Tutto regolare, con ricevuta.</p>
      </article>
    </div>
  </section>

  <!-- COSA COMPRIAMO -->
  <section class="asection acompra" id="compriamo">
    <div class="ahead">
      <span class="akicker r">Ritiriamo di tutto</span>
      <h2 class="r">Cosa <span class="it">compriamo</span></h2>
    </div>
    <div class="buy-grid">
      <div class="buy r"><span class="buy-em">🟡</span><b>Oro</b><span>Anche rotto, spaiato o usurato</span></div>
      <div class="buy r"><span class="buy-em">💍</span><b>Gioielli</b><span>Anelli, collane, bracciali, orecchini</span></div>
      <div class="buy r"><span class="buy-em">🪙</span><b>Monete</b><span>Sterline, marenghi, numismatica</span></div>
      <div class="buy r"><span class="buy-em">⚪</span><b>Argento</b><span>Posate, vassoi, lingotti, monili</span></div>
      <div class="buy r"><span class="buy-em">⌚</span><b>Orologi</b><span>Da polso e da tasca di pregio</span></div>
      <div class="buy r"><span class="buy-em">💎</span><b>Diamanti</b><span>Brillanti e pietre certificate</span></div>
    </div>
  </section>

  <!-- FIDUCIA -->
  <section class="asection afiducia" id="fiducia">
    <div class="fid-grid">
      <div class="fid-text">
        <span class="akicker r">Perché Aureo</span>
        <h2 class="r">La differenza è la <span class="it">fiducia</span></h2>
        <p class="r">Un compro oro serio non è quello che promette di più al telefono: è quello che ti fa vedere ogni passaggio. Da noi pesi, carati e quotazione sono sotto i tuoi occhi.</p>
        <ul class="fid-list">
          <li class="r"><b>Iscritti OAM</b> — operatori professionali in oro, a norma di legge.</li>
          <li class="r"><b>Bilancia certificata</b> e periti interni: nessun trucco sul peso.</li>
          <li class="r"><b>Riservatezza totale</b> — sala privata, nessun dato condiviso.</li>
          <li class="r"><b>Pagamento immediato</b> in contanti o bonifico, con ricevuta.</li>
        </ul>
      </div>
      <div class="fid-stats">
        <div class="fid-stat r"><b data-count="21">0</b><span>anni a Torino</span></div>
        <div class="fid-stat r"><b data-count="38000" data-suffix="+">0</b><span>clienti serviti</span></div>
        <div class="fid-stat r"><b data-count="100" data-suffix="%">0</b><span>valutazioni gratuite</span></div>
        <div class="fid-stat r"><b data-count="10" data-prefix="< ">0</b><span>minuti d'attesa</span></div>
      </div>
    </div>
  </section>

  <!-- RECENSIONI -->
  <section class="asection arev">
    <div class="ahead">
      <span class="akicker r">Dicono di noi</span>
      <h2 class="r">Clienti <span class="it">soddisfatti</span></h2>
      <div class="rev-badge r"><span class="stars">★★★★★</span> <b>4,9</b> su 5 · <span>312 recensioni Google</span></div>
    </div>
    <div class="rev-grid">
      <figure class="rev r"><div class="stars">★★★★★</div><blockquote>"Mi avevano offerto molto meno altrove. Qui hanno pesato tutto davanti a me e spiegato i carati. Pagamento immediato."</blockquote><figcaption>— Marta R., Torino</figcaption></figure>
      <figure class="rev r"><div class="stars">★★★★★</div><blockquote>"Serietà e riservatezza. Ho venduto i gioielli di famiglia senza sentirmi sotto pressione. Consigliatissimi."</blockquote><figcaption>— Giuseppe L., Moncalieri</figcaption></figure>
      <figure class="rev r"><div class="stars">★★★★★</div><blockquote>"Valutazione gratis e senza impegno davvero. Sono uscito col contante in mano in dieci minuti."</blockquote><figcaption>— Aldo P., Torino</figcaption></figure>
    </div>
  </section>

  <!-- FAQ -->
  <section class="asection afaq" id="faq">
    <div class="ahead">
      <span class="akicker r">Domande frequenti</span>
      <h2 class="r">Tutto quello che <span class="it">vuoi sapere</span></h2>
    </div>
    <div class="faq r">
      <details class="faq-i"><summary>Serve un documento per vendere l'oro?<span class="faq-x" aria-hidden="true"></span></summary><div class="faq-a">Sì: per legge serve un documento d'identità valido e bisogna essere maggiorenni. È una garanzia di trasparenza per te e per noi — ogni operazione è tracciata e accompagnata da regolare ricevuta.</div></details>
      <details class="faq-i"><summary>È tutto legale?<span class="faq-x" aria-hidden="true"></span></summary><div class="faq-a">Assolutamente. Siamo operatori professionali iscritti all'OAM e rispettiamo le norme antiriciclaggio. Ricevi sempre una ricevuta con i dettagli della valutazione e del pagamento.</div></details>
      <details class="faq-i"><summary>Quanto tempo ci vuole?<span class="faq-x" aria-hidden="true"></span></summary><div class="faq-a">Pochi minuti. Pesiamo e valutiamo davanti a te; se accetti, paghiamo subito. In media esci dal negozio in meno di dieci minuti.</div></details>
      <details class="faq-i"><summary>Come venite pagato: contanti o bonifico?<span class="faq-x" aria-hidden="true"></span></summary><div class="faq-a">Come preferisci tu: contanti immediati nei limiti consentiti dalla legge, oppure bonifico bancario tracciato. Nessun costo aggiuntivo in entrambi i casi.</div></details>
      <details class="faq-i"><summary>Comprate anche oro rotto o spaiato?<span class="faq-x" aria-hidden="true"></span></summary><div class="faq-a">Certo. Anelli rotti, orecchini spaiati, catenine annodate: conta il metallo e la sua purezza, non l'estetica. Portali pure così come sono.</div></details>
      <details class="faq-i"><summary>La valutazione è davvero gratuita?<span class="faq-x" aria-hidden="true"></span></summary><div class="faq-a">Sì, gratuita e senza alcun impegno. Ti facciamo valutare gli oggetti, sai quanto valgono e decidi con calma. Se non ti convince, te li riporti a casa.</div></details>
    </div>
  </section>

  <!-- DOVE SIAMO -->
  <section class="asection adove">
    <div class="dove-grid">
      <div class="dove-map r">
        <svg viewBox="0 0 400 300" class="mapsvg" role="img" aria-label="Mappa stilizzata della zona del negozio">
          <rect width="400" height="300" fill="#0c0905"/>
          <g stroke="#241c10" stroke-width="14" stroke-linecap="round"><path d="M-10 70H410"/><path d="M-10 210H410"/><path d="M90 -10V310"/><path d="M300 -10V310"/></g>
          <g stroke="#2e2413" stroke-width="5"><path d="M-10 140H410"/><path d="M190 -10V310"/><path d="M40 -10V310"/><path d="M250 -10V310"/></g>
          <path d="M-10 250C120 200 180 300 410 230" stroke="#16323f" stroke-width="20" fill="none" stroke-linecap="round"/>
          <g><circle cx="206" cy="124" r="26" fill="rgba(232,195,114,.18)"/><circle cx="206" cy="124" r="10" fill="#e8c372"/><path d="M206 134c8 12 14 14 14 22a14 14 0 01-28 0c0-8 6-10 14-22z" fill="#e8c372"/></g>
        </svg>
        <span class="dove-pin">📍 Via Garibaldi 28</span>
      </div>
      <div class="dove-info r">
        <span class="akicker">Dove siamo</span>
        <h2>Nel cuore di <span class="it">Torino</span></h2>
        <div class="open-badge" id="openStatus"><span class="dot"></span><b>—</b><span></span></div>
        <ul class="dove-list">
          <li><b>Indirizzo</b>Via Garibaldi 28, 10122 Torino</li>
          <li><b>Orari</b>Lun–Sab 9:30–19:00 · Domenica chiuso</li>
          <li><b>Come arrivare</b>Metro Porta Nuova · bus 4 e 11 · zona pedonale</li>
          <li><b>Parcheggio</b>Parcheggio Roma a 3 minuti a piedi</li>
        </ul>
        <a class="abtn abtn-ghost" href="https://www.google.com/maps/search/?api=1&query=Via+Garibaldi+28+Torino" target="_blank" rel="noopener">🗺️ Apri in Google Maps</a>
      </div>
    </div>
  </section>

  <!-- CTA / CONTATTI -->
  <section class="asection acta" id="contatti">
    <div class="acta-inner r">
      <span class="akicker">Prenota online</span>
      <h2>Valutazione gratuita<br/><span class="it">e senza impegno.</span></h2>
      <p>Prenota in 30 secondi: ti aspettiamo all'orario che preferisci, senza file.</p>
      <form class="lead" id="leadForm">
        <div class="lead-row">
          <label>Nome<input type="text" name="nome" required placeholder="Il tuo nome" /></label>
          <label>Telefono<input type="tel" name="tel" required placeholder="Es. 333 1234567" /></label>
        </div>
        <div class="lead-row">
          <label>Cosa vuoi valutare<select name="cosa"><option>Gioielli in oro</option><option>Monete / sterline</option><option>Argento</option><option>Orologi</option><option>Diamanti</option><option>Un po' di tutto</option></select></label>
          <label>Quando passi<select name="quando"><option>Oggi</option><option>Domani</option><option>Questa settimana</option><option>Devo ancora decidere</option></select></label>
        </div>
        <button class="abtn abtn-solid amag lead-submit" type="submit">Prenota la valutazione gratuita</button>
        <p class="lead-priv">🔒 Demo: i dati non vengono inviati. Ti ricontatteremmo per confermare l'orario.</p>
      </form>
      <div class="lead-done" id="leadDone" hidden>
        <span class="lead-check">✓</span>
        <h3>Richiesta inviata!</h3>
        <p>Ti ricontatteremmo a breve per confermare l'appuntamento. <br/>(In questa demo nessun dato è stato realmente inviato.)</p>
      </div>
      <p class="resv-sep">oppure contattaci subito</p>
      <div class="acta-actions">
        <a href="tel:+390110000000" class="abtn abtn-ghost">📞 Chiama 011 000 0000</a>
        <a href="https://wa.me/390110000000" target="_blank" rel="noopener" class="abtn abtn-ghost">💬 Scrivici su WhatsApp</a>
      </div>
    </div>
  </section>
  </main>

  <a class="wa-float" href="https://wa.me/390110000000" target="_blank" rel="noopener" aria-label="Scrivici su WhatsApp">
    <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.736-.979a9.864 9.864 0 002.732.272zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
  </a>

  <footer class="afoot">
    <span><b>Aureo</b> · Compro Oro · Via Garibaldi 28, Torino · Iscr. OAM (demo)</span>
    <span>Demo · <a href="/">Mole Digitale</a></span>
  </footer>

  <style is:global>
    :root{
      --bg:#0e0b07; --bg2:#15110b; --panel:#1a140c;
      --gold:#e8c372; --gold-d:#c79a3f; --copper:#c98a4b;
      --cream:#f4ecdd; --muted:#a99b80; --line:rgba(244,236,221,.12);
      --serif:'Playfair Display Variable',Georgia,serif;
      --sans:'Inter Variable',system-ui,sans-serif;
      --ease:cubic-bezier(.16,1,.3,1);
    }
    *{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth;scroll-padding-top:90px}
    @media (prefers-reduced-motion:reduce){html{scroll-behavior:auto}}
    body{background:var(--bg);color:var(--cream);font-family:var(--sans);line-height:1.65;-webkit-font-smoothing:antialiased;overflow-x:hidden}
    img,svg{display:block;max-width:100%}
    a{color:inherit;text-decoration:none}
    h1,h2,h3{font-family:var(--serif);font-weight:600;line-height:1.05;letter-spacing:-.01em}
    .it{font-style:italic;background:linear-gradient(120deg,#f6dca0,var(--gold),#f6dca0);-webkit-background-clip:text;background-clip:text;color:transparent}

    .demo-flag{position:fixed;top:0;left:0;right:0;z-index:300;text-align:center;font-size:.8rem;padding:.4rem;background:rgba(14,11,7,.9);backdrop-filter:blur(8px);border-bottom:1px solid var(--line);color:var(--muted)}
    .demo-flag b{color:var(--gold)}

    /* Ticker */
    .ticker{position:fixed;top:30px;left:0;right:0;z-index:160;overflow:hidden;background:linear-gradient(90deg,#1a140c,#221a0f);border-bottom:1px solid var(--line);height:34px;display:flex;align-items:center;white-space:nowrap;-webkit-mask-image:linear-gradient(90deg,transparent,#000 6%,#000 94%,transparent)}
    .ticker-row{display:inline-flex;gap:2.4rem;padding-left:2.4rem;animation:ticker 38s linear infinite;will-change:transform}
    .tk{font-size:.82rem;color:var(--muted);letter-spacing:.02em;display:inline-flex;align-items:center;gap:.5rem}
    .tk b{color:var(--gold);font-weight:600}
    .tk i{width:6px;height:6px;border-radius:50%;background:var(--gold);box-shadow:0 0 8px var(--gold);display:inline-block}
    @keyframes ticker{to{transform:translateX(-50%)}}

    /* NAV */
    .anav{position:fixed;top:64px;left:0;right:0;z-index:150;display:flex;align-items:center;gap:1.4rem;padding:1rem clamp(1rem,4vw,3rem);transition:.4s var(--ease)}
    .anav.solid{background:rgba(14,11,7,.86);backdrop-filter:blur(14px);border-bottom:1px solid var(--line);padding-top:.7rem;padding-bottom:.7rem}
    .abrand{font-family:var(--serif);font-size:1.5rem;font-weight:700;display:inline-flex;align-items:center;gap:.6rem;letter-spacing:.01em}
    .abrand em{color:var(--gold);font-style:normal}
    .ingot{width:26px;height:16px;border-radius:3px;background:linear-gradient(160deg,#fbe6b6,#dcab43 55%,#9c6f1f);box-shadow:0 0 0 1px rgba(255,255,255,.25) inset,0 6px 16px -6px rgba(232,195,114,.8);flex:none}
    .alinks{display:flex;gap:1.7rem;margin-left:auto}
    .alinks a{font-size:.95rem;color:var(--muted);position:relative;transition:color .25s}
    .alinks a::after{content:'';position:absolute;left:0;bottom:-5px;height:1px;width:0;background:var(--gold);transition:width .3s var(--ease)}
    .alinks a:hover{color:var(--cream)} .alinks a:hover::after{width:100%}
    .anav-toggle{display:none;background:none;border:0;color:var(--cream);cursor:pointer;width:42px;height:42px;border-radius:10px;margin-left:auto}

    .abtn{display:inline-flex;align-items:center;justify-content:center;gap:.5rem;padding:.85rem 1.6rem;border-radius:999px;font-weight:600;font-size:.95rem;cursor:pointer;transition:transform .25s var(--ease),background .25s,box-shadow .25s;white-space:nowrap;font-family:var(--sans);border:1px solid transparent}
    .abtn-solid{background:linear-gradient(135deg,#f3d488,var(--gold) 60%,var(--gold-d));color:#27190a;box-shadow:0 14px 32px -12px rgba(232,195,114,.75)}
    .abtn-solid:hover{transform:translateY(-3px);box-shadow:0 20px 40px -12px rgba(232,195,114,.9)}
    .abtn-ghost{border-color:var(--line);color:var(--cream)}
    .abtn-ghost:hover{background:rgba(244,236,221,.06);transform:translateY(-3px);border-color:rgba(232,195,114,.4)}

    /* HERO */
    .ahero{position:relative;min-height:100vh;display:flex;align-items:center;overflow:hidden;padding-top:110px}
    .ahero-bg{position:absolute;inset:0;z-index:0}
    .ahero-bg img{width:100%;height:100%;object-fit:cover;object-position:center right;transform-origin:center}
    .ahero-shade{position:absolute;inset:0;background:
      linear-gradient(90deg,rgba(14,11,7,.95) 24%,rgba(14,11,7,.6) 64%,rgba(14,11,7,.32)),
      linear-gradient(180deg,rgba(14,11,7,.35),rgba(14,11,7,.55))}
    .ahero-inner{position:relative;z-index:2;max-width:1180px;margin:0 auto;width:100%;padding:1rem clamp(1.2rem,5vw,3rem) 4rem}
    .ahero-text{max-width:640px}
    .aeyebrow{font-size:.82rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:1.4rem;display:inline-flex;align-items:center;gap:.55rem}
    .aeyebrow .dot{width:7px;height:7px;border-radius:50%;background:var(--gold);box-shadow:0 0 10px var(--gold);animation:pulse 2s var(--ease) infinite}
    @keyframes pulse{0%,100%{opacity:.4;transform:scale(.85)}50%{opacity:1;transform:scale(1.15)}}
    .ahero-title{font-size:clamp(2.6rem,6.4vw,5rem);margin-bottom:1.6rem}
    .ahero-title .al{display:block;overflow:hidden;padding-block:.1em;margin-block:-.06em}
    .ahero-title .aw{display:inline-block}
    .ahero-sub{max-width:520px;font-size:1.15rem;color:#e6dcc9;margin-bottom:2.2rem}
    .ahero-sub b{color:var(--cream)}
    .ahero-cta{display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:1.6rem}
    /* chip-sigillo (trust/credentials) — firma distinta dell'hero Aureo */
    .ahero-trust{list-style:none;display:flex;gap:.6rem;flex-wrap:wrap}
    .ahero-trust li{white-space:nowrap;display:inline-flex;align-items:center;gap:.5rem;border:1px solid var(--line);border-radius:999px;padding:.45rem .95rem .45rem .55rem;font-size:.82rem;color:var(--cream);background:rgba(244,236,221,.03)}
    .ahero-trust .seal{width:20px;height:20px;border-radius:50%;display:grid;place-items:center;background:rgba(232,195,114,.16);color:var(--gold);font-size:.7rem;font-weight:700;flex:none}
    .ahero-art{position:relative}
    .goldstack{width:100%;height:auto;filter:drop-shadow(0 30px 50px rgba(0,0,0,.5))}
    .goldstack .bar,.goldstack .coin{transform-box:fill-box;transform-origin:center}
    .coin-a{animation:floaty 5.5s ease-in-out infinite}
    .coin-b{animation:floaty 4.5s ease-in-out infinite reverse}
    @keyframes floaty{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
    .sheen{animation:sweep 4.5s var(--ease) infinite}
    @keyframes sweep{0%{transform:skewX(-22deg) translateX(0)}55%,100%{transform:skewX(-22deg) translateX(820px)}}
    .ascroll{position:absolute;bottom:1.4rem;left:50%;transform:translateX(-50%);z-index:2;width:26px;height:42px;border:1px solid rgba(244,236,221,.4);border-radius:14px}
    .ascroll span{position:absolute;top:8px;left:50%;transform:translateX(-50%);width:4px;height:8px;border-radius:2px;background:var(--gold);animation:ddot 1.6s var(--ease) infinite}
    @keyframes ddot{0%{opacity:0;top:8px}40%{opacity:1}80%{opacity:0;top:22px}100%{opacity:0}}

    /* SECTIONS */
    .asection{max-width:1180px;margin:0 auto;padding:clamp(4.5rem,10vw,8rem) clamp(1.2rem,5vw,3rem)}
    main{counter-reset:asec}
    .ahead{text-align:left;max-width:820px;margin:0 0 clamp(2.5rem,5vw,4rem);counter-increment:asec;padding-left:1.4rem;border-left:2px solid var(--gold)}
    .ahead .akicker::before{content:counter(asec,decimal-leading-zero) "  ·  ";font-family:var(--serif);color:var(--gold)}
    .akicker{display:inline-block;font-size:.78rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem}
    .ahead h2,.fid-text h2,.acta h2{font-size:clamp(2rem,5vw,3.4rem)}
    .alead{color:var(--muted);font-size:1.1rem;margin-top:.6rem;max-width:62ch}

    /* CALCOLATORE */
    .calc-card{display:grid;grid-template-columns:1.2fr .8fr;gap:0;border:1px solid var(--line);border-radius:22px;overflow:hidden;background:linear-gradient(180deg,#181208,#120d07);box-shadow:0 40px 80px -40px rgba(0,0,0,.7)}
    .calc-controls{padding:clamp(1.6rem,3vw,2.4rem)}
    .calc-field{margin-bottom:1.7rem}
    .calc-field:last-child{margin-bottom:0}
    .calc-label{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:.7rem;font-size:.8rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}
    .calc-label b{font-family:var(--serif);font-size:1.2rem;color:var(--gold);letter-spacing:0;text-transform:none}
    .seg{display:inline-flex;background:rgba(0,0,0,.35);border:1px solid var(--line);border-radius:12px;padding:.3rem;gap:.3rem}
    .seg-wrap{display:flex;flex-wrap:wrap}
    .seg-b{background:none;border:0;color:var(--muted);font-family:var(--sans);font-weight:600;font-size:.92rem;padding:.55rem 1rem;border-radius:9px;cursor:pointer;transition:all .2s}
    .seg-b:hover{color:var(--cream)}
    .seg-b.is-on{background:linear-gradient(135deg,#f3d488,var(--gold-d));color:#27190a}
    input[type=range]{-webkit-appearance:none;appearance:none;width:100%;height:6px;border-radius:999px;background:linear-gradient(90deg,var(--gold) var(--p,16%),rgba(244,236,221,.16) var(--p,16%));outline:none;margin:.3rem 0 1rem}
    input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;appearance:none;width:24px;height:24px;border-radius:50%;background:radial-gradient(circle at 35% 30%,#fff3cf,var(--gold) 55%,var(--gold-d));cursor:pointer;border:2px solid #2a1f0c;box-shadow:0 4px 14px -2px rgba(232,195,114,.8)}
    input[type=range]::-moz-range-thumb{width:22px;height:22px;border-radius:50%;background:var(--gold);cursor:pointer;border:2px solid #2a1f0c}
    .calc-presets{display:flex;gap:.5rem;flex-wrap:wrap}
    .calc-presets button{background:rgba(244,236,221,.05);border:1px solid var(--line);color:var(--muted);font-family:var(--sans);font-size:.8rem;padding:.4rem .8rem;border-radius:999px;cursor:pointer;transition:all .2s}
    .calc-presets button:hover{border-color:var(--gold);color:var(--gold)}
    .calc-out{background:radial-gradient(120% 120% at 80% 0%,rgba(232,195,114,.16),transparent 60%),#0c0905;border-left:1px solid var(--line);padding:clamp(1.6rem,3vw,2.4rem);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center}
    .calc-out-lbl{font-size:.78rem;letter-spacing:.18em;text-transform:uppercase;color:var(--muted)}
    .calc-amount{font-family:var(--serif);font-size:clamp(2.6rem,6vw,3.8rem);font-weight:700;margin:.5rem 0 .2rem;
      background:linear-gradient(120deg,#fbe6b6,var(--gold),#fbe6b6);-webkit-background-clip:text;background-clip:text;color:transparent;line-height:1}
    .calc-range{color:var(--muted);font-size:.92rem}
    .calc-cta{margin-top:1.6rem;width:100%}
    .calc-note{font-size:.76rem;color:var(--muted);margin-top:.8rem;opacity:.85}

    /* STEPS */
    .steps{display:grid;grid-template-columns:repeat(3,1fr);gap:1.4rem}
    .step{position:relative;background:linear-gradient(180deg,var(--panel),#120d07);border:1px solid var(--line);border-radius:18px;padding:2rem 1.6rem 1.8rem;overflow:hidden}
    .step-n{font-family:var(--serif);font-size:3rem;color:rgba(232,195,114,.16);position:absolute;top:.6rem;right:1.2rem;line-height:1}
    .step-ic{width:52px;height:52px;border-radius:14px;display:grid;place-items:center;color:var(--gold);background:rgba(232,195,114,.1);border:1px solid rgba(232,195,114,.25);margin-bottom:1.2rem}
    .step-ic svg{width:26px;height:26px}
    .step h3{font-size:1.35rem;margin-bottom:.5rem}
    .step p{color:var(--muted);font-size:.97rem}
    .step b{color:var(--cream)}

    /* COSA COMPRIAMO */
    .buy-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}
    .buy{background:rgba(244,236,221,.03);border:1px solid var(--line);border-radius:16px;padding:1.5rem;transition:transform .3s var(--ease),border-color .3s,background .3s}
    .buy:hover{transform:translateY(-5px);border-color:rgba(232,195,114,.45);background:rgba(232,195,114,.06)}
    .buy-em{font-size:1.7rem;display:block;margin-bottom:.7rem}
    .buy b{font-family:var(--serif);font-size:1.3rem;display:block;margin-bottom:.2rem}
    .buy span{color:var(--muted);font-size:.92rem}

    /* FIDUCIA */
    .fid-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:clamp(2rem,5vw,4rem);align-items:center}
    .fid-text p{color:var(--muted);margin:1rem 0 1.6rem;font-size:1.05rem}
    .fid-text h2{margin-top:.5rem}
    .fid-list{list-style:none;display:flex;flex-direction:column;gap:.9rem}
    .fid-list li{position:relative;padding-left:1.8rem;color:var(--muted);font-size:1rem}
    .fid-list li::before{content:'✓';position:absolute;left:0;top:0;color:var(--gold);font-weight:700}
    .fid-list b{color:var(--cream)}
    .fid-stats{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
    .fid-stat{background:linear-gradient(180deg,var(--panel),#120d07);border:1px solid var(--line);border-radius:16px;padding:1.6rem 1.2rem;text-align:center}
    .fid-stat b{font-family:var(--serif);font-size:2.4rem;color:var(--gold);display:block;line-height:1}
    .fid-stat span{color:var(--muted);font-size:.85rem;margin-top:.3rem;display:block}

    /* RECENSIONI */
    .rev-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.4rem}
    .rev{background:rgba(244,236,221,.03);border:1px solid var(--line);border-radius:18px;padding:1.8rem}
    .stars{color:var(--gold);letter-spacing:.15em;margin-bottom:.9rem}
    .rev blockquote{font-family:var(--serif);font-size:1.08rem;font-style:italic;line-height:1.5;color:var(--cream)}
    .rev figcaption{margin-top:1rem;color:var(--muted);font-size:.9rem}

    /* CTA */
    .acta{position:relative;text-align:center;max-width:820px}
    .acta-inner{background:radial-gradient(120% 120% at 50% 0%,rgba(232,195,114,.14),transparent 60%),linear-gradient(180deg,var(--panel),#100c06);border:1px solid var(--line);border-radius:26px;padding:clamp(2.6rem,6vw,4.5rem) clamp(1.4rem,5vw,3rem)}
    .acta-inner h2{font-size:clamp(2rem,5.5vw,3.6rem);margin:.3rem 0 1rem}
    .acta-inner p{color:var(--muted);max-width:440px;margin:0 auto 2rem}
    .acta-actions{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
    .ainfo{display:flex;gap:2.2rem;justify-content:center;flex-wrap:wrap;margin-top:2.6rem;padding-top:2rem;border-top:1px solid var(--line)}
    .ainfo b{display:block;font-family:var(--serif);color:var(--gold);font-size:1.05rem}
    .ainfo span{color:var(--muted);font-size:.9rem}

    .afoot{max-width:1180px;margin:0 auto;padding:2rem clamp(1.2rem,5vw,3rem);display:flex;justify-content:space-between;gap:1rem;flex-wrap:wrap;color:var(--muted);font-size:.82rem;border-top:1px solid var(--line)}
    .afoot b{color:var(--cream)}
    .afoot a{color:var(--gold)}

    /* TRASPARENZA */
    .trasp{display:grid;grid-template-columns:1fr auto 1fr auto 1fr;gap:1rem;align-items:stretch}
    .trasp-step{background:linear-gradient(180deg,var(--panel),#120d07);border:1px solid var(--line);border-radius:16px;padding:1.6rem;display:flex;flex-direction:column;gap:.4rem}
    .trasp-step.is-ours{border-color:rgba(232,195,114,.5);box-shadow:0 0 0 1px rgba(232,195,114,.2),0 30px 60px -40px rgba(232,195,114,.6)}
    .trasp-pct{font-family:var(--serif);font-size:2.1rem;color:var(--gold);line-height:1}
    .trasp-step b{font-size:1.05rem}
    .trasp-d{color:var(--muted);font-size:.9rem;flex:1}
    .trasp-bar{height:7px;border-radius:999px;background:rgba(244,236,221,.1);overflow:hidden;margin-top:.6rem}
    .trasp-bar i{display:block;height:100%;background:linear-gradient(90deg,var(--gold-d),var(--gold));border-radius:999px}
    .trasp-arrow{align-self:center;color:var(--gold);font-size:1.5rem}
    .trasp-note{text-align:center;color:var(--muted);font-size:.82rem;margin-top:1.5rem;opacity:.85}

    /* Reviews badge */
    .rev-badge{display:inline-flex;align-items:center;gap:.4rem;margin-top:1rem;color:var(--muted);font-size:.96rem;flex-wrap:wrap;justify-content:center}
    .rev-badge b{font-family:var(--serif);font-size:1.3rem;color:var(--cream)}
    .rev-badge .stars{color:var(--gold);letter-spacing:.1em}

    /* FAQ */
    .afaq{max-width:880px}
    .faq{display:flex;flex-direction:column;gap:.8rem}
    .faq-i{background:rgba(244,236,221,.03);border:1px solid var(--line);border-radius:14px;overflow:hidden;transition:border-color .25s}
    .faq-i[open]{border-color:rgba(232,195,114,.4)}
    .faq-i summary{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:1.1rem 1.3rem;cursor:pointer;font-family:var(--serif);font-size:1.12rem;color:var(--cream);list-style:none}
    .faq-i summary::-webkit-details-marker{display:none}
    /* toggle FAQ: cerchio oro che si riempie (firma Aureo) */
    .faq-x{position:relative;width:26px;height:26px;flex:none;border:1px solid rgba(232,195,114,.45);border-radius:50%;transition:background .3s,border-color .3s}
    .faq-x::before,.faq-x::after{content:'';position:absolute;background:var(--gold);transition:transform .3s var(--ease),opacity .3s,background .3s}
    .faq-x::before{top:12px;left:6px;width:14px;height:2px}
    .faq-x::after{top:6px;left:12px;width:2px;height:14px}
    .faq-i[open] .faq-x{background:var(--gold);border-color:var(--gold)}
    .faq-i[open] .faq-x::before{background:#27190a}
    .faq-i[open] .faq-x::after{transform:rotate(90deg);opacity:0}
    .faq-a{padding:0 1.3rem 1.2rem;color:var(--muted);font-size:.98rem}

    /* DOVE SIAMO */
    .dove-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(1.5rem,4vw,3rem);align-items:center}
    .dove-map{position:relative;border-radius:18px;overflow:hidden;border:1px solid var(--line);background:#0c0905;aspect-ratio:4/3}
    .mapsvg{width:100%;height:100%;object-fit:cover}
    .dove-pin{position:absolute;left:1rem;bottom:1rem;background:rgba(14,11,7,.85);backdrop-filter:blur(6px);border:1px solid var(--line);padding:.4rem .8rem;border-radius:999px;font-size:.85rem;color:var(--gold)}
    .dove-info h2{margin:.3rem 0 1rem}
    .dove-list{list-style:none;display:flex;flex-direction:column;gap:.7rem;margin:1.2rem 0 1.6rem}
    .dove-list li{color:var(--muted);font-size:.96rem}
    .dove-list b{display:block;color:var(--cream);font-family:var(--serif);font-size:.95rem;margin-bottom:.1rem}
    .open-badge{display:inline-flex;align-items:center;gap:.55rem;padding:.5rem .9rem;border-radius:999px;border:1px solid var(--line);font-size:.9rem;color:var(--muted)}
    .open-badge .dot{width:9px;height:9px;border-radius:50%;background:#d9694e;box-shadow:0 0 8px #d9694e;flex:none}
    .open-badge.is-open .dot{background:#5cba5c;box-shadow:0 0 8px #5cba5c}
    .open-badge b{color:var(--cream)}

    /* LEAD FORM */
    .lead{display:flex;flex-direction:column;gap:.9rem;max-width:560px;margin:0 auto 1.2rem;text-align:left}
    .lead-row{display:grid;grid-template-columns:1fr 1fr;gap:.9rem}
    .lead label{display:flex;flex-direction:column;gap:.35rem;font-size:.72rem;letter-spacing:.06em;text-transform:uppercase;color:var(--muted)}
    .lead input,.lead select{padding:.75rem .9rem;border-radius:10px;border:1px solid var(--line);background:rgba(0,0,0,.35);color:var(--cream);font-family:var(--sans);font-size:.95rem}
    .lead input:focus,.lead select:focus{outline:none;border-color:var(--gold)}
    .lead select option{color:#241a0c}
    .lead-submit{margin-top:.3rem;width:100%}
    .lead-priv{font-size:.76rem;color:var(--muted);text-align:center}
    .lead-done{max-width:520px;margin:0 auto 1.2rem;text-align:center;background:rgba(232,195,114,.08);border:1px solid rgba(232,195,114,.4);border-radius:16px;padding:2rem}
    .lead-check{display:inline-grid;place-items:center;width:54px;height:54px;border-radius:50%;background:var(--gold);color:#27190a;font-size:1.6rem;margin-bottom:.8rem}
    .lead-done h3{font-size:1.4rem;margin-bottom:.4rem}
    .lead-done p{color:var(--muted)}
    .resv-sep{color:var(--muted);font-size:.85rem;margin:.2rem 0 1.1rem}

    /* WhatsApp float */
    .wa-float{position:fixed;right:18px;bottom:18px;z-index:350;width:56px;height:56px;border-radius:50%;background:#25d366;color:#fff;display:grid;place-items:center;box-shadow:0 12px 30px -8px rgba(37,211,102,.7);transition:transform .25s var(--ease)}
    .wa-float:hover{transform:scale(1.08) translateY(-2px)}
    .wa-float::after{content:'';position:absolute;inset:0;border-radius:50%;border:2px solid #25d366;animation:wapulse 2.4s ease-out infinite}
    @keyframes wapulse{0%{transform:scale(1);opacity:.7}100%{transform:scale(1.6);opacity:0}}

    /* Reveal — "messa a fuoco" (blur-in), firma di Aureo */
    .r{opacity:0;transform:translateY(20px);filter:blur(8px)}
    .hl{opacity:0}

    @media (max-width:980px){
      /* hero full-bleed: testo a sinistra leggibile, overlay più scuro su mobile */
      .ahero-shade{background:linear-gradient(180deg,rgba(14,11,7,.55),rgba(14,11,7,.74) 45%,rgba(14,11,7,.95))}
      .ahero-bg img{object-position:center}
      .calc-card{grid-template-columns:1fr}
      .calc-out{border-left:0;border-top:1px solid var(--line)}
      .fid-grid{grid-template-columns:1fr}
      .trasp{grid-template-columns:1fr}
      .trasp-arrow{transform:rotate(90deg);justify-self:center}
      .dove-grid{grid-template-columns:1fr}
    }
    @media (max-width:760px){
      .alinks{display:none}
      .anav-toggle{display:grid;place-items:center}
      .anav>.abtn-solid{display:none}
      .anav.open .alinks{display:flex;position:absolute;top:100%;left:0;right:0;flex-direction:column;gap:1.1rem;
        background:rgba(14,11,7,.97);backdrop-filter:blur(14px);border-bottom:1px solid var(--line);padding:1.2rem clamp(1.2rem,5vw,3rem) 1.5rem;margin:0}
      .anav.open .alinks a{font-size:1.05rem}
      .steps,.buy-grid,.rev-grid{grid-template-columns:1fr}
      .fid-stats{grid-template-columns:1fr 1fr}
      .lead-row{grid-template-columns:1fr}
    }
    @media (prefers-reduced-motion:reduce){
      .r,.hl{opacity:1!important;transform:none!important;filter:none!important}
      .sheen,.coin-a,.coin-b,.ticker-row,.aeyebrow .dot,.wa-float::after{animation:none!important}
    }
  </style>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import Lenis from 'lenis';
    import 'lenis/dist/lenis.css';
    gsap.registerPlugin(ScrollTrigger);

    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const fine = matchMedia('(hover:hover) and (pointer:fine)').matches;
    const anav = document.getElementById('anav');
    const onScroll = (y) => anav.classList.toggle('solid', y > 40);

    // menu mobile
    const toggle = document.getElementById('navToggle');
    toggle.addEventListener('click', () => {
      const open = anav.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(open));
    });
    document.querySelectorAll('#alinks a').forEach((a) => a.addEventListener('click', () => anav.classList.remove('open')));

    /* ---- Calcolatore valutazione ---- */
    const gram = document.getElementById('gram');
    const gramOut = document.getElementById('gramOut');
    const amountEl = document.getElementById('amount');
    const rangeEl = document.getElementById('range');
    const karatField = document.getElementById('karatField');
    let perGram = 57.30;   // 18kt default
    let metal = 'oro';
    let shown = 0;

    const euro = (n) => '€ ' + Math.round(n).toLocaleString('it-IT');
    function compute(animate = true) {
      const g = +gram.value;
      gramOut.textContent = g + ' g';
      gram.style.setProperty('--p', ((g - 1) / (300 - 1) * 100) + '%');
      const val = g * perGram;
      rangeEl.textContent = `tra ${euro(val * 0.95)} e ${euro(val * 1.05)}`;
      if (reduced || !animate) { shown = val; amountEl.textContent = euro(val); return; }
      gsap.to({ v: shown }, { v: val, duration: .6, ease: 'power2.out',
        onUpdate() { amountEl.textContent = euro(this.targets()[0].v); },
        onComplete() { shown = val; } });
    }
    gram.addEventListener('input', () => compute());
    document.querySelectorAll('#karatSeg .seg-b').forEach((b) => b.addEventListener('click', () => {
      document.querySelectorAll('#karatSeg .seg-b').forEach((x) => x.classList.remove('is-on'));
      b.classList.add('is-on'); perGram = +b.dataset.g; compute();
    }));
    document.querySelectorAll('#metalSeg .seg-b').forEach((b) => b.addEventListener('click', () => {
      document.querySelectorAll('#metalSeg .seg-b').forEach((x) => x.classList.remove('is-on'));
      b.classList.add('is-on'); metal = b.dataset.metal;
      if (metal === 'argento') { perGram = 0.82; karatField.style.opacity = '.35'; karatField.style.pointerEvents = 'none'; }
      else { karatField.style.opacity = '1'; karatField.style.pointerEvents = 'auto';
        perGram = +document.querySelector('#karatSeg .seg-b.is-on').dataset.g; }
      compute();
    }));
    document.querySelectorAll('.calc-presets button').forEach((b) => b.addEventListener('click', () => {
      gram.value = b.dataset.set; compute();
    }));
    compute(false);

    /* ---- Form prenotazione (demo) ---- */
    const leadForm = document.getElementById('leadForm');
    const leadDone = document.getElementById('leadDone');
    if (leadForm) leadForm.addEventListener('submit', (e) => {
      e.preventDefault();
      leadForm.hidden = true; leadDone.hidden = false;
      leadDone.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth', block: 'center' });
    });

    /* ---- "Aperto adesso" ---- */
    (function () {
      const el = document.getElementById('openStatus'); if (!el) return;
      // getDay: 0=Dom … 6=Sab. Aureo: Lun–Sab 9:30–19:00
      const sched = [null, [570, 1140], [570, 1140], [570, 1140], [570, 1140], [570, 1140], [570, 1140]];
      const days = ['domenica', 'lunedì', 'martedì', 'mercoledì', 'giovedì', 'venerdì', 'sabato'];
      const fmt = (m) => String(Math.floor(m / 60)).padStart(2, '0') + ':' + String(m % 60).padStart(2, '0');
      const now = new Date(), d = now.getDay(), mins = now.getHours() * 60 + now.getMinutes(), t = sched[d];
      let open = false, txt = '';
      if (t && mins >= t[0] && mins < t[1]) { open = true; txt = '· chiude alle ' + fmt(t[1]); }
      else if (t && mins < t[0]) { txt = '· apre oggi alle ' + fmt(t[0]); }
      else { for (let i = 1; i <= 7; i++) { const s = sched[(d + i) % 7]; if (s) { txt = '· ' + (i === 1 ? 'apre domani' : 'apre ' + days[(d + i) % 7]) + ' alle ' + fmt(s[0]); break; } } }
      el.classList.toggle('is-open', open);
      el.querySelector('b').textContent = open ? 'Aperto adesso' : 'Chiuso ora';
      el.querySelector('span:last-child').textContent = ' ' + txt;
    })();

    if (!reduced) {
      const lenis = new Lenis({ lerp: 0.1 });
      const raf = (t) => { lenis.raf(t); requestAnimationFrame(raf); };
      requestAnimationFrame(raf);
      lenis.on('scroll', ({ scroll }) => { onScroll(scroll); ScrollTrigger.update(); });
      document.querySelectorAll('a[href^="#"]').forEach((a) => {
        const h = a.getAttribute('href'); if (!h || h === '#') return;
        const t = document.querySelector(h);
        if (t) a.addEventListener('click', (e) => { e.preventDefault(); lenis.scrollTo(t, { offset: -80 }); });
      });

      const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
      tl.from('.ahero-title .aw', { yPercent: 120, opacity: 0, stagger: 0.09, duration: 1 }, 0.15)
        .to('.ahero-text .hl', { opacity: 1, y: 0, stagger: 0.14, duration: 0.9 }, 0.5)
        .fromTo('.ahero-bg img', { scale: 1.18 }, { scale: 1, duration: 1.8, ease: 'power2.out' }, 0);
      gsap.set('.ahero-text .hl', { y: 20 });

      gsap.utils.toArray('.r').forEach((el) => {
        gsap.to(el, { opacity: 1, y: 0, filter: 'blur(0px)', duration: 0.9, ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 88%' } });
      });
      document.querySelectorAll('[data-count]').forEach((el) => {
        const target = +el.dataset.count, suf = el.dataset.suffix || '', pre = el.dataset.prefix || '';
        ScrollTrigger.create({ trigger: el, start: 'top 92%', once: true, onEnter: () => {
          gsap.to({ v: 0 }, { v: target, duration: 1.6, ease: 'power2.out',
            onUpdate() { el.textContent = pre + Math.round(this.targets()[0].v).toLocaleString('it-IT') + suf; } });
        }});
      });
      if (fine) document.querySelectorAll('.amag').forEach((b) => {
        b.addEventListener('mousemove', (e) => { const r = b.getBoundingClientRect();
          b.style.transform = `translate(${(e.clientX-r.left-r.width/2)*.25}px,${(e.clientY-r.top-r.height/2)*.35}px)`; });
        b.addEventListener('mouseleave', () => { b.style.transform = ''; });
      });
    } else {
      window.addEventListener('scroll', () => onScroll(window.scrollY), { passive: true });
      document.querySelectorAll('[data-count]').forEach((el) => el.textContent = (el.dataset.prefix||'') + (+el.dataset.count).toLocaleString('it-IT') + (el.dataset.suffix||''));
    }
  </script>
</body>
</html>
