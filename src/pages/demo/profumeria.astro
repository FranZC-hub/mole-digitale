---
// DEMO standalone — "Essènza", profumeria artistica a Torino. Tema SCURO luxe (nero + oro).
// Responsive solo flusso (flex/grid/clamp), niente badge absolute. Sito a sé.
import '@fontsource-variable/inter';
import '@fontsource-variable/cormorant';

const fam = [
  { ic: 'citrus', t: 'Agrumati',   d: 'Bergamotto, neroli, pompelmo: freschi e scintillanti.', p: 'Fresco' },
  { ic: 'flower', t: 'Floreali',   d: 'Rosa, gelsomino, fiori bianchi: eleganza senza tempo.', p: 'Elegante' },
  { ic: 'wood',   t: 'Legnosi',    d: 'Sandalo, cedro, vetiver: profondità e calore.',          p: 'Intenso' },
  { ic: 'amber',  t: 'Orientali',  d: 'Ambra, vaniglia, spezie: sensualità avvolgente.',        p: 'Caldo' },
  { ic: 'herb',   t: 'Aromatici',  d: 'Lavanda, salvia, erbe: carattere e freschezza.',         p: 'Deciso' },
  { ic: 'sweet',  t: 'Gourmand',   d: 'Vaniglia, caramello, cacao: dolcezza golosa.',           p: 'Goloso' },
];
const reviews = [
  { n: 'Giulia V.', av: 'G', txt: 'Mi hanno trovato un profumo che è diventato la mia firma. Consulenza vera, non una semplice vendita.' },
  { n: 'Marco T.', av: 'M', txt: 'Brand di nicchia introvabili altrove e competenza pazzesca. Qui il profumo si sceglie con calma.' },
  { n: 'Sara L.', av: 'S', txt: 'Ambiente raffinato e personale gentilissimo. Ho regalato una consulenza a mia madre: emozionata.' },
];
const faq = [
  { q: 'Serve prenotare la consulenza olfattiva?', a: 'È consigliato: così ti dedichiamo tutto il tempo necessario per esplorare con calma. La prima consulenza è gratuita.' },
  { q: 'Posso provare le fragranze sulla pelle?', a: 'Certo. Ogni profumo va vissuto sulla pelle: prepariamo campioncini così puoi valutarlo nelle ore successive.' },
  { q: 'Trattate solo profumeria di nicchia?', a: 'Selezioniamo oltre 200 brand, dai grandi classici alle case artistiche più ricercate, difficili da trovare in Italia.' },
  { q: 'Fate confezioni regalo?', a: 'Sì, ogni acquisto può essere incartato a mano. Disponibili anche gift card per la consulenza olfattiva.' },
];
function icon(n) {
  const w = (p) => `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">${p}</svg>`;
  const m = {
    citrus: '<circle cx="12" cy="12" r="9"/><path d="M12 3v18M3 12h18M5.6 5.6l12.8 12.8M18.4 5.6 5.6 18.4"/>',
    flower: '<circle cx="12" cy="12" r="2.4"/><path d="M12 9.6c0-2.6 1-4.1 0-5.6-1 1.5 0 3 0 5.6M14.4 12c2.6 0 4.1 1 5.6 0-1.5-1-3 0-5.6 0M12 14.4c0 2.6-1 4.1 0 5.6 1-1.5 0-3 0-5.6M9.6 12c-2.6 0-4.1-1-5.6 0 1.5 1 3 0 5.6 0"/>',
    wood: '<path d="M12 21V7"/><path d="M12 11 7.5 6.5M12 15l4.5-4.5M12 8 9 5"/>',
    amber: '<circle cx="12" cy="12" r="4"/><path d="M12 2.5v2M12 19.5v2M2.5 12h2M19.5 12h2M5.2 5.2l1.4 1.4M17.4 17.4l1.4 1.4M18.8 5.2l-1.4 1.4M6.6 17.4l-1.4 1.4"/>',
    herb: '<path d="M12 21V8"/><path d="M12 8c0-3 2.2-5 5.2-5 0 3-2.2 5-5.2 5M12 13c0-2.6-2-4.3-4.7-4.3 0 2.6 2 4.3 4.7 4.3"/>',
    sweet: '<path d="M9.5 8V5.5h5V8M8 8h8l-.9 12.5H8.9z"/><path d="M11 3.5h2"/>',
  };
  return w(m[n] || m.flower);
}
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>Essènza — Profumeria artistica a Torino</title>
  <meta name="description" content="Essènza, profumeria artistica a Torino: oltre 200 brand di nicchia, grandi classici e consulenza olfattiva su misura. Trova la fragranza che ti somiglia." />
  <meta name="theme-color" content="#14110f" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path d='M9.5 8V5.5h5V8M8 8h8l-.9 12.5H8.9z' fill='none' stroke='%23c8a35a' stroke-width='1.6'/></svg>" />
</head>
<body>
  <a class="demo-flag" href="/">★ Demo realizzata da <b>Mole Digitale</b> · torna al sito ↩</a>

  <header class="pfnav" id="pfnav">
    <a href="#top" class="pfbrand">Essènza<span aria-hidden="true">.</span></a>
    <nav class="pflinks" id="pflinks">
      <a href="#famiglie">Fragranze</a>
      <a href="#perche">Consulenza</a>
      <a href="#recensioni">Recensioni</a>
      <a href="#contatti">Contatti</a>
    </nav>
    <button class="pfnav-toggle" id="pfToggle" aria-label="Apri il menu" aria-expanded="false" aria-controls="pflinks"><svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg></button>
    <a href="#contatti" class="pfbtn pfbtn-solid">Prenota</a>
  </header>

  <main id="main">
  <!-- HERO -->
  <section class="pfhero" id="top">
    <div class="pfhero-text">
      <span class="pfkick r"><span class="pfdot"></span>Profumeria artistica · Torino</span>
      <h1 class="r">Il profumo<br/>è <span class="pfmark">memoria</span>.</h1>
      <p class="pfhero-sub r">Nicchia, grandi classici e case artistiche introvabili. Ti accompagniamo a trovare la fragranza che ti somiglia — con calma, sulla tua pelle.</p>
      <div class="pfhero-cta r">
        <a href="#contatti" class="pfbtn pfbtn-solid pfbtn-lg">Prenota una consulenza</a>
        <a href="#famiglie" class="pfbtn pfbtn-ghost pfbtn-lg">Le fragranze</a>
      </div>
      <ul class="pfhero-trust r"><li>✦ Consulenza olfattiva gratuita</li><li>✦ 200+ brand di nicchia</li><li>★ 4,9 su Google</li></ul>
    </div>
    <div class="pfhero-media r"><img src="/img/demo-profumeria/hero.webp" alt="Selezione di profumi di nicchia nella profumeria Essènza" /></div>
  </section>

  <!-- STAT STRIP -->
  <section class="pfstats">
    <div class="pfstats-in">
      <div class="r"><b>200+</b><span>brand selezionati</span></div>
      <div class="r"><b>1.500+</b><span>fragranze</span></div>
      <div class="r"><b>30</b><span>anni di profumeria</span></div>
      <div class="r"><b>4,9★</b><span>su Google</span></div>
    </div>
  </section>

  <!-- FAMIGLIE OLFATTIVE -->
  <section class="pfsection" id="famiglie">
    <div class="pfhead">
      <span class="pfkick2 r">Famiglie olfattive</span>
      <h2 class="r">Da dove nasce <span class="pfmark">il tuo profumo</span></h2>
      <p class="pflead r">Ogni fragranza appartiene a una famiglia. Capire quale ti appartiene è il primo passo per trovarla.</p>
    </div>
    <div class="pfgrid">
      {fam.map((f) => (
        <article class="pfcard r">
          <span class="pfcard-ic" set:html={icon(f.ic)} aria-hidden="true"></span>
          <div class="pfcard-row"><h3>{f.t}</h3><b class="pfcard-tag">{f.p}</b></div>
          <p>{f.d}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- PERCHE / FEATURE -->
  <section class="pfsection pffeat" id="perche">
    <div class="pffeat-grid">
      <div class="pffeat-media r"><img src="/img/demo-profumeria/p1.webp" alt="Consulenza olfattiva con prova del profumo sulla pelle" /></div>
      <div class="pffeat-text">
        <span class="pfkick2 r">La consulenza olfattiva</span>
        <h2 class="r">Non vendiamo profumi.<br/><span class="pfmark">Troviamo il tuo.</span></h2>
        <p class="r">Ascoltiamo i tuoi ricordi, i tuoi gusti e le occasioni. Poi, sulla tua pelle, costruiamo il profilo olfattivo che diventerà la tua firma.</p>
        <ul class="pfbullets r">
          <li><b>Consulenza personalizzata</b> gratuita e senza impegno</li>
          <li><b>Brand di nicchia</b> selezionati, introvabili altrove</li>
          <li><b>Campioncini</b> per provare il profumo nel tempo</li>
        </ul>
        <a href="#contatti" class="pfbtn pfbtn-solid r">Prenota la consulenza</a>
      </div>
    </div>
  </section>

  <!-- GALLERIA -->
  <section class="pfsection pfgal-sec">
    <div class="pfhead"><span class="pfkick2 r">In boutique</span><h2 class="r">Un rito, <span class="pfmark">non un acquisto</span></h2></div>
    <div class="pfgal">
      <img class="r" src="/img/demo-profumeria/hero.webp" alt="Flaconi di profumo esposti" loading="lazy" />
      <img class="r" src="/img/demo-profumeria/p2.webp" alt="Dettaglio di una fragranza di nicchia" loading="lazy" />
      <img class="r" src="/img/demo-profumeria/p3.webp" alt="Atmosfera della profumeria Essènza" loading="lazy" />
    </div>
  </section>

  <!-- RECENSIONI -->
  <section class="pfsection" id="recensioni">
    <div class="pfhead"><span class="pfkick2 r">Dicono di noi</span><h2 class="r">Profumi che <span class="pfmark">restano addosso</span></h2></div>
    <div class="pfgrid pfgrid-3">
      {reviews.map((r) => (
        <blockquote class="pfrev r"><div class="pfstars">★★★★★</div><p>«{r.txt}»</p><footer><span class="pfav">{r.av}</span><b>{r.n}</b></footer></blockquote>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section class="pfsection pffaq-sec">
    <div class="pfhead"><span class="pfkick2 r">Domande frequenti</span><h2 class="r">Le risposte, <span class="pfmark">subito</span></h2></div>
    <div class="pffaq r">
      {faq.map((f, i) => (
        <details class="pfq" open={i === 0}><summary>{f.q}<span class="pfq-ic" aria-hidden="true"></span></summary><div class="pfq-a"><p>{f.a}</p></div></details>
      ))}
    </div>
  </section>

  <!-- CONTATTI -->
  <section class="pfcta" id="contatti">
    <div class="pfcta-in r">
      <div class="pfcta-text">
        <span class="pfkick2">Prenota ora</span>
        <h2>Trova il profumo che <span class="pfmark2">ti somiglia</span></h2>
        <p>Scrivici per prenotare la tua consulenza olfattiva gratuita: poche domande, e iniziamo il viaggio verso la tua firma.</p>
        <div class="pfcta-side">
          <a href="tel:+390110000000" class="pfbtn pfbtn-solid pfbtn-lg">📞 011 000 0000</a>
          <a href="#contatti" class="pfbtn pfbtn-ghost pfbtn-lg">WhatsApp</a>
        </div>
        <p class="pfcta-note">📍 Via Lagrange 12, Torino · Mar–Sab 10:00–19:30</p>
      </div>
      <form class="pfform" onsubmit="return false">
        <label>Il tuo nome<input type="text" placeholder="Mario Rossi" autocomplete="name" /></label>
        <label>Telefono<input type="tel" placeholder="333 000 0000" autocomplete="tel" /></label>
        <label>Famiglia preferita
          <select><option>Agrumati</option><option>Floreali</option><option>Legnosi</option><option>Orientali</option><option>Aromatici</option><option>Gourmand</option><option>Non so, guidatemi</option></select>
        </label>
        <button class="pfbtn pfbtn-solid pfbtn-lg pfbtn-block" type="submit">Prenota la consulenza →</button>
        <p class="pfform-note">🔒 È una demo: nessun dato viene inviato.</p>
      </form>
    </div>
  </section>
  </main>

  <footer class="pffoot"><div><b>Essènza</b> · Profumeria artistica a Torino</div><div>Demo · <a href="/">Mole Digitale</a></div></footer>

  <a class="wa-fab" href="https://wa.me/390110000000" target="_blank" rel="noopener" aria-label="Scrivici su WhatsApp"><svg viewBox="0 0 24 24" width="26" height="26" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.8 4.9-1.3A10 10 0 1 0 12 2zm0 18a8 8 0 0 1-4.1-1.1l-.3-.2-2.9.8.8-2.8-.2-.3A8 8 0 1 1 12 20zm4.5-6c-.2-.1-1.4-.7-1.6-.8s-.4-.1-.5.1-.6.8-.8 1-.3.2-.5.1a6.5 6.5 0 0 1-3.2-2.8c-.2-.4.2-.4.6-1.2.1-.1 0-.3 0-.4l-.7-1.7c-.2-.5-.4-.4-.5-.4h-.5a1 1 0 0 0-.7.3 3 3 0 0 0-.9 2.2 5.2 5.2 0 0 0 1.1 2.7 11.9 11.9 0 0 0 4.6 4c2.3 1 2.3.7 2.7.6a2.5 2.5 0 0 0 1.6-1.1 2 2 0 0 0 .1-1.1z"/></svg></a>

  <style is:global>
    :root{
      --bg:#14110f;--bg2:#1b1714;--card:#1d1814;--ink:#f3ece1;--muted:#a99d8c;
      --gold:#c8a35a;--gold-l:#e0c184;--gold-d:#a07c34;--line:rgba(255,255,255,.1);--soft:0 24px 50px -24px rgba(0,0,0,.7);
      --serif:'Cormorant Variable',Georgia,serif;--sans:'Inter Variable',system-ui,sans-serif;--e:cubic-bezier(.2,.7,.2,1);
    }
    *{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth;scroll-padding-top:84px;overflow-x:clip}
    @media (prefers-reduced-motion:reduce){html{scroll-behavior:auto}}
    body{background:var(--bg);color:var(--ink);font-family:var(--sans);line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
    img{display:block;max-width:100%}a{color:inherit;text-decoration:none}
    h1,h2,h3{font-family:var(--serif);font-weight:600;line-height:1.04;letter-spacing:0}
    .pfmark{font-style:italic;color:var(--gold)}.pfmark2{font-style:italic;color:var(--gold-l)}

    .demo-flag{position:fixed;top:0;left:0;right:0;z-index:300;text-align:center;font-size:.8rem;padding:.4rem;background:rgba(20,17,15,.92);backdrop-filter:blur(8px);border-bottom:1px solid var(--line);color:var(--muted)}
    .demo-flag b{color:var(--gold)}

    .pfnav{position:fixed;top:27px;left:0;right:0;z-index:200;display:flex;align-items:center;gap:1.2rem;padding:.85rem clamp(1rem,4vw,2.6rem);transition:background .35s var(--e),box-shadow .35s}
    .pfnav.solid{background:rgba(20,17,15,.82);backdrop-filter:blur(14px);border-bottom:1px solid var(--line)}
    .pfbrand{font-family:var(--serif);font-size:1.7rem;font-weight:600;letter-spacing:.02em}.pfbrand span{color:var(--gold)}
    .pflinks{display:flex;gap:1.7rem;margin-left:auto}
    .pflinks a{font-size:.92rem;color:var(--ink);position:relative;transition:color .2s;text-transform:uppercase;letter-spacing:.08em}
    .pflinks a::after{content:'';position:absolute;left:0;bottom:-5px;height:1px;width:0;background:var(--gold);transition:width .3s var(--e)}
    .pflinks a:hover{color:var(--gold-l)}.pflinks a:hover::after{width:100%}
    .pfnav-toggle{display:none;background:none;border:0;color:var(--ink);cursor:pointer;width:44px;height:44px;border-radius:12px;place-items:center;margin-left:auto}

    .pfbtn{display:inline-flex;align-items:center;justify-content:center;gap:.45rem;font-weight:600;font-size:.9rem;padding:.7rem 1.3rem;border-radius:2px;cursor:pointer;border:1px solid transparent;transition:transform .2s var(--e),background .2s,color .2s;white-space:nowrap;letter-spacing:.03em}
    .pfbtn-solid{background:var(--gold);color:#14110f;box-shadow:0 12px 26px -14px var(--gold)}.pfbtn-solid:hover{background:var(--gold-l);transform:translateY(-3px)}
    .pfbtn-ghost{border-color:var(--line);color:var(--ink)}.pfbtn-ghost:hover{border-color:var(--gold);color:var(--gold-l);transform:translateY(-3px)}
    .pfbtn-lg{padding:.95rem 1.7rem;font-size:.98rem}.pfbtn-block{width:100%}

    .pfhero{max-width:1180px;margin:0 auto;display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(1.6rem,4vw,3.5rem);align-items:center;padding:7.5rem clamp(1.2rem,5vw,3rem) 3.5rem}
    .pfkick{display:inline-flex;align-items:center;gap:.5rem;font-size:.78rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:1.3rem}
    .pfdot{width:7px;height:7px;border-radius:50%;background:var(--gold)}
    .pfhero h1{font-size:clamp(3rem,7.5vw,5.6rem);margin-bottom:1.3rem;font-weight:500}
    .pfhero-sub{font-size:1.12rem;color:var(--muted);max-width:46ch;margin-bottom:1.8rem}
    .pfhero-cta{display:flex;gap:.8rem;flex-wrap:wrap}
    .pfhero-trust{list-style:none;display:flex;gap:1.2rem;flex-wrap:wrap;margin-top:1.8rem;color:var(--gold);font-size:.86rem;font-weight:500}
    .pfhero-media{border-radius:4px;overflow:hidden;box-shadow:var(--soft);aspect-ratio:4/5;border:1px solid var(--line)}
    .pfhero-media img{width:100%;height:100%;object-fit:cover}

    .pfstats{background:linear-gradient(90deg,#1b1714,#241d16,#1b1714);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
    .pfstats-in{max-width:1180px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;padding:2.4rem clamp(1.2rem,5vw,3rem)}
    .pfstats-in>div{text-align:center;border-left:1px solid var(--line)}.pfstats-in>div:first-child{border-left:none}
    .pfstats b{font-family:var(--serif);font-size:clamp(2rem,4vw,3rem);display:block;color:var(--gold-l);font-weight:600}
    .pfstats span{font-size:.82rem;color:var(--muted)}

    .pfsection{max-width:1180px;margin:0 auto;padding:clamp(3.5rem,8vw,6.5rem) clamp(1.2rem,5vw,3rem)}
    .pfhead{max-width:680px;margin:0 auto clamp(2.2rem,4vw,3.4rem);text-align:center}
    .pfkick2{display:inline-block;font-size:.74rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);border:1px solid var(--line);padding:.35rem .9rem;border-radius:999px;margin-bottom:1.1rem}
    .pfhead h2,.pffeat h2,.pfcta h2{font-size:clamp(2.1rem,5vw,3.4rem);font-weight:500}
    .pflead{color:var(--muted);font-size:1.08rem;margin-top:.9rem}

    .pfgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem}
    .pfgrid>*{min-width:0}
    .pfcard{background:var(--card);border:1px solid var(--line);border-radius:6px;padding:1.7rem;transition:transform .25s var(--e),border-color .25s}
    .pfcard:hover{transform:translateY(-5px);border-color:var(--gold)}
    .pfcard-ic{display:grid;place-items:center;width:50px;height:50px;border-radius:50%;background:rgba(200,163,90,.12);color:var(--gold-l);margin-bottom:1.1rem;border:1px solid var(--line)}
    .pfcard-ic svg{width:26px;height:26px}
    .pfcard-row{display:flex;align-items:baseline;justify-content:space-between;gap:.6rem;margin-bottom:.35rem}
    .pfcard h3{font-size:1.55rem;font-weight:600}.pfcard p{color:var(--muted);font-size:.94rem}
    .pfcard-tag{font-size:.68rem;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);flex:none}

    .pffeat-grid{display:grid;grid-template-columns:1fr 1.05fr;gap:clamp(1.6rem,4vw,3.5rem);align-items:center}
    .pffeat-grid>*{min-width:0}
    .pffeat-media{border-radius:4px;overflow:hidden;box-shadow:var(--soft);aspect-ratio:4/3;border:1px solid var(--line)}
    .pffeat-media img{width:100%;height:100%;object-fit:cover}
    .pffeat-text p{color:var(--muted);margin:1rem 0}
    .pfbullets{list-style:none;display:grid;gap:.7rem;margin-bottom:1.5rem}
    .pfbullets li{position:relative;padding-left:1.7rem;color:var(--muted)}
    .pfbullets li::before{content:'✦';position:absolute;left:0;color:var(--gold)}.pfbullets b{color:var(--ink)}

    .pfgal{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}
    .pfgal img{width:100%;aspect-ratio:1;object-fit:cover;border-radius:4px;border:1px solid var(--line);transition:transform .5s var(--e)}
    .pfgal img:hover{transform:scale(1.04)}

    .pfgrid-3{grid-template-columns:repeat(3,1fr)}
    .pfrev{background:var(--card);border:1px solid var(--line);border-radius:6px;padding:1.6rem;display:flex;flex-direction:column;gap:.8rem}
    .pfstars{color:var(--gold);letter-spacing:2px}.pfrev p{flex:1;font-style:italic;font-family:var(--serif);font-size:1.18rem;line-height:1.4}
    .pfrev footer{display:flex;align-items:center;gap:.6rem}
    .pfav{display:grid;place-items:center;width:38px;height:38px;border-radius:50%;background:var(--gold);color:#14110f;font-family:var(--serif);font-weight:700;flex:none}

    .pffaq{max-width:780px;margin:0 auto;display:grid;gap:.8rem}
    .pfq{background:var(--card);border:1px solid var(--line);border-radius:6px;overflow:hidden}
    .pfq summary{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:1.1rem 1.3rem;cursor:pointer;font-family:var(--serif);font-size:1.25rem;list-style:none}
    .pfq summary::-webkit-details-marker{display:none}
    .pfq-ic{position:relative;width:16px;height:16px;flex:none}
    .pfq-ic::before,.pfq-ic::after{content:'';position:absolute;background:var(--gold);border-radius:2px;transition:transform .3s var(--e)}
    .pfq-ic::before{top:7px;left:0;width:16px;height:2px}.pfq-ic::after{left:7px;top:0;width:2px;height:16px}
    .pfq[open] .pfq-ic::after{transform:scaleY(0)}
    .pfq-a{padding:0 1.3rem 1.2rem;color:var(--muted)}

    .pfcta{background:linear-gradient(150deg,#1d1814,#0f0c0a)}
    .pfcta-in{max-width:1100px;margin:0 auto;padding:clamp(3rem,7vw,5.5rem) clamp(1.2rem,5vw,3rem);display:grid;grid-template-columns:1fr 1fr;gap:clamp(2rem,5vw,4rem);align-items:center}
    .pfcta-in>*{min-width:0}
    .pfcta-text>p{color:var(--muted);margin:.8rem 0 1.6rem;max-width:42ch}
    .pfcta-side{display:flex;gap:.8rem;flex-wrap:wrap}.pfcta-note{margin-top:1.4rem;font-size:.88rem;color:var(--muted)}
    .pfform{background:var(--card);border:1px solid var(--line);border-radius:8px;padding:clamp(1.4rem,3vw,2rem);box-shadow:var(--soft);display:flex;flex-direction:column;gap:.9rem}
    .pfform label{display:flex;flex-direction:column;gap:.35rem;font-size:.82rem;font-weight:600;color:var(--muted)}
    .pfform input,.pfform select{min-width:0;width:100%;padding:.8rem .9rem;border:1px solid var(--line);border-radius:4px;font-family:var(--sans);font-size:1rem;background:var(--bg);color:var(--ink)}
    .pfform input:focus,.pfform select:focus{outline:2px solid var(--gold);border-color:transparent}
    .pfform-note{font-size:.76rem;color:var(--muted);text-align:center;font-weight:400}

    .pffoot{max-width:1180px;margin:0 auto;padding:2rem clamp(1.2rem,5vw,3rem);display:flex;justify-content:space-between;gap:1rem;flex-wrap:wrap;color:var(--muted);font-size:.86rem;border-top:1px solid var(--line)}
    .pffoot b{color:var(--gold-l);font-family:var(--serif)}.pffoot a{color:var(--gold)}

    .wa-fab{position:fixed;right:18px;bottom:18px;z-index:160;width:52px;height:52px;border-radius:50%;display:grid;place-items:center;background:#25d366;color:#fff;box-shadow:0 14px 30px -10px rgba(37,211,102,.7);transition:transform .2s var(--e)}
    .wa-fab:hover{transform:scale(1.08)}

    .r{opacity:0;transform:translateY(22px);transition:opacity .7s var(--e),transform .7s var(--e)}
    .r.in{opacity:1;transform:none}
    @media (prefers-reduced-motion:reduce){.r{opacity:1;transform:none;transition:none}}

    @media (max-width:900px){
      .pflinks{display:none}
      .pfnav.pfopen .pflinks{display:flex;position:absolute;top:100%;left:0;right:0;flex-direction:column;gap:1.1rem;background:rgba(20,17,15,.98);backdrop-filter:blur(14px);border-bottom:1px solid var(--line);padding:1.2rem clamp(1.2rem,5vw,3rem) 1.5rem}
      .pfnav-toggle{display:grid}
      .pfnav>.pfbtn-solid{padding:.5rem .9rem;font-size:.8rem}
      .pfhero{grid-template-columns:1fr;padding-top:6.5rem}.pfhero-media{order:-1;aspect-ratio:16/11}
      .pffeat-grid{grid-template-columns:1fr}.pffeat-media{order:-1;aspect-ratio:16/10}
      .pfcta-in{grid-template-columns:1fr}
      .pfstats-in{grid-template-columns:1fr 1fr;gap:1.4rem 1rem}.pfstats-in>div:nth-child(3){border-left:none}
    }
    @media (max-width:560px){
      .pfgrid,.pfgrid-3{grid-template-columns:1fr}.pfgal{grid-template-columns:1fr 1fr}
      .pfhero-trust{gap:.4rem 1.1rem}
    }
  </style>

  <script>
    const pfnav = document.getElementById('pfnav');
    addEventListener('scroll', () => pfnav.classList.toggle('solid', scrollY > 30), { passive: true });
    const pt = document.getElementById('pfToggle');
    pt.addEventListener('click', () => { const o = pfnav.classList.toggle('pfopen'); pt.setAttribute('aria-expanded', String(o)); });
    document.querySelectorAll('.pflinks a').forEach((a) => a.addEventListener('click', () => pfnav.classList.remove('pfopen')));
    document.addEventListener('click', (e) => { if (pfnav.classList.contains('pfopen') && !pfnav.contains(e.target)) { pfnav.classList.remove('pfopen'); pt.setAttribute('aria-expanded', 'false'); } });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { pfnav.classList.remove('pfopen'); pt.setAttribute('aria-expanded', 'false'); } });
    const io = new IntersectionObserver((es) => es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } }), { threshold: 0.12 });
    document.querySelectorAll('.r').forEach((el) => io.observe(el));
    document.querySelectorAll('.pfq').forEach((d) => d.addEventListener('toggle', () => { if (d.open) document.querySelectorAll('.pfq').forEach((o) => { if (o !== d) o.open = false; }); }));
  </script>
</body>
</html>
