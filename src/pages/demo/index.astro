---
import Layout from '../../layouts/Layout.astro';

// Le anteprime sono SCREENSHOT reali di ogni demo (public/img/thumbs/<key>.webp), 16:10.
const demos = [
  { k: 'ristorante',   name: 'Trattoria del Sole', cat: 'Ristorante',        url: '/demo/ristorante',   desc: 'Menu digitale + prenotazione tavolo' },
  { k: 'salone',       name: 'Salone Aurora',      cat: 'Parrucchiere',      url: '/demo/salone',       desc: 'Prenotazione appuntamenti online' },
  { k: 'officina',     name: 'Garage Rossi',       cat: 'Officina',          url: '/demo/officina',     desc: 'Sito vetrina + scheda Google' },
  { k: 'addestratore', name: 'Coda Felice',        cat: 'Addestratore cani', url: '/demo/addestratore', desc: 'Percorsi + configuratore + prova gratuita' },
  { k: 'estetica',     name: 'Velvèe',             cat: 'Centro estetico',   url: '/demo/estetica',     desc: 'Trattamenti in carosello + prenotazione' },
  { k: 'farmacia',     name: 'Farmacia Aurora',    cat: 'Farmacia',          url: '/demo/farmacia',     desc: 'Orari live + servizi in lista' },
  { k: 'farmacia-ausiliatrice', name: 'Farmacia dell\'Ausiliatrice', cat: 'Farmacia · multipagina', url: '/demoFarmaciaAusiliatrice/', desc: 'Sito completo + gestionale prodotti con login e foto' },
  { k: 'dentista',     name: 'Studio Sorriso',     cat: 'Dentista',          url: '/demo/dentista',     desc: 'Prima visita gratuita + trattamenti a tab' },
  { k: 'profumeria',   name: 'Essènza',            cat: 'Profumeria',        url: '/demo/profumeria',   desc: 'Consulenza olfattiva + indice fragranze' },
  { k: 'massaggi',     name: 'Sàva',               cat: 'Centro massaggi',   url: '/demo/massaggi',     desc: 'Massaggi in accordion con durate e prezzi' },
  { k: 'osteopata',    name: 'Àsse',               cat: 'Osteopatia',        url: '/demo/osteopata',    desc: 'Per chi è + percorso a timeline' },
  { k: 'viaggi',       name: 'Vàgo',               cat: 'Agenzia viaggi',    url: '/demo/viaggi',       desc: 'Hero con ricerca + destinazioni bento' },
  { k: 'nails',        name: 'Lúnula',             cat: 'Nail studio',       url: '/demo/nails',        desc: 'Listino + gallery masonry di nail art' },
  { k: 'animali',      name: 'Zampe Amiche',       cat: 'Veterinario',       url: '/demo/animali',      desc: 'Servizi + urgenze 24/7 + prenotazione' },
  { k: 'lavanderia',   name: 'Bollé',              cat: 'Lavanderia',        url: '/demo/lavanderia',   desc: 'Come funziona + listino + ritiro a domicilio' },
  { k: 'sushi',        name: 'Hashi',              cat: 'Sushi',             url: '/demo/sushi',        desc: 'Menu giapponese + omakase + prenotazione' },
  { k: 'ecommerce',    name: 'Bottega Subalpina',  cat: 'E-commerce',        url: '/demo/ecommerce',    desc: 'Negozio online con carrello' },
  { k: 'museo-egizio', name: 'Museo Egizio',       cat: 'Cultura',           url: '/demo/museo-egizio', desc: 'Sito museale + biglietti online' },
  { k: 'compro-oro',   name: 'Aureo',              cat: 'Compro Oro',        url: '/demo/compro-oro',   desc: 'Calcolo valore oro in tempo reale' },
  { k: 'gioielleria',  name: 'Lùmina',             cat: 'Gioielleria',       url: '/demo/gioielleria',  desc: 'Collezioni, preferiti e fede su misura' },
  { k: 'orologiaio',   name: 'Cronos',             cat: 'Orologiaio',        url: '/demo/orologiaio',   desc: 'Orologio live + preventivo riparazione' },
];
---
<Layout title="Demo — esempi di siti | Mole Digitale" description="Esempi di siti realizzati da Mole Digitale per attività di Torino: ristorante, parrucchiere, officina, addestratore cani, centro estetico, farmacia, dentista, profumeria, massaggi, osteopatia, viaggi, nail studio, veterinario, lavanderia, sushi, e-commerce, compro oro, gioielleria e orologiaio.">
  <section class="section" style="padding-top:8rem;">
    <div class="section-head" data-reveal>
      <span class="kicker">Demo</span>
      <h1>Esempi di siti che <span class="grad">facciamo</span>.</h1>
      <p class="section-lead">Venti attività, venti stili diversi — ogni sito ha una sua struttura. Aprili e prova a cliccare: prenotazioni, menu, carrello, calcolatori e preventivi che funzionano davvero.</p>
    </div>
    <div class="port-grid">
      {demos.map((dm) => (
        <a class="port-card glass" href={dm.url} data-reveal data-tilt>
          <div class="port-thumb">
            <img class="port-img" src={`/img/thumbs/${dm.k}.webp`} alt={`Anteprima del sito demo ${dm.name}`} loading="lazy" width="760" height="475" />
            <span class="port-go">Apri la demo →</span>
          </div>
          <div class="port-cap"><b>{dm.name}</b><span>{dm.cat} · {dm.desc}</span></div>
        </a>
      ))}
    </div>
    <div style="text-align:center; margin-top:3rem;" data-reveal>
      <a href="/#contatti" class="btn btn-primary btn-magnetic btn-lg">Voglio un sito così →</a>
    </div>
  </section>
</Layout>
