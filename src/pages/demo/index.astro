---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import pizz from '../../assets/img/lavoro-pizzeria.jpg';
import sal from '../../assets/img/lavoro-salone.jpg';
import off from '../../assets/img/lavoro-officina.jpg';
import ecom from '../../assets/img/lavoro-ecommerce.webp';
import museo from '../../assets/img/lavoro-museo.webp';
import cani from '../../assets/img/lavoro-cani.jpg';
import este from '../../assets/img/lavoro-estetica.jpg';
import farm from '../../assets/img/lavoro-farmacia.jpg';
import dent from '../../assets/img/lavoro-dentista.jpg';

const demos = [
  { img: pizz, name: 'Trattoria del Sole', cat: 'Ristorante',   url: '/demo/ristorante', desc: 'Menu digitale + prenotazione tavolo' },
  { img: sal,  name: 'Salone Aurora',      cat: 'Parrucchiere', url: '/demo/salone',     desc: 'Prenotazione appuntamenti online' },
  { img: off,  name: 'Garage Rossi',       cat: 'Officina',     url: '/demo/officina',   desc: 'Sito vetrina + scheda Google' },
  { img: cani, name: 'Coda Felice',        cat: 'Addestratore cani', url: '/demo/addestratore', desc: 'Percorsi + configuratore + prova gratuita' },
  { img: este, name: 'Velvèe',             cat: 'Centro estetico', url: '/demo/estetica',  desc: 'Trattamenti viso & corpo + prenotazione' },
  { img: farm, name: 'Farmacia Aurora',    cat: 'Farmacia',     url: '/demo/farmacia',   desc: 'Orari live + servizi e prenotazioni' },
  { img: dent, name: 'Studio Sorriso',     cat: 'Dentista',     url: '/demo/dentista',   desc: 'Prima visita gratuita + percorso di cura' },
  { img: ecom, name: 'Bottega Subalpina',  cat: 'E-commerce',   url: '/demo/ecommerce',  desc: 'Negozio online con carrello' },
  { img: museo, name: 'Museo Egizio',      cat: 'Cultura',      url: '/demo/museo-egizio', desc: 'Sito museale + biglietti online' },
  { cover: '/img/demo-oro/cover.svg',         name: 'Aureo',   cat: 'Compro Oro',  url: '/demo/compro-oro',  desc: 'Calcolo valore oro in tempo reale' },
  { cover: '/img/demo-gioielleria/cover.svg', name: 'Lùmina',  cat: 'Gioielleria', url: '/demo/gioielleria', desc: 'Collezioni, preferiti e fede su misura' },
  { cover: '/img/demo-orologiaio/cover.svg',  name: 'Cronos',  cat: 'Orologiaio',  url: '/demo/orologiaio',  desc: 'Orologio live + preventivo riparazione' },
];
---
<Layout title="Demo — esempi di siti | Mole Digitale" description="Esempi di siti realizzati da Mole Digitale per attività di Torino: ristorante, parrucchiere, officina, addestratore cani, centro estetico, farmacia, dentista, e-commerce, compro oro, gioielleria e orologiaio.">
  <section class="section" style="padding-top:8rem;">
    <div class="section-head" data-reveal>
      <span class="kicker">Demo</span>
      <h1>Esempi di siti che <span class="grad">facciamo</span>.</h1>
      <p class="section-lead">Ogni attività con uno stile diverso — dal ristorante alla farmacia. Aprili e prova a cliccare: prenotazioni, menu, carrello, calcolatori e preventivi che funzionano davvero.</p>
    </div>
    <div class="port-grid">
      {demos.map((dm) => (
        <a class="port-card glass" href={dm.url} data-reveal data-tilt>
          <div class="port-thumb">
            {dm.img
              ? <Image class="port-img" src={dm.img} alt={`Demo sito ${dm.name}`} widths={[360, 720]} sizes="(max-width:980px) 92vw, 360px" format="webp" loading="lazy" />
              : <img class="port-img" src={dm.cover} alt={`Demo sito ${dm.name}`} loading="lazy" width="360" height="360" />}
            <span class="port-go">Apri la demo →</span>
          </div>
          <div class="port-cap"><b>{dm.name}</b><span>{dm.cat} · {dm.desc}</span></div>
        </a>
      ))}
    </div>
    <div style="text-align:center; margin-top:3rem;" data-reveal>
      <a href="/#contatti" class="btn btn-primary btn-magnetic btn-lg">Voglio un sito così →</a>
    </div>
  </section>
</Layout>
