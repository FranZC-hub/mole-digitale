    .foto{border:5px ridge #999;width:150px;height:110px;object-fit:fill;margin:6px;image-rendering:pixelated}
    .counter{background:#000;color:#0f0;font-family:'Courier New',monospace;display:inline-block;padding:2px 8px;border:2px inset #888;letter-spacing:3px}
    .costr{color:#cc6600;font-weight:bold;font-size:14px;margin-top:8px}
