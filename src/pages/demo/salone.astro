---
// DEMO — Salone Aurora (parrucchiere). Tema CHIARO / editoriale.
import '@fontsource-variable/inter';
import '@fontsource-variable/playfair-display';
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>Salone Aurora — Parrucchiere a Torino</title>
  <meta name="description" content="Salone Aurora, parrucchiere a Torino: taglio, colore, trattamenti e cura dei capelli. Prenota online il tuo appuntamento in pochi secondi." />
  <meta name="theme-color" content="#fbf5f2" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><circle cx='12' cy='12' r='7' fill='%23c9728a'/></svg>" />
</head>
<body>
  <a class="demo-flag" href="/siti-web-parrucchieri-torino">★ Demo di <b>Mole Digitale</b> · Vuoi un sito così? <b>Scopri di più →</b></a>

  <header class="dnav" id="dnav">
    <a href="#top" class="dbrand"><span class="dot" aria-hidden="true"></span>Salone <em>Aurora</em></a>
    <nav class="dlinks">
      <a href="#servizi">Servizi</a>
      <a href="#prenota">Prenota</a>
      <a href="#team">Team</a>
      <a href="#galleria">Galleria</a>
    </nav>
    <button class="dnav-toggle" id="dtoggle" aria-label="Apri il menu" aria-expanded="false"><svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16"/></svg></button>
    <a href="#prenota" class="nav-cta">Prenota<span aria-hidden="true"> →</span></a>
  </header>

  <main id="main">
  <!-- HERO split -->
  <section class="hero" id="top">
    <div class="hero-text">
      <p class="eyebrow hl">Hair &amp; Beauty · Torino</p>
      <h1 class="htitle">
        <span class="dl"><span class="dw">La tua</span> <span class="dw it">bellezza,</span></span>
        <span class="dl"><span class="dw">nelle mani</span> <span class="dw">giuste.</span></span>
      </h1>
      <p class="hsub hl">Taglio, colore e cura dei capelli con prodotti di qualità. Esci da noi sentendoti semplicemente al meglio.</p>
      <div class="hcta hl">
        <a href="#prenota" class="dbtn dbtn-solid dmag">Prenota un appuntamento</a>
        <a href="#servizi" class="dbtn dbtn-ghost">I servizi</a>
      </div>
      <div class="hmeta hl"><span><b>★ 4,9</b> su Google</span><span><b>15+</b> anni</span><span><b>Mar–Sab</b></span></div>
    </div>
    <div class="hero-img" data-parallax><img src="/img/demo-salone/hero.webp" alt="Salone Aurora" /></div>
  </section>

  <!-- LISTINO -->
  <section class="dsection listino" id="servizi">
    <div class="listino-grid">
      <div class="listino-side r" data-clip><img src="/img/demo-salone/piatto-2.webp" alt="Listino prezzi del Salone Aurora" /></div>
      <div>
        <span class="kick r">Listino</span>
        <h2 class="r">I nostri <span class="it">servizi</span></h2>
        <ul class="price-list">
          <li class="r"><span>Taglio &amp; Piega</span><i></i><b>da 25€</b></li>
          <li class="r"><span>Piega &amp; Styling</span><i></i><b>da 18€</b></li>
          <li class="r"><span>Colore &amp; Riflessi</span><i></i><b>da 45€</b></li>
          <li class="r"><span>Balayage / Degradé</span><i></i><b>da 65€</b></li>
          <li class="r"><span>Trattamento ricostruzione</span><i></i><b>da 30€</b></li>
        </ul>
        <p class="note r">Ogni servizio inizia con una <b>consulenza gratuita</b>.</p>
      </div>
    </div>
  </section>

  <!-- PRENOTAZIONE APPUNTAMENTI (la feature della didascalia) -->
  <section class="dsection book" id="prenota">
    <div class="book-card r">
      <div class="book-head">
        <span class="kick">Prenotazione online</span>
        <h2>Il tuo posto, <span class="it">in 30 secondi.</span></h2>
        <p>Scegli servizio e giorno: ti confermiamo l'appuntamento via WhatsApp.</p>
      </div>
      <div class="book-form">
        <label class="bf">Servizio
          <select>
            <option>Taglio &amp; Piega</option>
            <option>Colore &amp; Riflessi</option>
            <option>Balayage / Degradé</option>
            <option>Trattamento</option>
          </select>
        </label>
        <div class="bf">
          <span class="bf-lab">Giorno</span>
          <div class="days">
            <button type="button">Mar 11</button>
            <button type="button" class="on">Mer 12</button>
            <button type="button">Gio 13</button>
            <button type="button">Ven 14</button>
            <button type="button">Sab 15</button>
          </div>
        </div>
        <div class="bf">
          <span class="bf-lab">Orario</span>
          <div class="slots">
            <button type="button">9:30</button>
            <button type="button" class="on">11:00</button>
            <button type="button">15:00</button>
            <button type="button">17:30</button>
          </div>
        </div>
        <a href="#prenota" class="dbtn dbtn-solid dmag book-go">Conferma la richiesta →</a>
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section class="dsection team" id="team">
    <div class="head"><span class="kick r">Il team</span><h2 class="r">Le mani <span class="it">che ti curano</span></h2></div>
    <div class="team-grid">
      <figure class="member r"><div class="m-img"><img src="/img/demo-salone/galleria-1.webp" alt="Giulia" /></div><figcaption><b>Giulia</b><span>Color specialist</span></figcaption></figure>
      <figure class="member r"><div class="m-img"><img src="/img/demo-salone/galleria-3.webp" alt="Marta" /></div><figcaption><b>Marta</b><span>Hair stylist</span></figcaption></figure>
      <figure class="member r"><div class="m-img"><img src="/img/demo-salone/interno.webp" alt="Sara" /></div><figcaption><b>Sara</b><span>Trattamenti</span></figcaption></figure>
    </div>
  </section>

  <!-- GALLERIA -->
  <section class="dsection galleria" id="galleria">
    <div class="head"><span class="kick r">Galleria</span><h2 class="r">I nostri <span class="it">lavori</span></h2></div>
    <div class="masonry">
      <img class="r" src="/img/demo-salone/taglio-1.webp" alt="Caschetto castano realizzato al Salone Aurora" loading="lazy" />
      <img class="r" src="/img/demo-salone/taglio-2.webp" alt="Ricci ramati luminosi" loading="lazy" />
      <img class="r" src="/img/demo-salone/taglio-3.webp" alt="Onde morbide su capelli castani" loading="lazy" />
      <img class="r" src="/img/demo-salone/taglio-4.webp" alt="Colore biondo luminoso" loading="lazy" />
      <img class="r" src="/img/demo-salone/taglio-5.webp" alt="Capelli lunghi castani con piega" loading="lazy" />
      <img class="r" src="/img/demo-salone/taglio-6.webp" alt="Ricci scuri definiti" loading="lazy" />
    </div>
  </section>

  </main>

  <footer class="dfoot">
    <div><b>Salone Aurora</b><br/>Via Garibaldi 10, Torino · 011 000 0000</div>
    <div>Mar–Sab 9:00–19:00 · Demo · <a href="/">Mole Digitale</a></div>
  </footer>

  <a class="wa-fab" href="https://wa.me/390110000000" target="_blank" rel="noopener" aria-label="Scrivici su WhatsApp">
    <svg viewBox="0 0 24 24" width="26" height="26" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.8 4.9-1.3A10 10 0 1 0 12 2zm0 18a8 8 0 0 1-4.1-1.1l-.3-.2-2.9.8.8-2.8-.2-.3A8 8 0 1 1 12 20zm4.5-6c-.2-.1-1.4-.7-1.6-.8s-.4-.1-.5.1-.6.8-.8 1-.3.2-.5.1a6.5 6.5 0 0 1-3.2-2.8c-.2-.4.2-.4.6-1.2.1-.1 0-.3 0-.4l-.7-1.7c-.2-.5-.4-.4-.5-.4h-.5a1 1 0 0 0-.7.3 3 3 0 0 0-.9 2.2 5.2 5.2 0 0 0 1.1 2.7 11.9 11.9 0 0 0 4.6 4c2.3 1 2.3.7 2.7.6a2.5 2.5 0 0 0 1.6-1.1 2 2 0 0 0 .1-1.1z"/></svg>
  </a>

  <style is:global>
    :root{
      --bg:#fbf5f2;--panel:#ffffff;--ink:#2b2026;--muted:#6e6168;
      --rose:#c9728a;--rose-d:#a8516c;--rose-soft:#f6e2e8;--line:rgba(43,32,38,.12);
      --serif:'Playfair Display Variable',Georgia,serif;--sans:'Inter Variable',system-ui,sans-serif;
      --e:cubic-bezier(.16,1,.3,1);
    }
    *{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth;overflow-x:clip;scroll-padding-top:96px}@media (prefers-reduced-motion:reduce){html{scroll-behavior:auto}}
    body{background:var(--bg);color:var(--ink);font-family:var(--sans);line-height:1.65;-webkit-font-smoothing:antialiased;overflow-x:hidden}
    img{display:block;max-width:100%}a{color:inherit;text-decoration:none}
    h1,h2{font-family:var(--serif);font-weight:600;line-height:1.05;letter-spacing:-.01em}
    .it{font-style:italic;color:var(--rose)}

    .demo-flag{position:fixed;top:0;left:0;right:0;z-index:200;text-align:center;font-size:.8rem;padding:.4rem;background:rgba(255,255,255,.9);backdrop-filter:blur(8px);border-bottom:1px solid var(--line);color:var(--muted)}
    .demo-flag b{color:var(--rose-d)}
    .wa-fab{position:fixed;right:18px;bottom:18px;z-index:160;width:52px;height:52px;border-radius:50%;display:grid;place-items:center;background:#25d366;color:#fff;box-shadow:0 14px 30px -10px rgba(37,211,102,.7);transition:transform .2s cubic-bezier(.16,1,.3,1)}
    .wa-fab:hover{transform:scale(1.08)}

    .dnav{position:fixed;top:31px;left:0;right:0;z-index:150;display:flex;align-items:center;gap:1.5rem;padding:1.1rem clamp(1rem,4vw,3rem);transition:.4s var(--e)}
    .dnav.solid{background:rgba(251,245,242,.9);backdrop-filter:blur(14px);border-bottom:1px solid var(--line);padding-top:.8rem;padding-bottom:.8rem}
    .dbrand{font-family:var(--serif);font-size:1.4rem;font-weight:600;display:inline-flex;align-items:center;gap:.6rem}
    .dbrand em{font-style:italic;color:var(--rose)}
    .dot{width:14px;height:14px;border-radius:50%;background:var(--rose);box-shadow:0 0 0 4px var(--rose-soft);flex:none}
    .dlinks{display:flex;gap:1.8rem;margin-left:auto}
    .dlinks a{font-size:.95rem;color:var(--muted);position:relative;transition:color .25s}
    .dlinks a::after{content:'';position:absolute;left:0;bottom:-5px;height:1px;width:0;background:var(--rose);transition:width .3s var(--e)}
    .dlinks a:hover{color:var(--ink)}.dlinks a:hover::after{width:100%}

    .dbtn{display:inline-flex;align-items:center;gap:.5rem;padding:.85rem 1.6rem;border-radius:999px;font-weight:600;font-size:.95rem;cursor:pointer;transition:transform .25s var(--e),background .25s;white-space:nowrap}
    .dbtn-solid{background:var(--rose);color:#fff;box-shadow:0 12px 28px -12px var(--rose)}
    .dbtn-solid:hover{transform:translateY(-3px);background:var(--rose-d)}
    .dbtn-ghost{border:1px solid var(--line);color:var(--ink)}.dbtn-ghost:hover{background:#fff;transform:translateY(-3px)}
    /* CTA nav EDITORIALE (firma boutique): testo sottolineato, niente pill */
    .nav-cta{font-size:.78rem;letter-spacing:.2em;text-transform:uppercase;color:var(--rose-d);border-bottom:1px solid var(--rose);padding-bottom:4px;white-space:nowrap;transition:color .25s,border-color .25s}
    .nav-cta:hover{color:var(--ink);border-color:var(--ink)}

    .hero{min-height:100vh;display:grid;grid-template-columns:1.05fr .95fr;align-items:center;gap:2.5rem;max-width:1280px;margin:0 auto;padding:9rem clamp(1.2rem,5vw,3.5rem) 4rem}
    .eyebrow{font-size:.82rem;letter-spacing:.24em;text-transform:uppercase;color:var(--rose-d);margin-bottom:1.5rem}
    .htitle{font-size:clamp(2.6rem,6vw,5rem);margin-bottom:1.6rem}
    .htitle .dl{display:block}.htitle .dw{display:inline-block}
    .hsub{max-width:460px;font-size:1.15rem;color:var(--muted);margin-bottom:2.2rem}
    .hcta{display:flex;gap:1rem;flex-wrap:wrap}
    .hmeta{display:flex;gap:2rem;margin-top:2.6rem;flex-wrap:wrap;color:var(--muted);font-size:.9rem}
    .hmeta b{color:var(--rose-d);margin-right:.3rem}
    .hero-img{position:relative;height:78vh;border-radius:240px 240px 20px 20px;overflow:hidden;box-shadow:0 40px 80px -40px rgba(168,81,108,.45)}
    .hero-img img{width:100%;height:108%;object-fit:cover}

    .dsection{max-width:1180px;margin:0 auto;padding:clamp(4rem,9vw,7rem) clamp(1.2rem,5vw,3rem)}
    .head{margin-bottom:clamp(2rem,4vw,3rem);text-align:center}
    .kick{display:inline-flex;align-items:center;gap:.7rem;font-size:.78rem;letter-spacing:.26em;text-transform:uppercase;color:var(--rose-d);margin-bottom:.8rem}
    .kick::before,.kick::after{content:'';width:30px;height:1px;background:var(--rose-d);opacity:.55}
    .head h2,.listino h2,.book-head h2{font-size:clamp(2rem,4.5vw,3.2rem)}

    .listino-grid{display:grid;grid-template-columns:.85fr 1.15fr;gap:clamp(2rem,5vw,4rem);align-items:center}
    .listino-side{border-radius:18px;overflow:hidden}
    .listino-side img{width:100%;height:520px;object-fit:cover}
    .price-list{list-style:none;margin:1.4rem 0}
    .price-list li{display:flex;align-items:baseline;gap:.8rem;padding:1rem 0;border-bottom:1px solid var(--line)}
    .price-list span{font-family:var(--serif);font-size:1.3rem}
    .price-list i{flex:1;border-bottom:1px dotted rgba(43,32,38,.25);transform:translateY(-4px)}
    .price-list b{font-size:1.1rem;color:var(--rose-d)}
    .note{color:var(--muted);margin-top:1rem}.note b{color:var(--ink)}

    /* BOOKING */
    .book{display:grid;place-items:center}
    .book-card{width:100%;max-width:760px;background:var(--panel);border:1px solid var(--line);border-radius:24px;padding:clamp(1.8rem,4vw,3rem);box-shadow:0 40px 90px -50px rgba(168,81,108,.4)}
    .book-head{text-align:center;margin-bottom:2rem}
    .book-head p{color:var(--muted);margin-top:.6rem}
    .book-form{display:flex;flex-direction:column;gap:1.3rem}
    .bf{display:flex;flex-direction:column;gap:.5rem;font-size:.9rem;color:var(--muted)}
    .bf-lab{font-size:.9rem}
    .bf select{padding:.9rem 1rem;border:1px solid var(--line);border-radius:12px;font-family:var(--sans);font-size:1rem;background:#fff;color:var(--ink)}
    .days,.slots{display:flex;gap:.6rem;flex-wrap:wrap}
    .days button,.slots button{padding:.7rem 1.1rem;border:1px solid var(--line);border-radius:12px;background:#fff;color:var(--ink);font-weight:600;cursor:pointer;font-family:var(--sans);transition:.2s}
    .days button:hover,.slots button:hover{border-color:var(--rose)}
    .days button.on,.slots button.on{background:var(--rose);color:#fff;border-color:var(--rose)}
    .book-go{justify-content:center;margin-top:.5rem}

    .team-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.6rem}
    .member .m-img{border-radius:16px;overflow:hidden;aspect-ratio:3/4;margin-bottom:1rem}
    .member .m-img img{width:100%;height:100%;object-fit:cover;transition:transform .8s var(--e)}
    .member:hover .m-img img{transform:scale(1.05)}
    .member b{font-family:var(--serif);font-size:1.25rem;display:block}
    .member span{color:var(--muted);font-size:.9rem}

    .masonry{columns:3;column-gap:1.2rem}
    .masonry img{width:100%;border-radius:14px;margin-bottom:1.2rem;break-inside:avoid;transition:transform .6s var(--e)}
    .masonry img:hover{transform:scale(1.02)}

    .dfoot{max-width:1180px;margin:0 auto;padding:2.5rem clamp(1.2rem,5vw,3rem);display:flex;justify-content:space-between;gap:1rem;flex-wrap:wrap;color:var(--muted);font-size:.9rem;border-top:1px solid var(--line)}
    .dfoot b{color:var(--ink);font-family:var(--serif)}.dfoot a{color:var(--rose-d)}

    .r{opacity:0;transform:translateY(32px)}.hl{opacity:0}[data-clip]{clip-path:inset(0 0 100% 0)}
    .dnav-toggle{display:none;background:none;border:0;color:var(--ink);cursor:pointer;width:44px;height:44px;border-radius:10px;place-items:center;margin-left:auto}
    .dnav-toggle:hover{background:rgba(43,32,38,.06)}
    @media (max-width:900px){
      .hero{grid-template-columns:1fr;padding-top:7rem}.hero-img{height:56vh;border-radius:140px 140px 16px 16px}
      /* su mobile l'immagine-listino sopra il listino vero sembrava un doppione tagliato: via */
      .listino-grid{grid-template-columns:1fr}.listino-side{display:none}
      .team-grid{grid-template-columns:1fr}.masonry{columns:2}.dlinks{display:none}
      .dnav>.dbtn{display:none}
      .dnav>.nav-cta{font-size:.72rem;letter-spacing:.12em}
      .dnav-toggle{display:grid}
      .dnav.dopen .dlinks{display:flex;position:absolute;top:100%;left:0;right:0;flex-direction:column;gap:1.1rem;background:rgba(251,245,242,.98);backdrop-filter:blur(14px);border-bottom:1px solid var(--line);padding:1.2rem clamp(1.2rem,5vw,3rem) 1.5rem}
    }
    @media (prefers-reduced-motion:reduce){.r,.hl{opacity:1!important;transform:none!important}[data-clip]{clip-path:none!important}}
  </style>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import Lenis from 'lenis';
    import 'lenis/dist/lenis.css';
    gsap.registerPlugin(ScrollTrigger);
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const fine = matchMedia('(hover:hover) and (pointer:fine)').matches;
    const dnav = document.getElementById('dnav');
    const onScroll = (y) => dnav.classList.toggle('solid', y > 40);

    // menu mobile (hamburger)
    const dtoggle = document.querySelector('.dnav-toggle');
    if (dtoggle) {
      dtoggle.addEventListener('click', () => { const o = dnav.classList.toggle('dopen'); dtoggle.setAttribute('aria-expanded', String(o)); });
      document.querySelectorAll('.dlinks a').forEach((a) => a.addEventListener('click', () => dnav.classList.remove('dopen')));
      document.addEventListener('click', (e) => { if (dnav.classList.contains('dopen') && !dnav.contains(e.target)) { dnav.classList.remove('dopen'); dtoggle.setAttribute('aria-expanded', 'false'); } });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && dnav.classList.contains('dopen')) { dnav.classList.remove('dopen'); dtoggle.setAttribute('aria-expanded', 'false'); } });
    }
    // selettori giorno/orario interattivi (mockup)
    document.querySelectorAll('.days, .slots').forEach((g) => g.addEventListener('click', (e) => {
      const b = e.target.closest('button'); if (!b) return;
      g.querySelectorAll('button').forEach((x) => x.classList.remove('on')); b.classList.add('on');
    }));
    if (!reduced) {
      const lenis = new Lenis({ lerp: 0.1 });
      const raf = (t) => { lenis.raf(t); requestAnimationFrame(raf); };
      requestAnimationFrame(raf);
      lenis.on('scroll', ({ scroll }) => { onScroll(scroll); ScrollTrigger.update(); });
      document.querySelectorAll('a[href^="#"]').forEach((a) => { const h = a.getAttribute('href'); if (!h || h === '#') return; const t = document.querySelector(h); if (t) a.addEventListener('click', (e) => { e.preventDefault(); lenis.scrollTo(t, { offset: -70 }); }); });
      gsap.set('.hl', { y: 18 });
      gsap.timeline({ defaults: { ease: 'power3.out' } })
        .from('.htitle .dw', { yPercent: 120, opacity: 0, stagger: 0.08, duration: 1 }, 0.15)
        .to('.hl', { opacity: 1, y: 0, stagger: 0.12, duration: 0.9 }, 0.5)
        .from('.hero-img img', { scale: 1.2, duration: 1.8 }, 0);
      document.querySelectorAll('[data-parallax]').forEach((el) => gsap.to(el.querySelector('img'), { yPercent: 12, ease: 'none', scrollTrigger: { trigger: el, start: 'top bottom', end: 'bottom top', scrub: true } }));
      gsap.utils.toArray('.r').forEach((el) => gsap.fromTo(el, { opacity: 0, scale: 0.95, y: 22 }, { opacity: 1, scale: 1, y: 0, duration: 0.9, ease: 'power3.out', scrollTrigger: { trigger: el, start: 'top 88%' } }));
      gsap.utils.toArray('[data-clip]').forEach((el) => gsap.to(el, { clipPath: 'inset(0 0 0% 0)', duration: 1.1, ease: 'power3.out', scrollTrigger: { trigger: el, start: 'top 85%' } }));
      if (fine) document.querySelectorAll('.dmag').forEach((b) => { b.addEventListener('mousemove', (e) => { const r = b.getBoundingClientRect(); b.style.transform = `translate(${(e.clientX-r.left-r.width/2)*.3}px,${(e.clientY-r.top-r.height/2)*.4}px)`; }); b.addEventListener('mouseleave', () => { b.style.transform = ''; }); });
    } else { window.addEventListener('scroll', () => onScroll(window.scrollY), { passive: true }); }
  </script>
</body>
</html>
