  <style is:global>
    :root{
      --bg:#0c1015; --bg2:#11161d; --panel:#161c25; --panel2:#1b2330;
      --steel:#9fb3c8; --bronze:#c8a06a; --bronze-d:#a9824c;
      --ink:#e7edf3; --muted:#8593a3; --line:rgba(231,237,243,.1);
      --disp:'Space Grotesk Variable','Space Grotesk',system-ui,sans-serif;
      --sans:'Inter Variable',system-ui,sans-serif;
      --ease:cubic-bezier(.2,.7,.2,1);
    }
    *{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth;scroll-padding-top:88px;overflow-x:clip}
    @media (prefers-reduced-motion:reduce){html{scroll-behavior:auto}}
    body{background:var(--bg);color:var(--ink);font-family:var(--sans);line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
    svg,img{display:block;max-width:100%}
    a{color:inherit;text-decoration:none}
    h1,h2,h3,.cbrand{font-family:var(--disp);font-weight:600;line-height:1.07;letter-spacing:-.015em}
    .grad{background:linear-gradient(120deg,var(--bronze),#ecd3aa 50%,var(--steel));-webkit-background-clip:text;background-clip:text;color:transparent}

    .demo-flag{position:fixed;top:0;left:0;right:0;z-index:300;text-align:center;font-size:.8rem;padding:.4rem;background:rgba(12,16,21,.9);backdrop-filter:blur(8px);border-bottom:1px solid var(--line);color:var(--muted)}
    .demo-flag b{color:var(--bronze)}

    /* NAV */
    .cnav{position:fixed;top:30px;left:0;right:0;z-index:150;display:flex;align-items:center;gap:1.4rem;padding:1rem clamp(1rem,4vw,3rem);transition:.35s var(--ease)}
    .cnav.solid{background:rgba(12,16,21,.86);backdrop-filter:blur(14px);border-bottom:1px solid var(--line);padding-top:.7rem;padding-bottom:.7rem}
    .cbrand{font-size:1.35rem;font-weight:700;display:inline-flex;align-items:center;gap:.45rem;letter-spacing:.06em}
    .cbrand em{color:var(--bronze);font-style:normal}
    .cbrand-sub{font-family:var(--sans);font-size:.7rem;font-weight:500;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);align-self:center}
    .cgear{width:18px;height:18px;border-radius:50%;border:3px solid var(--bronze);border-style:dashed;flex:none;animation:spin 9s linear infinite}
    .clinks{display:flex;gap:1.7rem;margin-left:auto}
    .clinks a{font-size:.95rem;color:var(--muted);font-weight:500;position:relative;transition:color .25s}
    .clinks a::after{content:'';position:absolute;left:0;bottom:-5px;height:1.5px;width:0;background:var(--bronze);transition:width .3s var(--ease)}
    .clinks a:hover{color:var(--ink)} .clinks a:hover::after{width:100%}
    .cnav-toggle{display:none;background:none;border:0;color:var(--ink);cursor:pointer;width:42px;height:42px;border-radius:10px;margin-left:auto}

    .cbtn{display:inline-flex;align-items:center;justify-content:center;gap:.45rem;font-weight:600;font-size:.94rem;padding:.78rem 1.4rem;border-radius:10px;cursor:pointer;border:1px solid transparent;transition:transform .2s var(--ease),background .2s,box-shadow .2s,border-color .2s;font-family:var(--sans);white-space:nowrap}
    .cbtn-solid{background:linear-gradient(135deg,var(--bronze),var(--bronze-d));color:#1a130a;box-shadow:0 12px 26px -14px var(--bronze)}
    .cbtn-solid:hover{transform:translateY(-2px);box-shadow:0 18px 34px -14px var(--bronze)}
    .cbtn-ghost{background:transparent;border-color:var(--line);color:var(--ink)}
    .cbtn-ghost:hover{border-color:var(--steel);transform:translateY(-2px)}

    /* HERO */
    .chero{padding:clamp(7rem,12vw,9.5rem) clamp(1.2rem,5vw,3rem) clamp(3rem,6vw,5rem);position:relative;overflow:hidden}
    .chero::before{content:'';position:absolute;inset:0;background:
      radial-gradient(50% 50% at 78% 30%,rgba(200,160,106,.14),transparent 70%),
      radial-gradient(40% 50% at 10% 80%,rgba(159,179,200,.1),transparent 70%);pointer-events:none}
    .chero-grid{max-width:1180px;margin:0 auto;display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(1.5rem,4vw,3.5rem);align-items:center;position:relative}
    .ceyebrow{display:inline-flex;align-items:center;gap:.55rem;text-transform:uppercase;letter-spacing:.18em;font-size:.74rem;font-weight:600;color:var(--bronze);margin-bottom:1.3rem}
    .ceyebrow .tick{width:8px;height:8px;border-radius:50%;background:var(--bronze);box-shadow:0 0 10px var(--bronze);animation:blink 2s var(--ease) infinite}
    @keyframes blink{0%,100%{opacity:.35}50%{opacity:1}}
    .chero-title{font-size:clamp(2.6rem,6.4vw,4.8rem)}
    .chero-sub{color:var(--muted);font-size:1.15rem;margin:1.4rem 0 2rem;max-width:48ch}
    .chero-cta{display:flex;gap:.8rem;flex-wrap:wrap}
    /* readout strumentali (al posto della strip di numeri) — look da quadrante tecnico */
    .chero-trust{list-style:none;display:flex;gap:.7rem;margin-top:2.4rem;flex-wrap:wrap}
    .chero-trust li{flex:1;min-width:96px;border:1px solid var(--line);border-radius:8px;padding:.7rem .85rem;background:rgba(159,179,200,.045)}
    .chero-trust .ct-lbl{display:block;font-family:var(--disp);font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:.35rem}
    .chero-trust b{font-family:var(--disp);color:var(--ink);font-size:1.5rem;line-height:1;display:flex;align-items:baseline;gap:.15rem;font-weight:600}
    .chero-trust b i{font-style:normal;font-size:.68rem;color:var(--steel);letter-spacing:.04em}
    .chero-watch{position:relative;display:grid;place-items:center}
    .watch{width:min(420px,82vw);height:auto;filter:drop-shadow(0 30px 50px rgba(0,0,0,.6));position:relative;z-index:1}
    .watch-glow{position:absolute;width:70%;aspect-ratio:1;border-radius:50%;background:radial-gradient(circle,rgba(200,160,106,.25),transparent 70%);filter:blur(20px);z-index:0}
    #handSec{transition:none}

    /* SECTIONS */
    .csection{max-width:1180px;margin:0 auto;padding:clamp(3.5rem,8vw,6.5rem) clamp(1.2rem,5vw,3rem);
      background-image:radial-gradient(rgba(159,179,200,.05) 1px,transparent 1px);background-size:30px 30px}
    .chead{text-align:left;max-width:880px;margin:0 0 clamp(2rem,4vw,3rem);padding-bottom:1.1rem;border-bottom:1px solid var(--line)}
    .ckicker{display:inline-block;font-family:var(--sans);font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--bronze);margin-bottom:.9rem;border:1px solid var(--line);border-radius:6px;padding:.32rem .7rem}
    .ckicker::before{content:'// ';opacity:.6}
    .chead h2,.lab-text h2,.ccta h2{font-size:clamp(1.9rem,4.6vw,3.1rem)}
    .clead{color:var(--muted);margin-top:.7rem;font-size:1.05rem;max-width:64ch}

    /* PREVENTIVO */
    .prev-card{display:grid;grid-template-columns:1.25fr .75fr;border:1px solid var(--line);border-radius:20px;overflow:hidden;background:linear-gradient(180deg,var(--panel),var(--bg2))}
    .prev-controls{padding:clamp(1.6rem,3vw,2.4rem);display:flex;flex-direction:column;gap:1.6rem}
    .prev-lbl{display:block;font-size:.78rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:.8rem;font-weight:600}
    .opts{display:flex;gap:.5rem;flex-wrap:wrap}
    .opts-grid{display:grid;grid-template-columns:1fr 1fr;gap:.5rem}
    .opt{background:rgba(231,237,243,.04);border:1px solid var(--line);color:var(--muted);font-family:var(--sans);font-weight:600;font-size:.9rem;padding:.7rem .9rem;border-radius:10px;cursor:pointer;transition:all .2s;text-align:left}
    .opt:hover{border-color:var(--steel);color:var(--ink)}
    .opt.is-on{background:linear-gradient(135deg,rgba(200,160,106,.22),rgba(200,160,106,.08));border-color:var(--bronze);color:var(--ink)}
    .prev-out{background:radial-gradient(120% 120% at 80% 0%,rgba(200,160,106,.16),transparent 60%),#0a0e12;border-left:1px solid var(--line);padding:clamp(1.6rem,3vw,2.4rem);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center}
    .prev-out-lbl{font-size:.76rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted)}
    .prev-amount{font-family:var(--disp);font-size:clamp(2.2rem,5vw,3rem);font-weight:700;margin:.4rem 0 .6rem;line-height:1;
      background:linear-gradient(120deg,var(--bronze),#ecd3aa);-webkit-background-clip:text;background-clip:text;color:transparent}
    .prev-time{display:inline-flex;align-items:center;gap:.5rem;color:var(--steel);font-size:.92rem}
    .prev-cta{margin-top:1.6rem;width:100%}
    .prev-note{font-size:.76rem;color:var(--muted);margin-top:.8rem}

    /* LISTINO */
    .serv-list{display:flex;flex-direction:column;border:1px solid var(--line);border-radius:18px;overflow:hidden}
    .srow{display:grid;grid-template-columns:auto 1fr auto;gap:1.1rem;align-items:center;padding:1.15rem 1.3rem;border-bottom:1px solid var(--line);transition:background .25s}
    .srow:last-child{border-bottom:0}
    .srow:hover{background:rgba(231,237,243,.03)}
    .srow-ic{font-size:1.5rem;width:48px;height:48px;display:grid;place-items:center;background:var(--panel);border:1px solid var(--line);border-radius:12px}
    .srow-main b{font-family:var(--disp);font-size:1.12rem;display:block}
    .srow-main span{color:var(--muted);font-size:.9rem}
    .srow-meta{text-align:right;white-space:nowrap}
    .srow-meta i{font-family:var(--disp);font-style:normal;font-weight:600;color:var(--bronze);font-size:1.1rem;display:block}
    .srow-meta em{font-style:normal;color:var(--muted);font-size:.82rem}

    /* LABORATORIO */
    .lab-grid{display:grid;grid-template-columns:.9fr 1.1fr;gap:clamp(1.5rem,4vw,3.5rem);align-items:center}
    .gears{width:100%;border-radius:20px;border:1px solid var(--line)}
    .gear{transform-box:fill-box}
    .gear{animation:spin 18s linear infinite}
    .gear.rev{animation:spin 13s linear infinite reverse}
    @keyframes spin{to{transform:rotate(360deg)}}
    .lab-text h2{margin:.4rem 0 1rem}
    .lab-text p{color:var(--muted);margin-bottom:1.6rem;max-width:48ch}
    .lab-stats{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
    .lab-stat{background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:1.2rem}
    .lab-stat b{font-family:var(--disp);font-size:1.9rem;color:var(--bronze);display:block;line-height:1}
    .lab-stat span{color:var(--muted);font-size:.84rem;margin-top:.2rem;display:block}

    /* GALLERIA */
    .gallery{display:grid;grid-template-columns:repeat(4,1fr);gap:1.2rem}
    .gw{background:var(--panel);border:1px solid var(--line);border-radius:16px;padding:1.2rem;text-align:center;transition:transform .3s var(--ease),border-color .3s}
    .gw:hover{transform:translateY(-6px);border-color:var(--bronze)}
    .gw svg{width:74%;margin:0 auto .8rem;transition:transform .5s var(--ease)}
    .gw:hover svg{transform:rotate(8deg)}
    .gw img{width:100%;aspect-ratio:1;object-fit:cover;border-radius:10px;margin:0 0 .8rem;transition:transform .5s var(--ease)}
    .gw:hover img{transform:scale(1.06)}
    .gw figcaption{color:var(--muted);font-size:.86rem}

    /* TRUST */
    .ctrust-sec{display:flex;flex-direction:column;gap:clamp(2rem,5vw,3.5rem)}
    .ctrust{display:grid;grid-template-columns:repeat(4,1fr);gap:1.2rem}
    .ct{background:var(--panel);border:1px solid var(--line);border-radius:16px;padding:1.5rem}
    .ct-ic{font-size:1.6rem;display:block;margin-bottom:.7rem}
    .ct b{font-family:var(--disp);font-size:1.1rem;display:block;margin-bottom:.2rem}
    .ct span{color:var(--muted);font-size:.9rem}
    .ctesti{display:grid;grid-template-columns:repeat(3,1fr);gap:1.4rem}
    .cte{background:rgba(231,237,243,.03);border:1px solid var(--line);border-radius:16px;padding:1.7rem}
    .cte-stars{color:var(--bronze);letter-spacing:.15em;margin-bottom:.8rem}
    .cte blockquote{font-family:var(--disp);font-size:1.04rem;line-height:1.5}
    .cte figcaption{margin-top:1rem;color:var(--muted);font-size:.9rem}

    /* CTA */
    .ccta{text-align:center}
    .ccta-inner{background:radial-gradient(120% 120% at 50% 0%,rgba(200,160,106,.16),transparent 60%),linear-gradient(180deg,var(--panel),var(--bg));border:1px solid var(--line);border-radius:24px;padding:clamp(2.6rem,6vw,4.5rem) clamp(1.4rem,5vw,3rem)}
    .ccta-inner h2{font-size:clamp(2rem,5vw,3.4rem);margin:.3rem 0 1rem}
    .ccta-inner p{color:var(--muted);max-width:440px;margin:0 auto 2rem}
    .ccta-actions{display:flex;gap:.8rem;justify-content:center;flex-wrap:wrap}
    .cinfo{display:flex;gap:2.2rem;justify-content:center;flex-wrap:wrap;margin-top:2.6rem;padding-top:2rem;border-top:1px solid var(--line)}
    .cinfo b{display:block;font-family:var(--disp);color:var(--bronze);font-size:1.02rem}
    .cinfo span{color:var(--muted);font-size:.9rem}

    .cfoot{max-width:1180px;margin:0 auto;padding:1.8rem clamp(1.2rem,5vw,3rem);display:flex;justify-content:space-between;gap:1rem;flex-wrap:wrap;color:var(--muted);font-size:.84rem;border-top:1px solid var(--line)}
    .cfoot b{color:var(--ink)}
    .cfoot a{color:var(--bronze);font-weight:600}

    /* PROCESSO timeline */
    .timeline{list-style:none;position:relative;max-width:720px;margin:0 auto}
    .timeline::before{content:'';position:absolute;left:11px;top:8px;bottom:8px;width:2px;background:linear-gradient(var(--bronze),var(--steel));opacity:.4}
    .tl-step{position:relative;padding:0 0 1.3rem 2.6rem}
    .tl-step:last-child{padding-bottom:0}
    .tl-dot{position:absolute;left:3px;top:6px;width:18px;height:18px;border-radius:50%;background:var(--bg);border:2px solid var(--bronze);box-shadow:0 0 0 4px rgba(200,160,106,.12)}
    .tl-card{background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:1.05rem 1.3rem}
    .tl-n{font-family:var(--disp);font-size:.78rem;color:var(--bronze);letter-spacing:.08em}
    .tl-card h3{font-size:1.1rem;margin:.15rem 0 .3rem}
    .tl-card p{color:var(--muted);font-size:.92rem}

    /* TRACKER */
    .ctrack{max-width:840px;margin:0 auto;background:linear-gradient(180deg,var(--panel),var(--bg2));border:1px solid var(--line);border-radius:20px;padding:clamp(1.6rem,4vw,2.6rem)}
    .ctrack-head{text-align:center}
    .ctrack .ckicker{margin-bottom:.5rem}
    .ctrack h2{font-size:clamp(1.6rem,4vw,2.4rem)}
    .ctrack .clead{margin-bottom:1.3rem}
    .track-form{display:flex;gap:.6rem;max-width:420px;margin:0 auto;flex-wrap:wrap}
    .track-form input{flex:1;min-width:170px;padding:.8rem 1rem;border-radius:10px;border:1px solid var(--line);background:rgba(0,0,0,.3);color:var(--ink);font-family:var(--disp);font-size:1rem;letter-spacing:.05em;text-transform:uppercase}
    .track-form input:focus{outline:none;border-color:var(--bronze)}
    .track-hint{text-align:center;color:var(--muted);font-size:.84rem;margin-top:.8rem}
    .track-ex{background:none;border:0;border-bottom:1px dashed var(--bronze);color:var(--bronze);cursor:pointer;font-family:var(--disp);font-size:.84rem;padding:0}
    .track-result{margin-top:1.6rem;background:#0a0e12;border:1px solid var(--line);border-radius:14px;padding:1.4rem}
    .track-empty{color:var(--muted);text-align:center;margin:0}
    .track-top{display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}
    .track-top b{font-family:var(--disp);font-size:1.3rem;letter-spacing:.05em}
    .track-badge{padding:.3rem .8rem;border-radius:999px;background:rgba(200,160,106,.16);color:var(--bronze);font-size:.82rem;font-weight:600;border:1px solid rgba(200,160,106,.3)}
    .track-badge.is-done{background:rgba(92,186,92,.16);color:#7dd37d;border-color:rgba(92,186,92,.4)}
    .track-model{color:var(--muted);font-size:.92rem;margin:.4rem 0 1.3rem}
    .track-steps{display:flex;justify-content:space-between;gap:.3rem;position:relative}
    .track-steps::before{content:'';position:absolute;top:9px;left:8%;right:8%;height:2px;background:var(--line)}
    .tstep{display:flex;flex-direction:column;align-items:center;gap:.5rem;flex:1;position:relative;z-index:1}
    .tstep-dot{width:20px;height:20px;border-radius:50%;background:var(--bg2);border:2px solid var(--line)}
    .tstep.done .tstep-dot{background:var(--bronze);border-color:var(--bronze)}
    .tstep.now .tstep-dot{border-color:var(--bronze);box-shadow:0 0 0 4px rgba(200,160,106,.2);background:var(--bronze)}
    .tstep-lbl{font-size:.72rem;color:var(--muted);text-align:center;line-height:1.2}
    .tstep.now .tstep-lbl,.tstep.done .tstep-lbl{color:var(--ink)}
    .track-eta{text-align:center;margin-top:1.2rem;color:var(--steel);font-weight:600;font-size:.95rem}

    /* BEFORE/AFTER */
    .ba{max-width:540px;margin:0 auto 2.5rem}
    .ba-stage{position:relative;border-radius:16px;overflow:hidden;border:1px solid var(--line);aspect-ratio:5/4;--pos:50%;background:#0c1015;touch-action:none}
    .ba-after,.ba-before{position:absolute;inset:0;touch-action:none}
    .ba-stage *{touch-action:none}
    .ba-after svg,.ba-before svg{width:100%;height:100%}
    .ba-before{clip-path:inset(0 calc(100% - var(--pos)) 0 0)}
    .ba-tag{position:absolute;top:.7rem;padding:.25rem .7rem;border-radius:999px;font-size:.72rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase}
    .ba-tag-a{right:.7rem;background:rgba(200,160,106,.92);color:#1a130a}
    .ba-tag-b{left:.7rem;background:rgba(125,138,153,.92);color:#0c1015}
    .ba-handle{position:absolute;top:0;bottom:0;left:var(--pos);width:2px;background:#fff;transform:translateX(-1px);pointer-events:none}
    .ba-handle span{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:34px;height:34px;border-radius:50%;background:#fff;color:#0c1015;display:grid;place-items:center;font-size:.95rem;box-shadow:0 4px 12px rgba(0,0,0,.45)}
    .ba-handle span::before{content:'⇄'}
    .ba input[type=range]{-webkit-appearance:none;appearance:none;width:100%;height:6px;border-radius:999px;background:var(--line);outline:none;margin:1rem 0 .6rem}
    .ba input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;appearance:none;width:22px;height:22px;border-radius:50%;background:var(--bronze);cursor:pointer;border:2px solid #1a130a}
    .ba input[type=range]::-moz-range-thumb{width:20px;height:20px;border-radius:50%;background:var(--bronze);cursor:pointer;border:2px solid #1a130a}
    .ba-cap{text-align:center;color:var(--muted);font-size:.86rem}

    /* MARQUEE recensioni */
    .cmarquee{overflow:hidden;-webkit-mask-image:linear-gradient(90deg,transparent,#000 6%,#000 94%,transparent);mask-image:linear-gradient(90deg,transparent,#000 6%,#000 94%,transparent);border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:1.3rem 0}
    .cmarquee-row{display:inline-flex;gap:2.5rem;white-space:nowrap;animation:cmarq 38s linear infinite;will-change:transform}
    .cq{color:var(--muted);font-size:.95rem}
    .cq i{color:var(--bronze);font-style:normal;letter-spacing:.1em;margin-right:.4rem}

    /* FAQ */
    .cfaq{max-width:880px}
    .faq{display:flex;flex-direction:column;gap:.8rem}
    .faq-i{background:var(--panel);border:1px solid var(--line);border-radius:14px;overflow:hidden;transition:border-color .25s}
    .faq-i[open]{border-color:var(--bronze)}
    .faq-i summary{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:1.1rem 1.3rem;cursor:pointer;font-family:var(--disp);font-size:1.06rem;color:var(--ink);list-style:none}
    .faq-i summary::-webkit-details-marker{display:none}
    /* toggle FAQ: box tecnico squadrato (firma Cronos) */
    .faq-x{position:relative;width:24px;height:24px;flex:none;border:1px solid var(--line);border-radius:4px;background:rgba(0,0,0,.25);transition:border-color .3s}
    .faq-x::before,.faq-x::after{content:'';position:absolute;background:var(--bronze);transition:transform .3s var(--ease),opacity .3s}
    .faq-x::before{top:11px;left:6px;width:12px;height:2px}
    .faq-x::after{top:5px;left:11px;width:2px;height:12px}
    .faq-i[open] .faq-x{border-color:var(--bronze)}
    .faq-i[open] .faq-x::after{transform:rotate(90deg);opacity:0}
    .faq-a{padding:0 1.3rem 1.2rem;color:var(--muted);font-size:.95rem}

    /* DOVE SIAMO */
    .dove-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(1.5rem,4vw,3rem);align-items:center}
    .dove-map{position:relative;border-radius:18px;overflow:hidden;border:1px solid var(--line);background:#0a0e12;aspect-ratio:4/3}
    .mapsvg{width:100%;height:100%;object-fit:cover}
    .dove-pin{position:absolute;left:1rem;bottom:1rem;background:rgba(12,16,21,.85);backdrop-filter:blur(6px);border:1px solid var(--line);padding:.4rem .8rem;border-radius:999px;font-size:.85rem;color:var(--bronze)}
    .dove-info h2{margin:.3rem 0 1rem}
    .dove-list{list-style:none;display:flex;flex-direction:column;gap:.7rem;margin:1.2rem 0 1.6rem}
    .dove-list li{color:var(--muted);font-size:.96rem}
    .dove-list b{display:block;color:var(--ink);font-family:var(--disp);font-size:.95rem;margin-bottom:.1rem}
    .open-badge{display:inline-flex;align-items:center;gap:.55rem;padding:.5rem .9rem;border-radius:999px;border:1px solid var(--line);font-size:.9rem;color:var(--muted)}
    .open-badge .dot{width:9px;height:9px;border-radius:50%;background:#d9694e;box-shadow:0 0 8px #d9694e;flex:none}
    .open-badge.is-open .dot{background:#5cba5c;box-shadow:0 0 8px #5cba5c}
    .open-badge b{color:var(--ink)}

    /* LEAD FORM */
    .lead{display:flex;flex-direction:column;gap:.9rem;max-width:560px;margin:0 auto 1.2rem;text-align:left}
    .lead-row{display:grid;grid-template-columns:1fr 1fr;gap:.9rem}
    .lead label{display:flex;flex-direction:column;gap:.35rem;font-size:.72rem;letter-spacing:.06em;text-transform:uppercase;color:var(--muted)}
    .lead input,.lead select,.lead textarea{padding:.75rem .9rem;border-radius:10px;border:1px solid var(--line);background:rgba(0,0,0,.3);color:var(--ink);font-family:var(--sans);font-size:.95rem}
    .lead textarea{resize:vertical;min-height:74px}
    .lead select option{color:#11161d}
    .lead input:focus,.lead select:focus,.lead textarea:focus{outline:none;border-color:var(--bronze)}
    .lead-full{grid-column:1/-1}
    .lead-submit{margin-top:.3rem;width:100%}
    .lead-priv{font-size:.76rem;color:var(--muted);text-align:center}
    .lead-done{max-width:520px;margin:0 auto 1.2rem;text-align:center;background:rgba(200,160,106,.1);border:1px solid rgba(200,160,106,.4);border-radius:16px;padding:2rem}
    .lead-check{display:inline-grid;place-items:center;width:54px;height:54px;border-radius:50%;background:var(--bronze);color:#1a130a;font-size:1.6rem;margin-bottom:.8rem}
    .lead-done h3{font-size:1.4rem;margin-bottom:.4rem}
    .lead-done p{color:var(--muted)}
    .resv-sep{color:var(--muted);font-size:.85rem;margin:.2rem 0 1.1rem}

    /* WhatsApp float */
    .wa-float{position:fixed;right:18px;bottom:18px;z-index:350;width:56px;height:56px;border-radius:50%;background:#25d366;color:#fff;display:grid;place-items:center;box-shadow:0 12px 30px -8px rgba(37,211,102,.6);transition:transform .25s var(--ease)}
    .wa-float:hover{transform:scale(1.08) translateY(-2px)}
    .wa-float::after{content:'';position:absolute;inset:0;border-radius:50%;border:2px solid #25d366;animation:wapulse 2.4s ease-out infinite}
    @keyframes wapulse{0%{transform:scale(1);opacity:.7}100%{transform:scale(1.6);opacity:0}}

    /* reveal */
    /* Reveal — ingresso laterale "da blueprint", firma di Cronos */
    .r{opacity:0;transform:translateX(-30px);transition:opacity .7s var(--ease),transform .7s var(--ease)}
    .r.in{opacity:1;transform:none}

    @media (max-width:960px){
      .chero-grid{grid-template-columns:1fr;text-align:center}
      .chero-watch{order:-1}.ceyebrow,.chero-cta,.chero-trust{justify-content:center}.chero-sub{margin-left:auto;margin-right:auto}
      .prev-card{grid-template-columns:1fr}.prev-out{border-left:0;border-top:1px solid var(--line)}
      .lab-grid{grid-template-columns:1fr}.lab-visual{order:-1;max-width:420px;margin:0 auto}
      .gallery{grid-template-columns:repeat(2,1fr)}.ctrust{grid-template-columns:repeat(2,1fr)}
      .dove-grid{grid-template-columns:1fr}
    }
    @media (max-width:680px){
      .clinks{display:none}.cnav-toggle{display:grid;place-items:center}
      .cbrand-sub,.cbrand em{display:none}
      .cnav{gap:.6rem}
      .cnav>.cbtn-solid{padding:.5rem .8rem;font-size:.76rem;white-space:nowrap}
      .cnav.open .clinks{display:flex;position:absolute;top:100%;left:0;right:0;flex-direction:column;gap:1.1rem;background:rgba(12,16,21,.98);backdrop-filter:blur(14px);border-bottom:1px solid var(--line);padding:1.2rem clamp(1.2rem,5vw,3rem) 1.5rem;margin:0}
      .opts-grid{grid-template-columns:1fr}.lab-stats{grid-template-columns:1fr 1fr}
      .lead-row{grid-template-columns:1fr}.tstep-lbl{font-size:.62rem}
      /* recensioni: su mobile niente marquee, vanno a capo (niente testo tagliato) */
      .cmarquee{-webkit-mask-image:none;mask-image:none}
      .cmarquee-row{animation:none;flex-wrap:wrap;white-space:normal;justify-content:center;gap:.9rem 1.5rem}
      .cmarquee-row .cq[aria-hidden="true"]{display:none}
      .cq{flex:0 1 100%;text-align:center}
    }
    @media (max-width:460px){ .gallery,.ctrust{grid-template-columns:1fr} }
    @media (prefers-reduced-motion:reduce){
      .r{opacity:1!important;transform:none!important;transition:none}
      .gear,.cgear,.ceyebrow .tick,.cmarquee-row,.wa-float::after{animation:none!important}
      .cmarquee{-webkit-mask-image:none;mask-image:none}
      .cmarquee-row{flex-wrap:wrap;white-space:normal;justify-content:center;gap:.9rem 1.5rem}
      .cmarquee-row .cq[aria-hidden="true"]{display:none}
    }
  </style>

  <script is:inline>
    (() => {
      const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
      const cnav = document.getElementById('cnav');
      const onScroll = () => cnav.classList.toggle('solid', window.scrollY > 40);
      window.addEventListener('scroll', onScroll, { passive: true });

      const toggle = document.getElementById('navToggle');
      toggle.addEventListener('click', () => { const o = cnav.classList.toggle('open'); toggle.setAttribute('aria-expanded', String(o)); });
      document.querySelectorAll('#clinks a').forEach((a) => a.addEventListener('click', () => cnav.classList.remove('open')));
      document.addEventListener('click', (e) => { if (cnav.classList.contains('open') && !cnav.contains(e.target)) { cnav.classList.remove('open'); toggle.setAttribute('aria-expanded', 'false'); } });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && cnav.classList.contains('open')) { cnav.classList.remove('open'); toggle.setAttribute('aria-expanded', 'false'); } });

      /* ---- Hour markers (generati) ---- */
      const mk = document.getElementById('markers');
      for (let i = 0; i < 12; i++) {
        const big = i % 3 === 0;
        const r = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
        r.setAttribute('x', big ? '176.5' : '178');
        r.setAttribute('y', '38');
        r.setAttribute('width', big ? '7' : '4');
        r.setAttribute('height', big ? '18' : '12');
        r.setAttribute('rx', '2');
        r.setAttribute('transform', `rotate(${i * 30} 180 180)`);
        r.setAttribute('opacity', big ? '1' : '.6');
        mk.appendChild(r);
      }

      /* ---- Orologio LIVE ---- */
      const hH = document.getElementById('handHour');
      const hM = document.getElementById('handMin');
      const hS = document.getElementById('handSec');
      const dateNum = document.getElementById('dateNum');
      function setHands(smooth) {
        const now = new Date();
        const ms = now.getMilliseconds();
        const s = now.getSeconds() + (smooth ? ms / 1000 : 0);
        const m = now.getMinutes() + s / 60;
        const h = (now.getHours() % 12) + m / 60;
        hH.setAttribute('transform', `rotate(${h * 30} 180 180)`);
        hM.setAttribute('transform', `rotate(${m * 6} 180 180)`);
        hS.setAttribute('transform', `rotate(${s * 6} 180 180)`);
        dateNum.textContent = now.getDate();
      }
      if (reduced) { setHands(false); setInterval(() => setHands(false), 1000); }
      else { const loop = () => { setHands(true); requestAnimationFrame(loop); }; loop(); }

      /* ---- Preventivo ---- */
      const prevAmount = document.getElementById('prevAmount');
      const prevTime = document.getElementById('prevTime');
      let factor = 1, extraDays = 0, base = 15, days = 0;
      const fmtMoney = (n) => '€ ' + Math.round(n).toLocaleString('it-IT');
      function quote() {
        const price = Math.max(12, base * factor);
        prevAmount.textContent = `${fmtMoney(price * 0.95)} – ${fmtMoney(price * 1.12)}`;
        const d = Math.round(days * (factor > 1.5 ? 1.4 : 1)) + (days > 0 ? extraDays : (extraDays ? Math.ceil(extraDays / 3) : 0));
        if (d <= 0) prevTime.textContent = base <= 20 ? 'pronto in ~10 minuti, mentre aspetti' : 'pronto in giornata';
        else if (d === 1) prevTime.textContent = 'pronto in ~1 giorno lavorativo';
        else prevTime.textContent = `pronto in ~${d} giorni lavorativi`;
      }
      document.querySelectorAll('#moveOpts .opt').forEach((b) => b.addEventListener('click', () => {
        document.querySelectorAll('#moveOpts .opt').forEach((x) => x.classList.remove('is-on'));
        b.classList.add('is-on'); factor = +b.dataset.f; extraDays = +b.dataset.extra; quote();
      }));
      document.querySelectorAll('#jobOpts .opt').forEach((b) => b.addEventListener('click', () => {
        document.querySelectorAll('#jobOpts .opt').forEach((x) => x.classList.remove('is-on'));
        b.classList.add('is-on'); base = +b.dataset.base; days = +b.dataset.days; quote();
      }));
      quote();

      /* ---- Tracker riparazione (demo) ---- */
      const trackData = {
        'CR-2048': { model: 'Cronografo automatico · revisione completa', step: 2, eta: 'Pronto previsto: tra circa 6 giorni lavorativi.' },
        'CR-1099': { model: 'Orologio al quarzo · sostituzione vetro', step: 4, eta: 'Pronto: puoi passare in laboratorio a ritirarlo!' },
        'CR-3001': { model: 'Solo tempo vintage · restauro quadrante', step: 1, eta: 'Pronto previsto: tra circa 3 settimane.' },
      };
      const TSTEPS = ['Ricevuto', 'In diagnosi', 'In lavorazione', 'Collaudo', 'Pronto'];
      const trackForm = document.getElementById('trackForm');
      const trackInput = document.getElementById('trackInput');
      const trackResult = document.getElementById('trackResult');
      function runTrack(code) {
        if (!trackResult) return;
        code = (code || '').trim().toUpperCase();
        trackResult.hidden = false;
        const d = trackData[code];
        if (!d) { trackResult.innerHTML = '<p class="track-empty">Codice non trovato. Controlla la ricevuta o prova uno dei codici demo qui sopra.</p>'; return; }
        const done = d.step >= 4;
        trackResult.innerHTML =
          '<div class="track-top"><b>' + code + '</b><span class="track-badge' + (done ? ' is-done' : '') + '">' + TSTEPS[d.step] + '</span></div>' +
          '<p class="track-model">' + d.model + '</p>' +
          '<div class="track-steps">' + TSTEPS.map(function (s, i) {
            return '<div class="tstep' + (i < d.step ? ' done' : '') + (i === d.step ? ' now' : '') + '"><span class="tstep-dot"></span><span class="tstep-lbl">' + s + '</span></div>';
          }).join('') + '</div>' +
          '<p class="track-eta">' + d.eta + '</p>';
      }
      if (trackForm) trackForm.addEventListener('submit', function (e) { e.preventDefault(); runTrack(trackInput.value); });
      document.querySelectorAll('.track-ex').forEach(function (b) { b.addEventListener('click', function () { trackInput.value = b.dataset.code; runTrack(b.dataset.code); }); });

      /* ---- Slider prima/dopo ---- */
      const baStage = document.getElementById('baStage');
      const baRange = document.getElementById('baRange');
      if (baStage && baRange) {
        const setBA = function (v) { v = Math.max(0, Math.min(100, v)); baStage.style.setProperty('--pos', v + '%'); baRange.value = v; };
        setBA(50);
        baRange.addEventListener('input', function () { setBA(+baRange.value); });
        let dragging = false;
        const fromEvent = function (e) { const r = baStage.getBoundingClientRect(); const x = (e.clientX || 0) - r.left; setBA(x / r.width * 100); };
        baStage.addEventListener('pointerdown', function (e) { dragging = true; fromEvent(e); });
        window.addEventListener('pointermove', function (e) { if (dragging) fromEvent(e); });
        window.addEventListener('pointerup', function () { dragging = false; });
      }

      /* ---- Form guasto (demo) ---- */
      const cForm = document.getElementById('leadForm');
      const cDone = document.getElementById('leadDone');
      if (cForm) cForm.addEventListener('submit', function (e) { e.preventDefault(); cForm.hidden = true; cDone.hidden = false; cDone.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth', block: 'center' }); });

      /* ---- "Aperto adesso" ---- */
      (function () {
        const el = document.getElementById('openStatus'); if (!el) return;
        const sched = [null, [540, 1110], [540, 1110], [540, 1110], [540, 1110], [540, 1110], null]; // Lun–Ven 9:00–18:30
        const days = ['domenica', 'lunedì', 'martedì', 'mercoledì', 'giovedì', 'venerdì', 'sabato'];
        const fmt = function (m) { return String(Math.floor(m / 60)).padStart(2, '0') + ':' + String(m % 60).padStart(2, '0'); };
        const now = new Date(), d = now.getDay(), mins = now.getHours() * 60 + now.getMinutes(), t = sched[d];
        let open = false, txt = '';
        if (t && mins >= t[0] && mins < t[1]) { open = true; txt = '· chiude alle ' + fmt(t[1]); }
        else if (t && mins < t[0]) { txt = '· apre oggi alle ' + fmt(t[0]); }
        else { for (let i = 1; i <= 7; i++) { const s = sched[(d + i) % 7]; if (s) { txt = '· ' + (i === 1 ? 'apre domani' : 'apre ' + days[(d + i) % 7]) + ' alle ' + fmt(s[0]); break; } } }
        el.classList.toggle('is-open', open);
        el.querySelector('b').textContent = open ? 'Aperto adesso' : 'Chiuso ora';
        el.querySelector('span:last-child').textContent = ' ' + txt;
      })();

      /* ---- Reveal + contatori ---- */
      const animateCount = (el) => {
        const target = +el.dataset.count, suf = el.dataset.suffix || '';
        const t0 = performance.now(), dur = 1500;
        const step = (t) => {
          const p = Math.min(1, (t - t0) / dur), e = 1 - Math.pow(1 - p, 3);
          el.textContent = Math.round(target * e).toLocaleString('it-IT') + suf;
          if (p < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      };
      if (reduced) {
        document.querySelectorAll('[data-count]').forEach((el) => el.textContent = (+el.dataset.count).toLocaleString('it-IT') + (el.dataset.suffix || ''));
      } else {
        const io = new IntersectionObserver((es) => es.forEach((en) => {
          if (en.isIntersecting) { en.target.classList.add('in'); const c = en.target.querySelector?.('[data-count]'); if (en.target.dataset && en.target.dataset.count) animateCount(en.target); else if (c) animateCount(c); io.unobserve(en.target); }
        }), { threshold: 0.14 });
        document.querySelectorAll('.r').forEach((el) => io.observe(el));
      }
    })();
  </script>
</body>
</html>
