---
// DEMO standalone — "Cronos", laboratorio orologiaio a Torino. Tema SCURO / tecnico (acciaio + bronzo).
// Sito a sé (non usa il Layout di Mole Digitale). JS vanilla: orologio analogico LIVE + preventivo riparazione.
import '@fontsource-variable/inter';
import '@fontsource-variable/space-grotesk';
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>Cronos — Laboratorio orologiaio a Torino · Riparazioni, revisioni e restauro</title>
  <meta name="description" content="Cronos, laboratorio orologiaio a Torino: cambio batteria in 10 minuti, revisione completa del movimento, prova impermeabilità e restauro vintage. Preventivo gratuito." />
  <meta name="theme-color" content="#0c1015" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><circle cx='12' cy='12' r='9' fill='none' stroke='%23c8a06a' stroke-width='2'/><path d='M12 7v5l3 2' fill='none' stroke='%239fb3c8' stroke-width='2' stroke-linecap='round'/></svg>" />
</head>
<body>
  <a class="demo-flag" href="/">★ Demo realizzata da <b>Mole Digitale</b> · torna al sito ↩</a>

  <header class="cnav" id="cnav">
    <a href="#top" class="cbrand"><span class="cgear" aria-hidden="true"></span>CRONOS<em>·</em><span class="cbrand-sub">orologeria</span></a>
    <nav class="clinks" id="clinks">
      <a href="#preventivo">Preventivo</a>
      <a href="#listino">Listino</a>
      <a href="#laboratorio">Laboratorio</a>
      <a href="#restauro">Restauro</a>
      <a href="#contatti">Contatti</a>
    </nav>
    <button class="cnav-toggle" id="navToggle" aria-label="Apri il menu" aria-expanded="false" aria-controls="clinks">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
    </button>
    <a href="#preventivo" class="cbtn cbtn-solid">Preventivo gratuito</a>
  </header>

  <main id="main">
  <!-- HERO -->
  <section class="chero" id="top">
    <div class="chero-grid">
      <div class="chero-text">
        <p class="ceyebrow r"><span class="tick"></span> Laboratorio orologiaio · Torino dal 1979</p>
        <h1 class="chero-title r">Il tempo,<br/>riparato <span class="grad">a regola d'arte.</span></h1>
        <p class="chero-sub r">Cambio batteria mentre aspetti, revisione completa del movimento, prova di impermeabilità e restauro di orologi vintage. Mani esperte, ricambi originali.</p>
        <div class="chero-cta r">
          <a href="#preventivo" class="cbtn cbtn-solid">Richiedi un preventivo</a>
          <a href="#listino" class="cbtn cbtn-ghost">Vedi il listino</a>
        </div>
        <ul class="chero-trust r" aria-label="In sintesi">
          <li><span class="ct-lbl">Garanzia</span><b>24<i>mesi</i></b></li>
          <li><span class="ct-lbl">Batteria</span><b>10<i>min</i></b></li>
          <li><span class="ct-lbl">Marche</span><b>45<i>+</i></b></li>
        </ul>
      </div>

      <div class="chero-watch r">
        <svg viewBox="0 0 360 360" class="watch" id="watch" role="img" aria-label="Orologio che segna l'ora attuale">
          <defs>
            <radialGradient id="case" cx=".4" cy=".35" r=".75"><stop offset="0" stop-color="#e6c896"/><stop offset=".5" stop-color="#c8a06a"/><stop offset="1" stop-color="#7c5f34"/></radialGradient>
            <radialGradient id="dial" cx=".4" cy=".35" r=".9"><stop offset="0" stop-color="#1d242e"/><stop offset="1" stop-color="#0c1015"/></radialGradient>
          </defs>
          <circle cx="180" cy="180" r="172" fill="url(#case)"/>
          <circle cx="180" cy="180" r="156" fill="#11161d"/>
          <circle cx="180" cy="180" r="150" fill="url(#dial)" stroke="#2a333f" stroke-width="2"/>
          <!-- minute ticks -->
          <circle cx="180" cy="180" r="138" fill="none" stroke="#4a5663" stroke-width="6" stroke-dasharray="1.5 12.95"/>
          <!-- hour markers -->
          <g id="markers" fill="#c8a06a"></g>
          <!-- numerals -->
          <g fill="#cfd8e2" font-family="'Space Grotesk Variable','Space Grotesk',sans-serif" font-size="22" font-weight="600" text-anchor="middle">
            <text x="180" y="68">12</text><text x="292" y="188">3</text><text x="180" y="306">6</text><text x="76" y="188">9</text>
          </g>
          <text x="180" y="138" text-anchor="middle" fill="#c8a06a" font-family="'Space Grotesk Variable','Space Grotesk',sans-serif" font-size="15" font-weight="600" letter-spacing="3">CRONOS</text>
          <text x="180" y="158" text-anchor="middle" fill="#7d8a99" font-family="'Inter Variable',sans-serif" font-size="9" letter-spacing="4">AUTOMATIC · TORINO</text>
          <!-- date window -->
          <rect x="222" y="170" width="26" height="20" rx="2" fill="#e7edf3"/>
          <text id="dateNum" x="235" y="185" text-anchor="middle" fill="#11161d" font-family="'Space Grotesk Variable',sans-serif" font-size="13" font-weight="700">21</text>
          <!-- hands -->
          <g id="handHour"><rect x="174" y="98" width="12" height="92" rx="6" fill="#e7edf3"/></g>
          <g id="handMin"><rect x="176.5" y="60" width="7" height="130" rx="3.5" fill="#cfd8e2"/></g>
          <g id="handSec"><rect x="178.6" y="46" width="2.8" height="158" rx="1.4" fill="#c8a06a"/><circle cx="180" cy="180" r="7" fill="#c8a06a"/></g>
          <circle cx="180" cy="180" r="3.4" fill="#11161d"/>
        </svg>
        <span class="watch-glow" aria-hidden="true"></span>
      </div>
    </div>
  </section>

  <!-- PREVENTIVO -->
  <section class="csection" id="preventivo">
    <div class="chead">
      <span class="ckicker r">Preventivo immediato</span>
      <h2 class="r">Quanto costa <span class="grad">ripararlo?</span></h2>
      <p class="clead r">Scegli il tuo orologio e l'intervento: ti diamo subito una stima di prezzo e tempi. La diagnosi precisa, in laboratorio, è gratuita.</p>
    </div>

    <div class="prev-card r">
      <div class="prev-controls">
        <div class="prev-field">
          <span class="prev-lbl">1 · Tipo di orologio</span>
          <div class="opts" id="moveOpts">
            <button class="opt is-on" data-f="1"   data-extra="0">Al quarzo</button>
            <button class="opt" data-f="1.35" data-extra="0">Automatico</button>
            <button class="opt" data-f="1.7"  data-extra="0">Cronografo</button>
            <button class="opt" data-f="1.9"  data-extra="6">Vintage (pre-1980)</button>
          </div>
        </div>
        <div class="prev-field">
          <span class="prev-lbl">2 · Intervento</span>
          <div class="opts opts-grid" id="jobOpts">
            <button class="opt is-on" data-base="15"  data-days="0">Cambio batteria</button>
            <button class="opt" data-base="35"  data-days="1">Prova impermeabilità</button>
            <button class="opt" data-base="55"  data-days="3">Sostituzione vetro</button>
            <button class="opt" data-base="40"  data-days="0">Cinturino / bracciale</button>
            <button class="opt" data-base="75"  data-days="4">Lucidatura cassa</button>
            <button class="opt" data-base="180" data-days="10">Revisione completa</button>
            <button class="opt" data-base="320" data-days="22">Restauro quadrante</button>
          </div>
        </div>
      </div>
      <div class="prev-out">
        <span class="prev-out-lbl">Stima indicativa</span>
        <div class="prev-amount" id="prevAmount">€ 15 – 18</div>
        <div class="prev-time"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2" stroke-linecap="round"/></svg><span id="prevTime">pronto in ~10 minuti, mentre aspetti</span></div>
        <a href="#contatti" class="cbtn cbtn-solid prev-cta">Prenota l'intervento</a>
        <p class="prev-note">Stima senza impegno · diagnosi e preventivo in laboratorio gratuiti.</p>
      </div>
    </div>
  </section>

  <!-- LISTINO / SERVIZI -->
  <section class="csection" id="listino">
    <div class="chead">
      <span class="ckicker r">Cosa facciamo</span>
      <h2 class="r">Servizi & <span class="grad">listino</span></h2>
    </div>
    <div class="serv-list">
      <div class="srow r"><div class="srow-ic">🔋</div><div class="srow-main"><b>Cambio batteria</b><span>Batteria originale, guarnizione controllata, test di tenuta.</span></div><div class="srow-meta"><i>da € 15</i><em>~10 min</em></div></div>
      <div class="srow r"><div class="srow-ic">💧</div><div class="srow-main"><b>Prova impermeabilità</b><span>Test in pressione e sostituzione guarnizioni.</span></div><div class="srow-meta"><i>da € 35</i><em>1 giorno</em></div></div>
      <div class="srow r"><div class="srow-ic">🔍</div><div class="srow-main"><b>Sostituzione vetro</b><span>Minerale, zaffiro o plexi, anche bombato.</span></div><div class="srow-meta"><i>da € 55</i><em>2–4 gg</em></div></div>
      <div class="srow r"><div class="srow-ic">⛓️</div><div class="srow-main"><b>Cinturino &amp; bracciale</b><span>Sostituzione, riduzione maglie, anse e molle.</span></div><div class="srow-meta"><i>da € 40</i><em>subito</em></div></div>
      <div class="srow r"><div class="srow-ic">✨</div><div class="srow-main"><b>Lucidatura cassa</b><span>Rifinitura satinata/lucida, via graffi e segni del tempo.</span></div><div class="srow-meta"><i>da € 75</i><em>3–5 gg</em></div></div>
      <div class="srow r"><div class="srow-ic">⚙️</div><div class="srow-main"><b>Revisione completa</b><span>Movimento smontato, pulito, oliato e regolato. Garanzia 24 mesi.</span></div><div class="srow-meta"><i>da € 180</i><em>~2 sett.</em></div></div>
      <div class="srow r"><div class="srow-ic">🛠️</div><div class="srow-main"><b>Restauro vintage</b><span>Quadrante, lancette e movimento riportati a vita, nel rispetto dell'originale.</span></div><div class="srow-meta"><i>da € 320</i><em>su valutazione</em></div></div>
    </div>
  </section>

  <!-- LABORATORIO -->
  <section class="csection" id="laboratorio">
    <div class="lab-grid">
      <div class="lab-visual r">
        <svg viewBox="0 0 300 300" class="gears" role="img" aria-label="Ingranaggi di un movimento">
          <rect width="300" height="300" rx="20" fill="#11161d"/>
          <g class="gear" style="transform-origin:108px 124px">
            <circle cx="108" cy="124" r="58" fill="none" stroke="#c8a06a" stroke-width="20" stroke-dasharray="7 13.2"/>
            <circle cx="108" cy="124" r="40" fill="#161c25" stroke="#3a4654" stroke-width="2"/>
            <circle cx="108" cy="124" r="8" fill="#c8a06a"/>
            <g stroke="#2a333f" stroke-width="4"><line x1="108" y1="92" x2="108" y2="156"/><line x1="76" y1="124" x2="140" y2="124"/></g>
          </g>
          <g class="gear rev" style="transform-origin:200px 186px">
            <circle cx="200" cy="186" r="44" fill="none" stroke="#9fb3c8" stroke-width="16" stroke-dasharray="6 11.0"/>
            <circle cx="200" cy="186" r="30" fill="#161c25" stroke="#3a4654" stroke-width="2"/>
            <circle cx="200" cy="186" r="6" fill="#9fb3c8"/>
            <g stroke="#2a333f" stroke-width="3"><line x1="200" y1="162" x2="200" y2="210"/><line x1="176" y1="186" x2="224" y2="186"/></g>
          </g>
          <g class="gear" style="transform-origin:214px 92px">
            <circle cx="214" cy="92" r="28" fill="none" stroke="#7d8a99" stroke-width="11" stroke-dasharray="5 8.4"/>
            <circle cx="214" cy="92" r="18" fill="#161c25" stroke="#3a4654" stroke-width="2"/>
            <circle cx="214" cy="92" r="5" fill="#7d8a99"/>
          </g>
        </svg>
      </div>
      <div class="lab-text">
        <span class="ckicker r">In laboratorio</span>
        <h2 class="r">Ogni movimento, <span class="grad">smontato e curato</span></h2>
        <p class="r">Non ci limitiamo a una pulizia esterna. Smontiamo il calibro pezzo per pezzo, laviamo a ultrasuoni, sostituiamo le parti usurate, oliamo nei punti giusti e regoliamo la precisione al cronocomparatore.</p>
        <div class="lab-stats">
          <div class="lab-stat r"><b data-count="45">0</b><span>anni di mestiere</span></div>
          <div class="lab-stat r"><b data-count="32000" data-suffix="+">0</b><span>orologi riparati</span></div>
          <div class="lab-stat r"><b data-count="45" data-suffix="+">0</b><span>marche trattate</span></div>
          <div class="lab-stat r"><b data-count="24" data-suffix=" mesi">0</b><span>di garanzia</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESSO -->
  <section class="csection cprocess">
    <div class="chead">
      <span class="ckicker r">Come funziona</span>
      <h2 class="r">Cosa succede <span class="grad">al tuo orologio</span></h2>
      <p class="clead r">Trasparenza totale, dal momento in cui ce lo affidi a quando torna al tuo polso.</p>
    </div>
    <ol class="timeline">
      <li class="tl-step r"><span class="tl-dot"></span><div class="tl-card"><span class="tl-n">01 · Accettazione</span><h3>Lo registriamo</h3><p>Scheda con foto e condizioni dell'orologio. Ricevi un codice per seguirne lo stato online.</p></div></li>
      <li class="tl-step r"><span class="tl-dot"></span><div class="tl-card"><span class="tl-n">02 · Diagnosi</span><h3>Apriamo e capiamo</h3><p>Esaminiamo il movimento e individuiamo con precisione cosa serve. Sempre gratis.</p></div></li>
      <li class="tl-step r"><span class="tl-dot"></span><div class="tl-card"><span class="tl-n">03 · Preventivo</span><h3>Ti diciamo costo e tempi</h3><p>Si procede solo dopo il tuo "sì". Nessuna sorpresa, nessun lavoro non concordato.</p></div></li>
      <li class="tl-step r"><span class="tl-dot"></span><div class="tl-card"><span class="tl-n">04 · Lavorazione</span><h3>Ci mettiamo le mani</h3><p>Smontaggio, pulizia a ultrasuoni, ricambi, oliatura e regolazione al cronocomparatore.</p></div></li>
      <li class="tl-step r"><span class="tl-dot"></span><div class="tl-card"><span class="tl-n">05 · Collaudo</span><h3>Lo mettiamo alla prova</h3><p>Test di precisione e di tenuta per più giorni, finché tutto non è perfetto.</p></div></li>
      <li class="tl-step r"><span class="tl-dot"></span><div class="tl-card"><span class="tl-n">06 · Riconsegna</span><h3>Torna al tuo polso</h3><p>Pulito e in perfetta forma, con 24 mesi di garanzia scritta.</p></div></li>
    </ol>
  </section>

  <!-- TRACKER -->
  <section class="csection ctrack-sec">
    <div class="ctrack">
      <div class="ctrack-head">
        <span class="ckicker r">Riparazione in corso?</span>
        <h2 class="r">Traccia il tuo <span class="grad">orologio</span></h2>
        <p class="clead r">Inserisci il codice che trovi sulla ricevuta e scopri a che punto siamo.</p>
        <form class="track-form r" id="trackForm">
          <input type="text" id="trackInput" placeholder="Es. CR-2048" aria-label="Codice riparazione" autocomplete="off" />
          <button class="cbtn cbtn-solid" type="submit">Traccia</button>
        </form>
        <p class="track-hint r">Demo: prova con <button type="button" class="track-ex" data-code="CR-2048">CR-2048</button>, <button type="button" class="track-ex" data-code="CR-1099">CR-1099</button> o <button type="button" class="track-ex" data-code="CR-3001">CR-3001</button>.</p>
      </div>
      <div class="track-result" id="trackResult" hidden></div>
    </div>
  </section>

  <!-- RESTAURO / GALLERIA -->
  <section class="csection" id="restauro">
    <div class="chead">
      <span class="ckicker r">Restauro &amp; collezione</span>
      <h2 class="r">Diamo una seconda vita <span class="grad">al tempo</span></h2>
      <p class="clead r">Trascina il cursore: ecco un solo tempo anni '60 prima e dopo il nostro restauro.</p>
    </div>
    <div class="ba r">
      <div class="ba-stage" id="baStage">
        <div class="ba-after">
          <svg viewBox="0 0 300 240" aria-hidden="true" preserveAspectRatio="xMidYMid slice">
            <rect width="300" height="240" fill="#0c1015"/>
            <circle cx="150" cy="120" r="90" fill="#7c5f34"/><circle cx="150" cy="120" r="86" fill="#c8a06a"/>
            <circle cx="150" cy="120" r="76" fill="#11161d"/><circle cx="150" cy="120" r="72" fill="#1d242e"/>
            <circle cx="150" cy="120" r="66" fill="none" stroke="#c8a06a" stroke-width="3" stroke-opacity=".4" stroke-dasharray="1.4 8.0"/>
            <g stroke="#c8a06a" stroke-width="4" stroke-linecap="round"><line x1="150" y1="56" x2="150" y2="68"/><line x1="214" y1="120" x2="202" y2="120"/><line x1="150" y1="184" x2="150" y2="172"/><line x1="86" y1="120" x2="98" y2="120"/></g>
            <line x1="150" y1="120" x2="120" y2="88" stroke="#e7edf3" stroke-width="5" stroke-linecap="round"/>
            <line x1="150" y1="120" x2="182" y2="86" stroke="#cfd8e2" stroke-width="3.5" stroke-linecap="round"/>
            <circle cx="150" cy="120" r="5" fill="#c8a06a"/>
            <path d="M104 70a86 86 0 0 1 96 -6" stroke="rgba(255,255,255,.16)" stroke-width="9" fill="none" stroke-linecap="round"/>
          </svg>
          <span class="ba-tag ba-tag-a">Dopo</span>
        </div>
        <div class="ba-before">
          <svg viewBox="0 0 300 240" aria-hidden="true" preserveAspectRatio="xMidYMid slice">
            <rect width="300" height="240" fill="#0c1015"/>
            <circle cx="150" cy="120" r="90" fill="#27282a"/><circle cx="150" cy="120" r="86" fill="#46443f"/>
            <circle cx="150" cy="120" r="76" fill="#101113"/><circle cx="150" cy="120" r="72" fill="#2b2620"/>
            <g stroke="#6a6258" stroke-width="4" stroke-linecap="round"><line x1="150" y1="56" x2="150" y2="68"/><line x1="214" y1="120" x2="202" y2="120"/><line x1="150" y1="184" x2="150" y2="172"/><line x1="86" y1="120" x2="98" y2="120"/></g>
            <line x1="150" y1="120" x2="120" y2="88" stroke="#7a756c" stroke-width="5" stroke-linecap="round"/>
            <line x1="150" y1="120" x2="182" y2="86" stroke="#6a6258" stroke-width="3.5" stroke-linecap="round"/>
            <circle cx="150" cy="120" r="5" fill="#6a6258"/>
            <g stroke="#ffffff" stroke-opacity=".1" stroke-width="1.3" stroke-linecap="round"><line x1="96" y1="84" x2="206" y2="150"/><line x1="110" y1="170" x2="200" y2="92"/><line x1="120" y1="120" x2="190" y2="135"/></g>
            <polyline points="150,66 160,92 150,108 166,128" fill="none" stroke="#0c1015" stroke-width="2"/>
            <g fill="#ffffff" fill-opacity=".06"><circle cx="124" cy="100" r="6"/><circle cx="176" cy="142" r="5"/><circle cx="140" cy="150" r="4"/></g>
          </svg>
          <span class="ba-tag ba-tag-b">Prima</span>
        </div>
        <div class="ba-handle" id="baHandle"><span></span></div>
      </div>
      <input type="range" id="baRange" min="0" max="100" value="50" aria-label="Confronta prima e dopo il restauro" />
      <p class="ba-cap">← trascina per confrontare prima e dopo →</p>
    </div>
    <div class="gallery">
      <figure class="gw r">
        <img src="/img/demo-orologiaio/g-solotempo.webp" alt="Orologio solo tempo in revisione" loading="lazy" />
        <figcaption>Solo tempo · revisione completa</figcaption>
      </figure>
      <figure class="gw r">
        <img src="/img/demo-orologiaio/g-cronografo.webp" alt="Cronografo da revisionare" loading="lazy" />
        <figcaption>Cronografo · revisione</figcaption>
      </figure>
      <figure class="gw r">
        <img src="/img/demo-orologiaio/g-diver.webp" alt="Orologio subacqueo vintage" loading="lazy" />
        <figcaption>Subacqueo · restauro vintage</figcaption>
      </figure>
      <figure class="gw r">
        <img src="/img/demo-orologiaio/g-tasca.webp" alt="Orologio da tasca da restaurare" loading="lazy" />
        <figcaption>Da tasca · restauro</figcaption>
      </figure>
    </div>
  </section>

  <!-- GARANZIA / TRUST -->
  <section class="csection ctrust-sec">
    <div class="ctrust">
      <div class="ct r"><span class="ct-ic">🛡️</span><b>Garanzia 24 mesi</b><span>Su ogni revisione del movimento.</span></div>
      <div class="ct r"><span class="ct-ic">🧩</span><b>Ricambi originali</b><span>O equivalenti certificati, mai pezzi dubbi.</span></div>
      <div class="ct r"><span class="ct-ic">📝</span><b>Preventivo gratuito</b><span>Diagnosi e stima senza alcun impegno.</span></div>
      <div class="ct r"><span class="ct-ic">📦</span><b>Spedizione assicurata</b><span>Non sei a Torino? Spedisci in sicurezza.</span></div>
    </div>
    <div class="cmarquee" aria-label="Recensioni dei clienti">
      <div class="cmarquee-row">
        <span class="cq"><i>★★★★★</i> "Il cronografo di mio padre era fermo da vent'anni: tornato perfetto." — Stefano D.</span>
        <span class="cq"><i>★★★★★</i> "Cambio batteria in dieci minuti mentre prendevo un caffè." — Lucia B.</span>
        <span class="cq"><i>★★★★★</i> "Revisione spiegata per bene e con garanzia. Si vede la passione." — Andrea T.</span>
        <span class="cq"><i>★★★★★</i> "Restauro del quadrante impeccabile, professionisti veri." — Marco P.</span>
        <span class="cq"><i>★★★★★</i> "Onesti sul preventivo, nessuna sorpresa al ritiro." — Elena R.</span>
        <span class="cq" aria-hidden="true"><i>★★★★★</i> "Il cronografo di mio padre era fermo da vent'anni: tornato perfetto." — Stefano D.</span>
