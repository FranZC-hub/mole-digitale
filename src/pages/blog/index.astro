---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const fmt = (d) => d.toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' });
---
<Layout title="Blog — guide e consigli | Mole Digitale" description="Guide pratiche su siti web, Google e presenza online per gli esercenti di Torino.">
  <section class="section" style="padding-top:8rem;">
    <div class="section-head" data-reveal>
      <span class="kicker">Blog</span>
      <h1>Guide e consigli, <span class="grad">senza giri di parole</span>.</h1>
      <p class="section-lead">Cose utili su siti web, Google e presenza online — spiegate semplici.</p>
    </div>
    <div class="blog-list">
      {posts.map((p) => (
        <a class="blog-card glass" href={`/blog/${p.id}/`} data-reveal>
          <time datetime={p.data.date.toISOString().slice(0, 10)}>{fmt(p.data.date)}</time>
          <h3>{p.data.title}</h3>
          <p>{p.data.description}</p>
          <span class="blog-more">Leggi l'articolo →</span>
        </a>
      ))}
    </div>
  </section>
  <style>
    .blog-list { display:grid; gap:1.4rem; max-width:820px; margin:0 auto; }
    .blog-card { display:block; padding:1.8rem; transition:transform .3s var(--ease), box-shadow .3s; }
    .blog-card:hover { transform:translateY(-5px); box-shadow:0 30px 60px -30px rgba(124,92,255,.4); }
    .blog-card time { color:var(--c2); font-size:.82rem; font-family:'Space Grotesk Variable','Space Grotesk'; }
    .blog-card h3 { font-size:1.4rem; margin:.5rem 0 .6rem; }
    .blog-card p { color:var(--muted); }
    .blog-more { display:inline-block; margin-top:1rem; color:var(--c2); font-weight:600; }
  </style>
</Layout>
