      { h: 'Menu curato', p: 'Nigiri, uramaki, sashimi e special: presentati con stile e sempre aggiornati.' },
      { h: 'Prenotazione & delivery', p: 'Tavolo, asporto e consegna: il cliente sceglie come gustarti.' },
      { h: 'Immagine premium', p: 'Design raffinato che comunica qualità e giustifica il prezzo.' },
    ],
    demoUrl: '/demo/sushi', demoName: 'Hashi', widget: 'il filtro menu crudo/cotto/veggie',
  },
  'siti-web-addestratori-cani-torino': {
    kicker: 'Per addestratori ed educatori cinofili',
    h1a: 'Siti web per', h1b: 'addestratori cani a Torino',
    intro: "Un sito che trasmette fiducia ai proprietari: percorsi chiari, metodo gentile e lezione di prova in evidenza. Chi cerca un educatore per il proprio cane trova te.",
    points: [
      { h: 'Percorsi chiari', p: 'Cuccioli, educazione di base, problemi di comportamento: ognuno trova il suo.' },
      { h: 'Lezione di prova', p: 'La prima lezione di prova in evidenza: il modo più facile per iniziare.' },
      { h: 'Metodo e fiducia', p: 'Racconti il tuo approccio gentile: i proprietari scelgono di pancia.' },
    ],
    demoUrl: '/demo/addestratore', demoName: 'Coda Felice', widget: 'il configuratore del percorso su misura',
  },
};

export function getStaticPaths() {
  return [
    'siti-web-ristoranti-torino',
    'siti-web-parrucchieri-torino',
    'siti-web-officine-torino',
    'siti-web-bar-torino',
    'siti-web-estetiste-torino',
    'siti-web-negozi-torino',
    'siti-web-pasticcerie-torino',
    'siti-web-farmacie-torino',
    'siti-web-dentisti-torino',
    'siti-web-profumerie-torino',
    'siti-web-centri-massaggi-torino',
    'siti-web-osteopati-torino',
    'siti-web-agenzie-viaggi-torino',
    'siti-web-nail-studio-torino',
    'siti-web-veterinari-torino',
    'siti-web-lavanderie-torino',
    'siti-web-ristoranti-giapponesi-torino',
    'siti-web-addestratori-cani-torino',
  ].map((settore) => ({ params: { settore } }));
}

const { settore } = Astro.params;
const d = settori[settore];
const title = `${d.h1a} ${d.h1b} — Mole Digitale`;

// Gruppo del settore: guida sia il preset del preventivo sia il testo delle FAQ
const groupOf = (slug) => {
  const k = slug.replace('siti-web-', '').replace('-torino', '');
  if (['ristoranti', 'bar', 'pasticcerie', 'ristoranti-giapponesi'].includes(k)) return 'food';
  if (['parrucchieri', 'estetiste', 'nail-studio', 'centri-massaggi', 'profumerie'].includes(k)) return 'beauty';
  if (['dentisti', 'osteopati', 'veterinari', 'farmacie'].includes(k)) return 'med';
  if (['negozi'].includes(k)) return 'shop';
  return 'base';
};
const group = groupOf(settore);

// "Cosa include" nella FAQ prezzi, coerente col settore (niente "menu" alle farmacie)
const inclusoBy = {
  food:   'menu digitale, prenotazione tavolo, galleria, SEO locale e scheda Google',
  beauty: 'prenotazione appuntamenti, galleria lavori, SEO locale e scheda Google',
  med:    'prenotazione visite, moduli di contatto, SEO locale e scheda Google',
  shop:   'catalogo prodotti, galleria, SEO locale e scheda Google',
  base:   'prenotazioni, catalogo/listino, SEO locale e scheda Google',
};

// FAQ per settore (nome interpolato) + dati strutturati FAQPage
const faqs = [
  { q: `Quanto costa un sito per ${d.h1b}?`, a: group === 'shop'
      ? `Si parte da €490 una tantum per il sito Essenziale (onepage). Per ${d.h1b} la scelta tipica è il sito Attività a €790 come vetrina con ${inclusoBy.shop} — oppure, se vuoi vendere online, l'e-commerce completo da €1.200 con carrello e pagamenti. Poi un canone di €29/mese per hosting, dominio, SSL e assistenza. Prima bozza gratis, prezzi IVA esclusa.`
      : `Si parte da €490 una tantum per il sito Essenziale (onepage); il pacchetto più scelto per ${d.h1b} è il sito Attività a €790, con ${inclusoBy[group]}. Poi un canone di €29/mese per hosting, dominio, SSL e assistenza. Prima bozza gratis, prezzi IVA esclusa.` },
  { q: 'In quanto tempo è pronto?', a: 'In media 7 giorni lavorativi da quando abbiamo foto e testi. Con il brief guidato su moledigitale.it/inizia raccogliamo tutto in una volta e partiamo subito.' },
  { q: 'Devo avere già foto e testi?', a: 'No. Se non li hai, i testi li scriviamo noi (pensati per farti scegliere dai clienti) e per le foto possiamo organizzare uno shooting a Torino. Si parte anche da una semplice chiacchierata.' },
  { q: 'Verrò trovato su Google?', a: `Il sito nasce ottimizzato per le ricerche locali (es. «${d.h1b.replace(' a Torino', '')} vicino a me») e includiamo la scheda Google Business. I risultati SEO crescono nelle settimane: ti diciamo sempre cosa aspettarti, senza promesse magiche.` },
  { q: 'E dopo la consegna?', a: 'Non sparisci in un cassetto: hosting, backup e assistenza sono nel canone. Le modifiche si fanno su richiesta a piccole cifre chiare, dette sempre prima.' },
];
const faqSchemaSettore = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
---
<!-- metaDesc: solo per i settori la cui intro supera i ~160 caratteri utili in SERP; altrimenti vale l'intro. -->
<Layout title={title} description={d.metaDesc ?? d.intro} image={`/og/${settore}.png`}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchemaSettore)} />
  <section class="section" style="padding-top:8rem;">
    <div class="section-head" data-reveal>
      <span class="kicker">{d.kicker}</span>
      <h1 style="font-size:clamp(2.2rem,5vw,3.4rem); line-height:1.1;">{d.h1a} <span class="grad">{d.h1b}</span>.</h1>
      <p class="section-lead">{d.intro}</p>
      <div style="margin-top:1.6rem; display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href="/#contatti" class="btn btn-primary btn-magnetic">Voglio il mio sito</a>
        <a href={d.demoUrl} class="btn btn-ghost">Guarda un esempio →</a>
      </div>
    </div>

    <div class="land-points">
      {d.points.map((pt) => (
        <article class="prob-card" data-reveal>
          <h3>{pt.h}</h3>
          <p>{pt.p}</p>
        </article>
      ))}
    </div>

    <div class="land-incluso" data-reveal>
      <h2>Sempre incluso, per ogni attività</h2>
      <ul>
        <li>✓ Sito velocissimo e perfetto da telefono</li>
        <li>✓ Scheda Google e SEO locale per farti trovare a Torino</li>
        <li>✓ Contatto WhatsApp diretto in un tap</li>
        <li>✓ HTTPS, backup e caricamento sotto il secondo</li>
      </ul>
      <p>All'hosting, al dominio e all'assistenza pensiamo noi a canone fisso: tu pensi all'attività, al lato tecnico pensiamo noi.</p>
    </div>

    <!-- Anteprima della demo (screenshot reale) -->
    <a class="land-shot glass" href={d.demoUrl} data-reveal>
      <img src={`/img/thumbs/${d.demoUrl.split('/').pop()}.webp`} alt={`Anteprima del sito demo ${d.demoName}`} loading="lazy" width="760" height="475" />
      <span class="land-shot-cap"><b>{d.demoName}</b> — un esempio reale di come può essere il tuo sito · <i>apri la demo →</i></span>
    </a>

    <!-- Prezzi chiari -->
    <div class="land-price" data-reveal>
      <h2>Quanto costa, <span class="grad">senza sorprese</span>.</h2>
      <div class="land-price-grid">
        <div class="land-price-card glass"><b>Essenziale</b><span class="lp-p">€490</span><span class="lp-d">onepage · contatti, mappa, WhatsApp</span></div>
        <div class="land-price-card glass lp-hot"><b>Attività</b><span class="lp-p">€790</span><span class="lp-d">fino a 6 pagine · prenotazioni, SEO locale, scheda Google</span></div>
        <div class="land-price-card glass"><b>Poi</b><span class="lp-p">€29<i>/mese</i></span><span class="lp-d">hosting, dominio, SSL e assistenza</span></div>
      </div>
      <p class="lp-note">Prima bozza gratis, nessun anticipo · prezzi IVA esclusa.</p>
    </div>

    {d.widget && (
      <p class="land-widget" data-reveal>⚡ Nella demo <b>{d.demoName}</b> trovi anche: <b>{d.widget}</b> — <a href={d.demoUrl}>provalo →</a></p>
    )}

    <!-- FAQ di settore -->
    <div class="land-faq" data-reveal>
      <h2>Domande frequenti</h2>
      <div class="faq-list">
        {faqs.map((f, i) => (
          <details class="faq-item" open={i === 0}>
            <summary>{f.q}<span class="chev">+</span></summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>

    <div class="cta-card glass" data-reveal style="margin-top:3rem; text-align:center; display:block;">
      <h2 style="font-size:clamp(1.6rem,3.5vw,2.4rem); margin-bottom:1rem;">Un sito così, <span class="grad">per la tua attività</span>.</h2>
      <p style="color:var(--muted); margin-bottom:1.6rem;">Apri la demo, poi scrivici: ti facciamo una prima bozza gratis, su misura per la tua attività.</p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href={d.demoUrl} class="btn btn-ghost">Apri la demo</a>
        <a href={`https://wa.me/393662102203?text=${encodeURIComponent('Ciao! Vorrei un sito — ' + d.h1b)}`} target="_blank" rel="noopener" class="btn btn-ghost">WhatsApp</a>
        <a href="/#contatti" class="btn btn-primary btn-magnetic">Preventivo gratis</a>
      </div>
    </div>
  </section>

  <style>
    .land-points { display:grid; grid-template-columns:repeat(3,1fr); gap:1.2rem; }
    .land-shot { display:block; max-width:680px; margin:3rem auto 0; padding:.8rem; text-decoration:none; transition:transform .3s var(--ease), box-shadow .3s; }
    .land-shot:hover { transform:translateY(-6px); box-shadow:0 30px 60px -30px rgba(124,92,255,.5); }
    .land-shot img { width:100%; height:auto; border-radius:12px; display:block; }
    .land-shot-cap { display:block; padding:.9rem .4rem .2rem; color:var(--muted); font-size:.92rem; text-align:center; }
    .land-shot-cap b { color:var(--text,#f3f3fb); font-family:'Space Grotesk Variable','Space Grotesk'; }
    .land-shot-cap i { color:var(--c2); font-style:normal; font-weight:600; }
    .land-price { max-width:860px; margin:3.5rem auto 0; text-align:center; }
    .land-price h2, .land-faq h2 { font-size:clamp(1.5rem,3.5vw,2.2rem); margin-bottom:1.4rem; }
    .land-price-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; }
    .land-price-card { padding:1.4rem 1rem; }
    .land-price-card b { display:block; font-family:'Space Grotesk Variable','Space Grotesk'; margin-bottom:.3rem; }
    .lp-p { display:block; font-family:'Space Grotesk Variable','Space Grotesk'; font-size:1.9rem; font-weight:700; background:var(--grad); -webkit-background-clip:text; background-clip:text; color:transparent; }
    .lp-p i { font-style:normal; font-size:.9rem; }
    .lp-d { color:var(--muted); font-size:.85rem; }
    .lp-hot { border-color:rgba(124,92,255,.5); }
    .lp-note { color:var(--muted); font-size:.92rem; margin-top:1rem; }
    .lp-note a { color:var(--c2); text-decoration:underline; }
    .land-widget { max-width:760px; margin:2.2rem auto 0; text-align:center; color:var(--muted); background:var(--surface); border:1px solid var(--border); border-radius:var(--radius-sm); padding:1rem 1.3rem; }
    .land-widget a { color:var(--c2); text-decoration:underline; }
    .land-faq { max-width:760px; margin:3.5rem auto 0; text-align:center; }
    .land-faq .faq-list { text-align:left; }
    .land-incluso { max-width:760px; margin:3rem auto 0; text-align:center; }
    .land-incluso h2 { font-size:clamp(1.5rem,3.5vw,2.2rem); margin-bottom:1.2rem; }
    .land-incluso ul { list-style:none; display:inline-grid; gap:.6rem; text-align:left; margin:0 0 1.2rem; padding:0; }
    .land-incluso li { color:var(--muted); }
    .land-incluso p { color:var(--muted); }
    @media (max-width:780px){ .land-points, .land-price-grid { grid-template-columns:1fr; } }
  </style>
</Layout>
