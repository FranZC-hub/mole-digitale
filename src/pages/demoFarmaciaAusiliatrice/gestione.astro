---
import Layout from './_Layout.astro';
---
<Layout title="Gestione servizi (demo)" active="">
  <!-- SCHERMATA DI ACCESSO (il pannello appare solo dopo il login) -->
  <section class="fsection" id="gLogin" style="padding-top:8rem;">
    <div class="glogin r">
      <span class="fcross glogin-ic" aria-hidden="true">+</span>
      <h1>Area <span class="fmark">riservata</span></h1>
      <p class="glogin-sub">Accesso al pannello di gestione della farmacia.</p>
      <form class="fform glogin-form" id="gLoginForm">
        <label>Nome utente<input type="text" id="gl-user" autocomplete="username" required /></label>
        <label>Password<input type="password" id="gl-pass" autocomplete="current-password" required /></label>
        <p class="glogin-err" id="glErr" hidden>⚠ Credenziali non corrette. Riprova.</p>
        <button type="submit" class="fbtn fbtn-solid fbtn-block fbtn-lg">Accedi →</button>
        <!-- ⚠ Solo per la bozza: da RIMUOVERE nella versione definitiva -->
        <button type="button" class="glogin-demo" id="glDemo">
          <b>🔑 Credenziali di prova</b>
          <span>utente: <code>ausiliatrice</code> · password: <code>farmacia2026</code></span>
          <small>tocca qui per compilare — verranno rimosse nella versione definitiva</small>
        </button>
        <p class="fform-note">Demo: nella versione reale l'accesso è protetto sul server, con utenti e permessi.</p>
      </form>
    </div>
  </section>

  <section class="fsection" id="gPanel" hidden style="padding-top:8rem;">
    <div class="fhead fhead-c r">
      <span class="fkick">Pannello riservato</span>
      <h1>Gestisci i servizi <span class="fmark">in autonomia</span></h1>
      <p>Aggiungi un servizio qui sotto e guarda comparire subito sulla pagina <a href="/demoFarmaciaAusiliatrice/servizi/" style="color:var(--cel-d);text-decoration:underline;">Servizi</a> del sito. <button type="button" id="gLogout" class="glogout">Esci dall'area riservata</button></p>
    </div>

    <div class="ggrid">
      <form class="fform r" id="gForm">
        <h3 style="font-size:1.1rem;">➕ Nuovo servizio</h3>
        <label>Nome del servizio<input type="text" id="g-nome" required placeholder="Es. Foratura del lobo" maxlength="60" /></label>
        <label>Descrizione breve<textarea id="g-desc" rows="2" placeholder="Es. Foratura sterile con sistema monouso e orecchini anallergici inclusi." maxlength="160"></textarea></label>
        <label>Scegli un'icona
          <select id="g-em"><option>🩺</option><option>💉</option><option>🧪</option><option>🩸</option><option>💊</option><option>🫀</option><option>📈</option><option>🏠</option><option>💬</option><option>🦷</option><option>👂</option><option>👶</option></select>
        </label>
        <label class="fconsent"><input type="checkbox" id="g-prenota" /> <span>Servizio <b>prenotabile</b> (mostra l'etichetta «prenotabile»)</span></label>
        <button type="submit" class="fbtn fbtn-cel fbtn-block">Pubblica sul sito →</button>
        <p class="fform-note">Demo: i dati restano solo su questo dispositivo.</p>
      </form>

      <div class="glist-wrap r">
        <h3 style="font-size:1.1rem;margin-bottom:.8rem;">I servizi che hai aggiunto</h3>
        <div class="glist" id="gList"></div>
        <a href="/demoFarmaciaAusiliatrice/servizi/" class="fbtn fbtn-solid" style="margin-top:1rem;">Guarda come appaiono sul sito →</a>
      </div>
    </div>
  </section>

  <style>
    /* login */
    .glogin{max-width:420px;margin:2rem auto 0;text-align:center}
    .glogin-ic{width:56px;height:56px;font-size:2rem;border-radius:16px;margin:0 auto 1rem;display:grid;place-items:center;background:rgba(14,122,58,.09);color:var(--blu);font-weight:800}
    .glogin h1{font-size:clamp(1.9rem,4.5vw,2.6rem)}
    .glogin-sub{color:var(--muted);margin:.5rem 0 1.4rem}
    .glogin-form{text-align:left}
    .glogin-err{color:#c04545;font-weight:700;font-size:.9rem;text-align:center}
    .glogin-demo{display:grid;gap:.2rem;text-align:center;background:var(--bg2);border:1px dashed var(--cel);border-radius:12px;padding:.9rem 1rem;cursor:pointer;font-family:inherit;transition:border-color .2s,background .2s}
    .glogin-demo:hover{border-color:var(--blu);background:#ddf3e2}
    .glogin-demo b{font-size:.9rem}
    .glogin-demo span{font-size:.92rem;color:var(--ink)}
    .glogin-demo code{background:#fff;border:1px solid var(--line);border-radius:6px;padding:.1rem .45rem;font-weight:700}
    .glogin-demo small{color:var(--muted);font-size:.74rem}
    .glogout{background:none;border:0;color:var(--cel-d);font-size:.9rem;font-weight:700;text-decoration:underline;cursor:pointer;font-family:inherit}
    .ggrid{display:grid;grid-template-columns:1fr 1.1fr;gap:1.6rem;align-items:start;max-width:980px;margin:0 auto}
    .ggrid>*{min-width:0}
    .glist{display:grid;gap:.6rem}
    /* :global — la lista è iniettata via JS e non riceve lo scope Astro */
    :global(.gitem){display:flex;align-items:center;gap:.8rem;background:var(--card);border:1px solid var(--line);border-radius:13px;padding:.8rem 1rem}
    :global(.gitem .em){font-size:1.5rem;flex:none}
    :global(.gitem .tx){flex:1;min-width:0}
    :global(.gitem b){display:block;font-size:.98rem}
    :global(.gitem .tx span){font-size:.8rem;color:var(--muted);display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    :global(.gitem button){background:none;border:1px solid var(--line);border-radius:9px;width:34px;height:34px;cursor:pointer;color:#c04545;font-size:1rem;flex:none}
    :global(.gitem button:hover){border-color:#c04545}
    :global(.gempty){color:var(--muted);background:var(--bg2);border:1px dashed var(--line);border-radius:13px;padding:1.2rem;text-align:center;font-size:.94rem}
    @media (max-width:760px){.ggrid{grid-template-columns:1fr}}
  </style>

  <script>
    import { readServices, writeServices, esc } from './_shared.js';
    // ---- Accesso demo (nella versione reale: autenticazione lato server) ----
    const GL_USER = 'ausiliatrice', GL_PASS = 'farmacia2026';
    const loginSec = document.getElementById('gLogin'), panelSec = document.getElementById('gPanel');
    const gate = () => {
      const ok = sessionStorage.getItem('aus-auth') === 'ok';
      loginSec.hidden = ok; panelSec.hidden = !ok;
    };
    document.getElementById('gLoginForm').addEventListener('submit', (e) => {
      e.preventDefault();
      const u = document.getElementById('gl-user').value.trim().toLowerCase();
      const p = document.getElementById('gl-pass').value;
      if (u === GL_USER && p === GL_PASS) { sessionStorage.setItem('aus-auth', 'ok'); document.getElementById('glErr').hidden = true; gate(); }
      else { document.getElementById('glErr').hidden = false; }
    });
    document.getElementById('gLogout').addEventListener('click', () => { sessionStorage.removeItem('aus-auth'); gate(); });
    // riquadro credenziali di prova (da rimuovere in produzione): un tocco e compila
    document.getElementById('glDemo').addEventListener('click', () => {
      document.getElementById('gl-user').value = GL_USER;
      document.getElementById('gl-pass').value = GL_PASS;
      document.getElementById('gl-pass').focus();
    });
    gate();
    const list = document.getElementById('gList');
    const render = () => {
      const items = readServices();
      list.innerHTML = items.length
        ? items.map((s, i) => `<div class="gitem"><span class="em">${esc(s.em)}</span><div class="tx"><b>${esc(s.nome)}</b><span>${esc(s.desc || '')}${s.prenotabile ? ' · prenotabile' : ''}</span></div><button type="button" data-i="${i}" aria-label="Elimina ${esc(s.nome)}">✕</button></div>`).join('')
        : '<div class="gempty">Ancora nessun servizio. Aggiungine uno dal modulo: apparirà qui e sulla pagina Servizi.</div>';
      list.querySelectorAll('button[data-i]').forEach((b) => b.addEventListener('click', () => {
        const arr = readServices(); arr.splice(+b.dataset.i, 1); writeServices(arr); render();
      }));
    };
    document.getElementById('gForm').addEventListener('submit', (e) => {
      e.preventDefault();
      const nome = document.getElementById('g-nome').value.trim();
      const desc = document.getElementById('g-desc').value.trim();
      if (!nome) return;
      writeServices([{ id: 'u' + Date.now(), nome, desc, em: document.getElementById('g-em').value, prenotabile: document.getElementById('g-prenota').checked }, ...readServices()]);
      e.target.reset(); render();
    });
    render();
  </script>
</Layout>
