---
import Layout from './_Layout.astro';
import { BASE_SERVICES } from './_shared.js';
// Fonte unica: i servizi in tendina sono quelli realmente PRENOTABILI (stessi nomi di /servizi/),
// così cliccare "Prenota" su una card non crea doppioni. I servizi prenotabili aggiunti dal
// titolare nel gestionale vengono aggiunti via JS.
const bookable = BASE_SERVICES.filter((s) => s.prenotabile);
---
<Layout title="Prenotazioni" active="" desc="Prenota un servizio alla Farmacia dell'Ausiliatrice a Torino: Holter, ECG, tamponi e autoanalisi. Scegli giorno e fascia oraria, confermiamo su WhatsApp.">
  <section class="fsection" style="padding-top:8rem;">
    <div class="fhead fhead-c r"><span class="fkick">Salta la fila</span><h1>Prenota un <span class="fmark">servizio</span></h1><p>Scegli servizio e giorno preferito: ti confermiamo l'appuntamento su WhatsApp o per telefono.</p></div>

    <div class="prgrid">
      <form class="fform r" id="prForm">
        <label>Servizio
          <select id="pr-serv">
            {bookable.map((s) => <option>{s.nome}</option>)}
          </select>
        </label>
        <div class="prrow">
          <label>Giorno preferito<input type="date" id="pr-data" required /></label>
          <label>Fascia oraria
            <select id="pr-ora"><option>Mattina</option><option>Pomeriggio</option></select>
          </label>
        </div>
        <label>Il tuo nome<input type="text" id="pr-nome" required autocomplete="name" /></label>
        <label>Telefono<input type="tel" id="pr-tel" required autocomplete="tel" /></label>
        <label class="fconsent"><input type="checkbox" id="pr-privacy" required /><span>Ho letto l'<a href="/demoFarmaciaAusiliatrice/privacy/" target="_blank" rel="noopener">informativa privacy</a> e acconsento al trattamento dei dati per gestire la richiesta.</span></label>
        <button type="submit" class="fbtn fbtn-cel fbtn-lg fbtn-block">Richiedi la prenotazione →</button>
        <p class="fform-ok" id="prOk" role="status" aria-live="polite"></p>
        <p class="fform-note">Bozza dimostrativa: nella versione reale la richiesta arriva subito alla farmacia (email + WhatsApp).</p>
      </form>

      <div class="prside">
        <div class="fcard r"><span class="fic" aria-hidden="true">⏱</span><h3>Quanto ci vuole?</h3><p>ECG e autoanalisi: pochi minuti, referto immediato. Holter: montaggio in farmacia, referto entro 5 giorni (24h in urgenza).</p></div>
        <div class="fcard r"><span class="fic" aria-hidden="true">💬</span><h3>Preferisci WhatsApp?</h3><p>Scrivici direttamente: <a href="https://wa.me/393388762564?text=Ciao!%20Vorrei%20prenotare%20un%20servizio" target="_blank" rel="noopener" style="color:var(--cel-d);font-weight:700;">prenota in chat →</a></p></div>
        <div class="fcard r"><span class="fic" aria-hidden="true">🏠</span><h3>Consegna a domicilio</h3><p>Ordina i tuoi farmaci entro le 12: consegniamo in giornata nel quartiere.</p></div>
      </div>
    </div>
  </section>
  <style>
    .prgrid{display:grid;grid-template-columns:1.1fr 1fr;gap:1.6rem;align-items:start;max-width:1000px;margin:0 auto}
    .prgrid>*{min-width:0}
    .prrow{display:grid;grid-template-columns:1fr 1fr;gap:.8rem}
    .prrow>*{min-width:0}
    .prside{display:grid;gap:1rem}
    /* evidenziazione breve quando il servizio arriva pre-selezionato da /servizi/ */
    #pr-serv.pr-flash{animation:prflash 1.5s ease}
    @keyframes prflash{20%,60%{box-shadow:0 0 0 3px rgba(23,166,63,.4);border-color:var(--cel)}}
    @media (prefers-reduced-motion:reduce){#pr-serv.pr-flash{animation:none}}
    @media (max-width:760px){.prgrid{grid-template-columns:1fr}.prrow{grid-template-columns:1fr}}
  </style>
  <script>
    import { readServices } from './_shared.js';
    const dEl = document.getElementById('pr-data');
    const oraEl = document.getElementById('pr-ora');
    const selServ = document.getElementById('pr-serv');

    // La tendina include anche i servizi PRENOTABILI aggiunti dal titolare nel gestionale
    // (senza questo, i servizi in localStorage non comparirebbero nella prenotazione generica).
    (() => {
      const esistenti = new Set([...selServ.options].map((o) => o.text.trim().toLowerCase()));
      readServices()
        .filter((s) => s && s.prenotabile && s.nome && !esistenti.has(s.nome.trim().toLowerCase()))
        .forEach((s) => selServ.add(new Option(s.nome, s.nome)));
    })();

    // Niente giorni passati: minimo = oggi
    const iso = (dt) => dt.toISOString().split('T')[0];
    dEl.min = iso(new Date());
    // La farmacia è chiusa la domenica; il sabato solo mattina → adatto i campi al giorno scelto
    const syncGiorno = () => {
      if (!dEl.value) return;
      const g = new Date(dEl.value + 'T00:00').getDay(); // 0=domenica, 6=sabato
      if (g === 0) { dEl.setCustomValidity('La farmacia è chiusa la domenica: scegli un altro giorno.'); dEl.reportValidity(); return; }
      dEl.setCustomValidity('');
      const pom = oraEl.querySelector('option[value="Pomeriggio"], option:nth-child(2)');
      if (g === 6) { oraEl.value = 'Mattina'; if (pom) pom.disabled = true; } // sabato: solo mattina
      else if (pom) pom.disabled = false;
    };
    dEl.addEventListener('change', syncGiorno);

    document.getElementById('prForm').addEventListener('submit', (e) => {
      e.preventDefault();
      const s = document.getElementById('pr-serv').value;
      const d = document.getElementById('pr-data').value;
      const ora = oraEl.value;
      const ok = document.getElementById('prOk');
      ok.innerHTML = `✅ Richiesta registrata: <b>${s}</b> per il <b>${d ? d.split('-').reverse().join('/') : 'giorno scelto'}</b> (${ora}). Ti confermiamo a breve! <i>(demo: nessun dato inviato)</i>`;
      ok.style.display = 'block';
      e.target.reset();
    });

    // Servizio arrivato da /servizi/ (?servizio=Nome): lo preseleziono (aggiungendolo
    // alla tendina se non c'è) e porto l'attenzione al modulo. Così cliccare "Prenota"
    // su una card avvia subito la prenotazione di QUEL servizio.
    const wanted = new URLSearchParams(location.search).get('servizio');
    if (wanted) {
      const sel = document.getElementById('pr-serv');
      const norm = (t) => t.trim().toLowerCase();
      const opts = [...sel.options];
      let match = opts.find((o) => norm(o.text) === norm(wanted))
        || opts.find((o) => norm(o.text).includes(norm(wanted)) || norm(wanted).includes(norm(o.text)));
      if (!match) { match = new Option(wanted, wanted); sel.add(match, 0); }
      sel.value = match.value;
      document.getElementById('prForm').scrollIntoView({ behavior: 'smooth', block: 'center' });
      sel.classList.add('pr-flash');
      setTimeout(() => sel.classList.remove('pr-flash'), 1600);
    }
  </script>
</Layout>
