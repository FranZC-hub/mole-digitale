---
// BOZZA CLIENTE — Farmacia dell'Ausiliatrice s.r.l. (Corso Principe Oddone 28, Torino)
// Anteprima non ufficiale realizzata da Mole Digitale su dati pubblici del sito attuale.
// ORARI: quelli ufficiali della farmacia (Lun–Ven 8.45–12.45 / 15.15–19.15, Sab 8.45–12.45).
import '@fontsource-variable/manrope';
import '@fontsource-variable/inter';

interface Props { title: string; desc?: string; active?: string }
const { title, desc = 'Farmacia dell\'Ausiliatrice — Corso Principe Oddone 28, Torino. Il nostro impegno è la cura della persona.', active = '' } = Astro.props;

const NAV = [
  ['/', 'Home'], ['chi-siamo/', 'Chi siamo'], ['servizi/', 'Servizi'], ['prodotti/', 'Prodotti'],
  ['dove-siamo/', 'Dove siamo'], ['contatti/', 'Contatti'],
];
const BASE = '/demoFarmaciaAusiliatrice/';
const WA = 'https://wa.me/393388762564';

// Dati strutturati per la SEO locale ("farmacia vicino a me"): si attivano quando si toglie il noindex.
// ⚠️ Coordinate geo approssimative: da confermare col cliente prima del go-live.
const pharmacySchema = {
  '@context': 'https://schema.org',
  '@type': 'Pharmacy',
  name: 'Farmacia dell\'Ausiliatrice',
  image: 'https://www.moledigitale.it/img/demo-farmacia/hero.webp',
  address: { '@type': 'PostalAddress', streetAddress: 'Corso Principe Oddone 28', addressLocality: 'Torino', postalCode: '10152', addressRegion: 'TO', addressCountry: 'IT' },
  geo: { '@type': 'GeoCoordinates', latitude: 45.0812, longitude: 7.6739 },
  telephone: '+390114365466',
  email: 'info@farmaciaausiliatrice.it',
  url: 'https://www.farmaciaausiliatrice.it/',
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'], opens: '08:45', closes: '12:45' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'], opens: '15:15', closes: '19:15' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Saturday', opens: '08:45', closes: '12:45' },
  ],
};
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title} — Farmacia dell'Ausiliatrice · Torino</title>
  <meta name="description" content={desc} />
  <meta name="theme-color" content="#0e7a3a" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><rect width='24' height='24' rx='6' fill='%230e7a3a'/><path d='M12 6v12M6 12h12' stroke='%23fff' stroke-width='3.2' stroke-linecap='round'/></svg>" />
  <!-- Anteprima quando il link viene condiviso (WhatsApp ecc.) -->
  <meta property="og:title" content={title + " — Farmacia dell'Ausiliatrice · Torino"} />
  <meta property="og:description" content={desc} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="it_IT" />
  <meta property="og:image" content="https://www.moledigitale.it/img/demo-farmacia/hero.webp" />
  <meta name="twitter:card" content="summary_large_image" />
  <script type="application/ld+json" set:html={JSON.stringify(pharmacySchema)} />
</head>
<body>
  <a class="fskip" href="#main">Salta al contenuto</a>
  <a class="demo-flag" href="/dypa">✦ Anteprima realizzata da <b>Mole Digitale</b><span class="flag-more"> — bozza di proposta per Farmacia dell'Ausiliatrice</span></a>

  <header class="fnav" id="fnav">
    <a href={BASE} class="fbrand"><svg class="flogo" viewBox="0 0 48 48" aria-hidden="true"><path d="M18 4 H30 V18 H44 V30 H30 V44 H18 V30 H4 V18 H18 Z" fill="none" stroke="var(--cel)" stroke-width="4.2" stroke-linejoin="round" stroke-linecap="round"/><text x="15.5" y="24" font-size="15" font-weight="800" fill="var(--rosso)" text-anchor="middle" dominant-baseline="middle" font-family="Georgia,'Times New Roman',serif">F</text><text x="32.5" y="40" font-size="15" font-weight="800" fill="var(--rosso)" text-anchor="middle" dominant-baseline="middle" font-family="Georgia,'Times New Roman',serif">A</text></svg><span><b>Farmacia</b> dell'Ausiliatrice</span></a>
    <nav class="flinks" id="flinks">
      {NAV.map(([href, label]) => (
        <a href={BASE + (href === '/' ? '' : href)} class={active === label ? 'on' : undefined} aria-current={active === label ? 'page' : undefined}>{label}</a>
      ))}
    </nav>
    <button class="fnav-toggle" id="fToggle" aria-label="Apri il menu" aria-expanded="false" aria-controls="flinks"><svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg></button>
    <a href={BASE + 'gestione/'} class="fnav-lock" aria-label="Area riservata — accedi" title="Area riservata">
      <svg viewBox="0 0 24 24" width="19" height="19" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="10.5" width="14" height="9.5" rx="2"/><path d="M8 10.5V7.5a4 4 0 0 1 8 0v3"/><circle cx="12" cy="15.2" r="1.3" fill="currentColor"/></svg>
      <span>Accedi</span>
    </a>
    <a href={BASE + 'prenotazioni/'} class="fbtn fbtn-solid fnav-cta">Prenota</a>
  </header>

  <main id="main" tabindex="-1">
    <slot />
  </main>

  <footer class="ffoot">
    <div class="ffoot-in">
      <div>
        <p class="ffoot-brand"><svg class="flogo flogo-foot" viewBox="0 0 48 48" aria-hidden="true"><path d="M18 4 H30 V18 H44 V30 H30 V44 H18 V30 H4 V18 H18 Z" fill="none" stroke="var(--cel)" stroke-width="4.2" stroke-linejoin="round" stroke-linecap="round"/><text x="15.5" y="24" font-size="15" font-weight="800" fill="var(--rosso)" text-anchor="middle" dominant-baseline="middle" font-family="Georgia,'Times New Roman',serif">F</text><text x="32.5" y="40" font-size="15" font-weight="800" fill="var(--rosso)" text-anchor="middle" dominant-baseline="middle" font-family="Georgia,'Times New Roman',serif">A</text></svg> <b>Farmacia dell'Ausiliatrice s.r.l.</b></p>
        <p>Corso Principe Oddone, 28 — 10152 Torino</p>
        <p>P.IVA 08379260014</p>
      </div>
      <div>
        <p><b>Contatti</b></p>
        <p><a href="tel:+390114365466">011 436 5466</a></p>
        <p><a href="mailto:info@farmaciaausiliatrice.it">info@farmaciaausiliatrice.it</a></p>
        <p><a href={WA} target="_blank" rel="noopener">WhatsApp 338 876 2564</a></p>
      </div>
      <div>
        <p><b>Seguici</b></p>
        <p><a href="https://www.facebook.com/FarmaciaAusiliatrice" target="_blank" rel="noopener">Facebook</a></p>
        <p><a href="https://www.instagram.com/farmaciaausiliatrice" target="_blank" rel="noopener">Instagram</a></p>
        <p style="margin-top:.6rem"><a href={BASE + 'privacy/'}>Privacy &amp; cookie</a></p>
      </div>
    </div>
    <p class="ffoot-note">Bozza dimostrativa · <a href="/">Mole Digitale</a></p>
  </footer>

  <a class="wa-fab" href={WA} target="_blank" rel="noopener" aria-label="Scrivici su WhatsApp"><svg viewBox="0 0 24 24" width="26" height="26" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.8 4.9-1.3A10 10 0 1 0 12 2zm0 18a8 8 0 0 1-4.1-1.1l-.3-.2-2.9.8.8-2.8-.2-.3A8 8 0 1 1 12 20zm4.5-6c-.2-.1-1.4-.7-1.6-.8s-.4-.1-.5.1-.6.8-.8 1-.3.2-.5.1a6.5 6.5 0 0 1-3.2-2.8c-.2-.4.2-.4.6-1.2.1-.1 0-.3 0-.4l-.7-1.7c-.2-.5-.4-.4-.5-.4h-.5a1 1 0 0 0-.7.3 3 3 0 0 0-.9 2.2 5.2 5.2 0 0 0 1.1 2.7 11.9 11.9 0 0 0 4.6 4c2.3 1 2.3.7 2.7.6a2.5 2.5 0 0 0 1.6-1.1 2 2 0 0 0 .1-1.1z"/></svg></a>

  <style is:global>
    :root{
      --blu:#0e7a3a;--blu-d:#0a5b2b;--cel:#17a63f;--cel-d:#0c7d34;--rosso:#d3372f;
      --bg:#f6faf7;--bg2:#e9f4ec;--card:#ffffff;--ink:#16243a;--muted:#5b6b80;
      --line:rgba(22,36,58,.12);--soft:0 18px 42px -22px rgba(12,70,35,.4);
      --disp:'Manrope Variable',system-ui,sans-serif;--sans:'Inter Variable',system-ui,sans-serif;--e:cubic-bezier(.2,.7,.2,1);
    }
    *{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth;scroll-padding-top:96px;overflow-x:clip}
    @media (prefers-reduced-motion:reduce){html{scroll-behavior:auto}}
    body{background:var(--bg);color:var(--ink);font-family:var(--sans);line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
    img{display:block;max-width:100%}a{color:inherit;text-decoration:none}
    a:focus-visible,button:focus-visible,.fbtn:focus-visible,input:focus-visible,select:focus-visible,textarea:focus-visible,[tabindex]:focus-visible{outline:2px solid var(--cel-d);outline-offset:2px;border-radius:4px}
    h1,h2,h3{font-family:var(--disp);font-weight:800;line-height:1.1;letter-spacing:-.015em}
    .fmark{color:var(--cel)}

    .demo-flag{position:fixed;top:0;left:0;right:0;z-index:300;text-align:center;font-size:.78rem;padding:.4rem .8rem;background:var(--blu-d);color:#d6ecdc;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .demo-flag b{color:#fff}
    @media (max-width:640px){.flag-more{display:none}} /* su mobile resta su UNA riga: niente sovrapposizioni con la nav */

    .fnav{position:fixed;top:29px;left:0;right:0;z-index:200;display:flex;align-items:center;gap:1.1rem;padding:.8rem clamp(1rem,4vw,2.6rem);background:rgba(246,250,247,.94);backdrop-filter:blur(12px);border-bottom:1px solid var(--line)}
    .fbrand{font-family:var(--disp);font-size:1.08rem;display:inline-flex;align-items:center;gap:.55rem;font-weight:600}
    .fbrand b{font-weight:800}
    .fskip{position:fixed;top:-60px;left:.6rem;z-index:400;background:var(--blu);color:#fff;padding:.6rem 1rem;border-radius:0 0 10px 10px;font-weight:700;font-size:.9rem;transition:top .2s}
    .fskip:focus{top:0;outline:2px solid #fff;outline-offset:2px}
    .flogo{width:38px;height:38px;flex:none}
    .flogo-foot{width:40px;height:40px;background:#fff;border-radius:10px;padding:3px}
    .flinks{display:flex;gap:1.25rem;margin-left:auto}
    .flinks a{font-size:.92rem;font-weight:600;color:var(--muted);position:relative;transition:color .2s}
    .flinks a::after{content:'';position:absolute;left:0;bottom:-6px;height:2px;width:0;background:var(--cel);transition:width .3s var(--e)}
    .flinks a:hover{color:var(--ink)}.flinks a:hover::after,.flinks a.on::after{width:100%}
    .flinks a.on{color:var(--ink)}
    .fnav-toggle{display:none;background:none;border:0;color:var(--ink);cursor:pointer;width:44px;height:44px;border-radius:12px;place-items:center;margin-left:auto}
    .fnav-lock{display:inline-flex;align-items:center;gap:.4rem;font-size:.86rem;font-weight:700;color:var(--muted);border:1px solid var(--line);border-radius:11px;padding:.55rem .85rem;transition:color .2s,border-color .2s}
    .fnav-lock:hover{color:var(--blu);border-color:var(--blu)}

    .fbtn{display:inline-flex;align-items:center;justify-content:center;gap:.45rem;font-weight:700;font-size:.92rem;padding:.72rem 1.35rem;border-radius:12px;cursor:pointer;border:1px solid transparent;transition:transform .2s var(--e),background .2s;white-space:nowrap;font-family:var(--sans)}
    .fbtn-solid{background:var(--blu);color:#fff;box-shadow:0 12px 26px -12px var(--blu)}.fbtn-solid:hover{background:var(--blu-d);transform:translateY(-2px)}
    .fbtn-cel{background:var(--cel);color:#fff;box-shadow:0 12px 26px -12px var(--cel)}.fbtn-cel:hover{background:var(--cel-d);transform:translateY(-2px)}
    .fbtn-ghost{border-color:var(--line);color:var(--ink);background:var(--card)}.fbtn-ghost:hover{border-color:var(--cel);color:var(--cel-d);transform:translateY(-2px)}
    .fbtn-lg{padding:.95rem 1.7rem;font-size:1rem}.fbtn-block{width:100%}

    .fsection{max-width:1150px;margin:0 auto;padding:clamp(3rem,7vw,5.5rem) clamp(1.2rem,5vw,3rem)}
    .fhead{max-width:660px;margin-bottom:clamp(1.8rem,4vw,2.8rem)}
    .fhead-c{margin-left:auto;margin-right:auto;text-align:center}
    .fkick{display:inline-block;font-weight:700;font-size:.76rem;letter-spacing:.14em;text-transform:uppercase;color:var(--cel-d);background:rgba(23,166,63,.12);padding:.35rem .8rem;border-radius:999px;margin-bottom:.9rem}
    .fhead h1{font-size:clamp(2.2rem,5.5vw,3.6rem)}
    .fhead h2{font-size:clamp(1.8rem,4.4vw,2.8rem)}
    .fhead p{color:var(--muted);margin-top:.8rem;font-size:1.06rem}

    .fgrid3{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem}
    .fgrid3>*{min-width:0}
    .fcard{background:var(--card);border:1px solid var(--line);border-radius:18px;padding:1.6rem;transition:transform .25s var(--e),box-shadow .25s}
    .fcard:hover{transform:translateY(-4px);box-shadow:var(--soft)}
    .fcard h3{font-size:1.18rem;margin-bottom:.4rem}
    .fcard p{color:var(--muted);font-size:.94rem}
    .fic{display:grid;place-items:center;width:48px;height:48px;border-radius:13px;background:rgba(14,122,58,.09);color:var(--blu);margin-bottom:.9rem;font-size:1.4rem}

    .ffoot{background:var(--blu-d);color:#d0e7d8;margin-top:2rem}
    .ffoot-in{max-width:1150px;margin:0 auto;padding:2.6rem clamp(1.2rem,5vw,3rem) 1.4rem;display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:1.6rem;font-size:.92rem}
    .ffoot-in>div>p{margin-bottom:.35rem}
    .ffoot-in b{color:#fff}
    .ffoot-in a:hover{color:#fff;text-decoration:underline}
    .ffoot-brand{display:flex;align-items:center;gap:.5rem;font-size:1.02rem;margin-bottom:.6rem !important}
    .ffoot-note{max-width:1150px;margin:0 auto;padding:1rem clamp(1.2rem,5vw,3rem) 1.6rem;border-top:1px solid rgba(255,255,255,.14);font-size:.8rem;color:#8fb79d}
    .ffoot-note a{color:#d0e7d8;text-decoration:underline}

    .wa-fab{position:fixed;right:18px;bottom:18px;z-index:160;width:52px;height:52px;border-radius:50%;display:grid;place-items:center;background:#25d366;color:#fff;box-shadow:0 14px 30px -10px rgba(37,211,102,.7);transition:transform .2s var(--e)}
    .wa-fab:hover{transform:scale(1.08)}

    /* card prodotto (usate in home e /prodotti, iniettate via JS -> stili nel layout globale) */
    .pcard{position:relative;background:var(--card);border:1px solid var(--line);border-radius:16px;padding:1.3rem;display:flex;flex-direction:column;gap:.3rem;transition:transform .25s var(--e),box-shadow .25s}
    .pcard:hover{transform:translateY(-4px);box-shadow:var(--soft)}
    .pcard.mine{border-color:var(--cel)}
    .pmine{align-self:flex-start;font-size:.66rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;background:rgba(23,166,63,.14);color:var(--cel-d);padding:.22rem .55rem;border-radius:999px;margin-bottom:.3rem}
    .pem{font-size:2rem;line-height:1}
    .pimg{width:100%;aspect-ratio:4/3;object-fit:cover;border-radius:10px;background:var(--bg2)}
    .pcat{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--muted)}
    .pcard h3{font-size:1.02rem;font-weight:700;flex:1}
    .pfoot{display:flex;align-items:center;justify-content:space-between;gap:.6rem;margin-top:.5rem}
    .pfoot b{color:var(--blu);font-size:1.05rem}
    .pfoot a{font-size:.82rem;font-weight:700;color:var(--cel-d)}

    .r{opacity:0;transform:translateY(16px);transition:opacity .6s var(--e),transform .6s var(--e)}
    .r.in{opacity:1;transform:none}
    @media (prefers-reduced-motion:reduce){.r{opacity:1;transform:none;transition:none}}

    /* form condivisi */
    .fform{background:var(--card);border:1px solid var(--line);border-radius:18px;padding:clamp(1.4rem,3vw,2rem);display:flex;flex-direction:column;gap:.9rem;box-shadow:var(--soft)}
    .fform label{display:flex;flex-direction:column;gap:.35rem;font-size:.85rem;font-weight:700}
    .fform input,.fform select,.fform textarea{min-width:0;width:100%;padding:.8rem .9rem;border:1px solid var(--line);border-radius:11px;font-family:var(--sans);font-size:1rem;background:var(--bg);color:var(--ink)}
    .fform input:focus,.fform select:focus,.fform textarea:focus{outline:2px solid var(--cel);border-color:transparent}
    .fform-note{font-size:.78rem;color:var(--muted);text-align:center;font-weight:400}
    .fform-ok{display:none;text-align:center;background:rgba(23,166,63,.1);border:1px solid var(--cel);border-radius:12px;padding:1rem;color:var(--ink);font-weight:600}
    .fconsent{flex-direction:row;align-items:flex-start;gap:.55rem;font-weight:400;font-size:.82rem;color:var(--muted)}
    .fconsent input{width:auto;min-width:0;margin-top:.15rem;accent-color:var(--blu)}
    .fconsent a{color:var(--cel-d);font-weight:700;text-decoration:underline}

    @media (max-width:920px){
      .flinks{display:none}
      .fnav.open .flinks{display:flex;position:absolute;top:100%;left:0;right:0;flex-direction:column;gap:1rem;background:rgba(246,250,247,.98);backdrop-filter:blur(12px);border-bottom:1px solid var(--line);padding:1.2rem clamp(1.2rem,5vw,3rem) 1.4rem}
      .fnav{gap:.55rem}
      .fbrand{font-size:.98rem;min-width:0}
      .flogo{width:32px;height:32px}
      .fnav-toggle{display:grid}
      .fnav-cta{padding:.5rem .9rem;font-size:.82rem}
      .fnav-lock{padding:.5rem .6rem}
      .fnav-lock span{display:none} /* su mobile resta solo il lucchetto */
      .fgrid3{grid-template-columns:1fr}
      .ffoot-in{grid-template-columns:1fr}
    }
    /* Telefoni molto stretti: comprimo brand e CTA così la barra resta su una riga */
    @media (max-width:400px){
      .fbrand{font-size:.86rem;gap:.4rem}
      .flogo{width:28px;height:28px}
      .fnav-cta{padding:.45rem .7rem;font-size:.78rem}
      .fnav{gap:.4rem;padding-left:.7rem;padding-right:.7rem}
    }
  </style>

  <script>
    const fnav = document.getElementById('fnav');
    const ft = document.getElementById('fToggle');
    ft.addEventListener('click', () => { const o = fnav.classList.toggle('open'); ft.setAttribute('aria-expanded', String(o)); });
    document.querySelectorAll('.flinks a').forEach((a) => a.addEventListener('click', () => fnav.classList.remove('open')));
    document.addEventListener('click', (e) => { if (fnav.classList.contains('open') && !fnav.contains(e.target)) { fnav.classList.remove('open'); ft.setAttribute('aria-expanded', 'false'); } });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { fnav.classList.remove('open'); ft.setAttribute('aria-expanded', 'false'); } });
    const io = new IntersectionObserver((es) => es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } }), { threshold: 0.1 });
    document.querySelectorAll('.r').forEach((el) => io.observe(el));
    // statistiche first-party (misura le visite del cliente alla bozza)
    try { if (!navigator.webdriver && !['localhost', '127.0.0.1'].includes(location.hostname)) {
      fetch('/stats.php?p=' + encodeURIComponent(location.pathname) + '&r=', { keepalive: true }).catch(() => {});
    } } catch (_) {}
  </script>
</body>
</html>
