---
import Layout from './_Layout.astro';
import { BASE_SERVICES } from './_shared.js';
const PREN = '/demoFarmaciaAusiliatrice/prenotazioni/';
const bookHref = (nome) => PREN + '?servizio=' + encodeURIComponent(nome);
// I servizi base sono resi lato server (visibili anche senza JavaScript). Quelli aggiunti
// dal titolare nel gestionale (localStorage) vengono iniettati in cima via JS.
---
<Layout title="Servizi" active="Servizi" desc="I servizi della Farmacia dell'Ausiliatrice a Torino: Holter cardiaco, ECG con telerefertazione, tamponi rapidi, autoanalisi, riconfezionamento farmaci e consegna a domicilio.">
  <section class="fsection" style="padding-top:8rem;">
    <div class="fhead fhead-c r"><span class="fkick">Cosa facciamo</span><h1>I nostri <span class="fmark">servizi</span></h1><p>Telemedicina, autoanalisi e attenzioni quotidiane: la farmacia come presidio di salute del quartiere.</p></div>

    <div class="ssearch r">
      <span class="ssearch-ic" aria-hidden="true">🔎</span>
      <input type="search" id="sSearch" placeholder="Cerca un servizio per nome…" aria-label="Cerca un servizio per nome" autocomplete="off" />
    </div>

    <div class="sgrid" id="sGrid">
      {BASE_SERVICES.map((s) => (
        <article class="fcard r" data-nome={s.nome} data-em={s.em} data-desc={s.desc ?? ''} data-nuovo={s.nuovo ? '1' : ''} data-prenotabile={s.prenotabile ? '1' : ''}>
          <span class="fic" aria-hidden="true">{s.em}</span>
          <h3><button type="button" class="sopen">{s.nome}</button> {s.nuovo && <span class="sbadge sbadge-new">novità</span>} {s.prenotabile && <span class="sbadge">prenotabile</span>}</h3>
          {s.desc && <p>{s.desc}</p>}
          {s.prenotabile && <a class="sbook" href={bookHref(s.nome)}>Prenota →</a>}
        </article>
      ))}
    </div>
    <p class="snores r" id="sNoRes" hidden>Nessun servizio trovato con questo nome. Prova con un'altra parola.</p>

    <div class="scta r">
      <a href={PREN} class="fbtn fbtn-solid fbtn-lg">Prenota un servizio →</a>
      <a href="https://wa.me/393388762564" target="_blank" rel="noopener" class="fbtn fbtn-ghost fbtn-lg">Chiedi su WhatsApp</a>
    </div>

    <div class="md-hint r">
      💡 <b>Per il titolare:</b> questa pagina si aggiorna da sola con i servizi che inserisci dal
      <a href="/demoFarmaciaAusiliatrice/gestione/">pannello di gestione (demo) →</a>
    </div>
  </section>

  <!-- MODALE DETTAGLIO SERVIZIO (aperto al click sulla card, come nelle Offerte) -->
  <div class="omodal" id="sDetail" hidden role="dialog" aria-modal="true" aria-labelledby="sdNome">
    <div class="omodal-back" data-close></div>
    <div class="omodal-card">
      <button type="button" class="omodal-x" data-close aria-label="Chiudi">✕</button>
      <span class="pem omodal-em" id="sdEm" aria-hidden="true"></span>
      <div id="sdBadges"></div>
      <h2 id="sdNome"></h2>
      <p class="omodal-desc" id="sdDesc"></p>
      <a class="fbtn fbtn-cel fbtn-block fbtn-lg" id="sdBook">Prenota questo servizio →</a>
    </div>
  </div>

  <style>
    .ssearch{max-width:460px;margin:0 auto 1.8rem;position:relative}
    .ssearch-ic{position:absolute;left:1rem;top:50%;transform:translateY(-50%);opacity:.6;pointer-events:none}
    .ssearch input{width:100%;padding:.85rem 1rem .85rem 2.6rem;border:1px solid var(--line);border-radius:999px;font-family:var(--sans);font-size:1rem;background:var(--card);color:var(--ink)}
    .ssearch input:focus{outline:2px solid var(--cel);border-color:transparent}
    .sgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem}
    .sgrid>*{min-width:0}
    /* card come colonna cliccabile; il bottone "Prenota" si allinea in basso (anche sulle card iniettate) */
    :global(#sGrid .fcard){display:flex;flex-direction:column;cursor:pointer}
    :global(#sGrid .fcard[hidden]){display:none}
    :global(#sGrid .fcard p){margin-bottom:1rem}
    /* nome = <button> accessibile ma con l'aspetto del titolo */
    :global(.sopen){display:inline;text-align:left;background:none;border:0;padding:0;margin:0;font:inherit;color:inherit;cursor:pointer}
    :global(.sopen:hover){color:var(--blu);text-decoration:underline}
    /* :global — badge/bottoni servono anche alle card iniettate via JS (senza scope Astro) */
    :global(.sbadge){display:inline-block;font-size:.62rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;background:rgba(23,166,63,.14);color:var(--cel-d);padding:.2rem .5rem;border-radius:999px;vertical-align:middle;margin-left:.3rem}
    :global(.sbadge-new){background:var(--rosso);color:#fff}
    :global(.fcard-mine){border-color:var(--cel)}
    :global(.sbook){align-self:flex-start;margin-top:auto;display:inline-flex;align-items:center;gap:.35rem;font-weight:700;font-size:.9rem;color:var(--cel-d);background:rgba(23,166,63,.1);border:1px solid transparent;border-radius:11px;padding:.55rem 1rem;transition:background .2s,color .2s}
    :global(.sbook:hover){background:var(--cel);color:#fff}
    .snores{text-align:center;color:var(--muted);padding:1.5rem}
    .scta{display:flex;gap:.9rem;justify-content:center;flex-wrap:wrap;margin-top:2.2rem}

    /* modale dettaglio (stessa veste delle Offerte) */
    .omodal{position:fixed;inset:0;z-index:320;display:grid;place-items:center;padding:1.2rem}
    .omodal[hidden]{display:none}
    .omodal-back{position:absolute;inset:0;background:rgba(6,30,16,.55);backdrop-filter:blur(3px)}
    .omodal-card{position:relative;background:var(--card);border:1px solid var(--line);border-radius:20px;padding:clamp(1.5rem,4vw,2.2rem);width:100%;max-width:440px;max-height:88vh;overflow:auto;box-shadow:var(--soft);display:flex;flex-direction:column;gap:.6rem;animation:opop .25s var(--e)}
    @keyframes opop{from{opacity:0;transform:translateY(14px) scale(.98)}}
    @media (prefers-reduced-motion:reduce){.omodal-card{animation:none}}
    .omodal-x{position:absolute;top:.8rem;right:.8rem;width:36px;height:36px;border-radius:50%;border:1px solid var(--line);background:var(--bg);color:var(--ink);font-size:1rem;cursor:pointer}
    .omodal-x:hover{border-color:var(--rosso);color:var(--rosso)}
    .omodal-em{font-size:3rem}
    #sdBadges:empty{display:none}
    #sDetail h2{font-size:1.4rem}
    .omodal-desc{color:var(--muted);line-height:1.55}
    body.omodal-open{overflow:hidden}

    @media (max-width:920px){.sgrid{grid-template-columns:1fr 1fr}}
    @media (max-width:560px){.sgrid{grid-template-columns:1fr}}
  </style>
  <script>
    import { readServices, serviceCard } from './_shared.js';
    const PREN = '/demoFarmaciaAusiliatrice/prenotazioni/?servizio=';
    const grid = document.getElementById('sGrid');
    // i servizi aggiunti dal titolare compaiono per primi
    const custom = readServices();
    if (custom.length) grid.insertAdjacentHTML('afterbegin', custom.map((s) => serviceCard(s, true)).join(''));

    const cards = [...grid.querySelectorAll('.fcard')];
    const noRes = document.getElementById('sNoRes');

    // ---- ricerca per nome (base SSR + iniettati) ----
    document.getElementById('sSearch').addEventListener('input', (e) => {
      const q = e.target.value.trim().toLowerCase();
      let visible = 0;
      cards.forEach((c) => {
        const show = (c.dataset.nome || '').toLowerCase().includes(q);
        c.hidden = !show; if (show) { c.classList.add('in'); visible++; }
      });
      noRes.hidden = visible !== 0;
    });

    // ---- dettaglio servizio in modale (come le Offerte) ----
    const modal = document.getElementById('sDetail');
    const sdBook = document.getElementById('sdBook');
    let lastFocus = null;
    const open = () => { lastFocus = document.activeElement; modal.hidden = false; document.body.classList.add('omodal-open'); modal.querySelector('.omodal-x').focus(); };
    const close = () => { modal.hidden = true; document.body.classList.remove('omodal-open'); if (lastFocus) lastFocus.focus(); };
    const openDetail = (d) => {
      document.getElementById('sdEm').textContent = d.em || '🧩';
      document.getElementById('sdNome').textContent = d.nome || '';
      const desc = document.getElementById('sdDesc');
      desc.textContent = d.desc || ''; desc.hidden = !d.desc;
      document.getElementById('sdBadges').innerHTML =
        (d.nuovo ? '<span class="sbadge sbadge-new">novità</span>' : '') +
        (d.prenotabile ? '<span class="sbadge">prenotabile</span>' : '');
      // il bottone "Prenota" nel dettaglio solo se il servizio è prenotabile
      if (d.prenotabile) { sdBook.style.display = ''; sdBook.href = PREN + encodeURIComponent(d.nome); }
      else { sdBook.style.display = 'none'; }
      open();
    };
    modal.querySelectorAll('[data-close]').forEach((el) => el.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if (modal.hidden) return;
      if (e.key === 'Escape') { close(); return; }
      if (e.key === 'Tab') {
        const f = [...modal.querySelectorAll('button,[href],[tabindex]:not([tabindex="-1"])')].filter((el) => el.offsetParent !== null);
        if (!f.length) return;
        const a = f[0], b = f[f.length - 1];
        if (e.shiftKey && document.activeElement === a) { e.preventDefault(); b.focus(); }
        else if (!e.shiftKey && document.activeElement === b) { e.preventDefault(); a.focus(); }
      }
    });
    cards.forEach((c) => {
      c.addEventListener('click', (e) => { if (!e.target.closest('.sbook')) openDetail(c.dataset); });
      const book = c.querySelector('.sbook');
      if (book) book.addEventListener('click', (e) => e.stopPropagation()); // "Prenota" naviga, non apre il dettaglio
    });
  </script>
</Layout>
