---
import Layout from './_Layout.astro';
---
<Layout title="Prodotti" active="Prodotti">
  <section class="fsection" style="padding-top:8rem;">
    <div class="fhead fhead-c r"><span class="fkick">Il banco</span><h1>I nostri <span class="fmark">prodotti</span></h1><p>Dermocosmesi, integrazione e autoanalisi scelti dai farmacisti. Per prezzi e disponibilità aggiornate, chiamaci o scrivici su WhatsApp.</p></div>

    <div class="pfilter r" id="pFilter" role="group" aria-label="Filtra per categoria">
      <button type="button" data-f="all" class="on">Tutti</button>
      <button type="button" data-f="Dermocosmesi">Dermocosmesi</button>
      <button type="button" data-f="Integratori">Integratori</button>
      <button type="button" data-f="Autoanalisi">Autoanalisi</button>
    </div>

    <div class="pgrid r" id="pGrid"></div>

    <div class="pgest r">
      💡 <b>Per il titolare:</b> questa pagina si aggiorna da sola con i prodotti che inserisci dal
      <a href="/demoFarmaciaAusiliatrice/gestione/">pannello di gestione (demo) →</a>
    </div>
  </section>

  <style>
    .pfilter{display:flex;gap:.6rem;flex-wrap:wrap;justify-content:center;margin-bottom:1.8rem}
    .pfilter button{padding:.6rem 1.2rem;border-radius:999px;border:1px solid var(--line);background:var(--card);font-family:inherit;font-weight:700;font-size:.9rem;color:var(--muted);cursor:pointer;transition:all .2s}
    .pfilter button:hover{border-color:var(--cel)}
    .pfilter button.on{background:var(--blu);border-color:var(--blu);color:#fff}
    .pgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem}
    .pgrid>*{min-width:0}
    :global(.pcard){position:relative;background:var(--card);border:1px solid var(--line);border-radius:16px;padding:1.3rem;display:flex;flex-direction:column;gap:.3rem;transition:transform .25s var(--e),box-shadow .25s}
    :global(.pcard:hover){transform:translateY(-4px);box-shadow:var(--soft)}
    :global(.pcard.mine){border-color:var(--cel)}
    :global(.pmine){align-self:flex-start;font-size:.66rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;background:rgba(47,159,224,.14);color:var(--cel-d);padding:.22rem .55rem;border-radius:999px;margin-bottom:.3rem}
    :global(.pem){font-size:2rem;line-height:1}
    :global(.pcat){font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--muted)}
    :global(.pcard h3){font-size:1.02rem;font-weight:700;flex:1}
    :global(.pfoot){display:flex;align-items:center;justify-content:space-between;gap:.6rem;margin-top:.5rem}
    :global(.pfoot b){color:var(--blu);font-size:1.05rem}
    :global(.pfoot a){font-size:.82rem;font-weight:700;color:var(--cel-d)}
    .pgest{margin-top:2.2rem;text-align:center;background:var(--bg2);border:1px dashed var(--cel);border-radius:14px;padding:1rem 1.3rem;color:var(--muted);font-size:.95rem}
    .pgest a{color:var(--cel-d);font-weight:700;text-decoration:underline}
    @media (max-width:920px){.pgrid{grid-template-columns:1fr 1fr}}
    @media (max-width:520px){.pgrid{grid-template-columns:1fr}}
  </style>

  <script>
    import { ausProducts, prodCard } from './_shared.js';
    const grid = document.getElementById('pGrid');
    const render = (f) => {
      const all = ausProducts();
      grid.innerHTML = (f === 'all' ? all : all.filter((p) => p.cat === f)).map(prodCard).join('') || '<p style="grid-column:1/-1;text-align:center;color:var(--muted)">Nessun prodotto in questa categoria (per ora!).</p>';
    };
    document.querySelectorAll('#pFilter button').forEach((b) => b.addEventListener('click', () => {
      document.querySelectorAll('#pFilter button').forEach((o) => o.classList.toggle('on', o === b));
      render(b.dataset.f);
    }));
    render('all');
  </script>
</Layout>
