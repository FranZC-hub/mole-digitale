---
// Font self-hosted (niente più richieste a Google Fonts → più veloce + GDPR-friendly)
import '@fontsource-variable/inter';
import '@fontsource-variable/space-grotesk';
import '../styles/global.css';
import '../styles/scroll.css';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  image?: string;
}
const {
  title = 'Siti web per attività a Torino — Mole Digitale',
  description = 'Rifacciamo e creiamo siti web moderni per ristoranti, negozi e attività di Torino e provincia. Veloci, belli e a prezzi onesti.',
  noindex = false,
  image,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image ?? '/og-image.png', Astro.site);

// Analytics privacy-friendly (Cloudflare Web Analytics: gratis, niente cookie, GDPR-ok).
// Incolla qui il token dal pannello Cloudflare per attivarlo. Vuoto = disattivato.
const cfAnalyticsToken = '';
// Microsoft Clarity (heatmap + registrazioni sessione, gratis). ID progetto vuoto = disattivato.
const clarityId = '';

const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Mole Digitale',
  description: 'Creazione e rifacimento di siti web per esercenti e piccole attività di Torino e provincia, a costi ridotti.',
  url: Astro.site?.href,
  telephone: '+39 366 210 2203',
  email: 'info@moledigitale.it',
  priceRange: '€€',
  areaServed: { '@type': 'City', name: 'Torino' },
  address: { '@type': 'PostalAddress', addressLocality: 'Torino', addressRegion: 'TO', addressCountry: 'IT' },
  geo: { '@type': 'GeoCoordinates', latitude: 45.0703, longitude: 7.6869 },
  makesOffer: [
    { '@type': 'Offer', name: 'Sito Essenziale', price: '390', priceCurrency: 'EUR' },
    { '@type': 'Offer', name: 'Sito Attività', price: '690', priceCurrency: 'EUR' },
    { '@type': 'Offer', name: 'Hosting & dominio (canone mensile)', price: '29', priceCurrency: 'EUR' },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Quanto tempo ci vuole davvero?', acceptedAnswer: { '@type': 'Answer', text: "In media 7 giorni lavorativi per un sito completo. Per l'onepage Essenziale anche 5. Dipende da quanto velocemente ci mandi foto e testi — ma su quello ti diamo una mano." } },
    { '@type': 'Question', name: 'Devo avere già le foto e i testi?', acceptedAnswer: { '@type': 'Answer', text: 'No. Se non li hai, ti aiutiamo noi a scrivere i testi e possiamo organizzare uno shooting foto a Torino a parte. Partiamo anche solo da una chiacchierata.' } },
    { '@type': 'Question', name: 'Il prezzo è davvero tutto lì?', acceptedAnswer: { '@type': 'Answer', text: 'Sì, te lo diciamo prima. Paghi una tantum la creazione, poi un canone di 29€/mese + IVA per hosting, dominio, SSL e assistenza. Il primo anno di modifiche è incluso nel pacchetto Attività; dopo, piccoli interventi a parte. Tutti i prezzi sono IVA esclusa.' } },
    { '@type': 'Question', name: 'Lavorate solo a Torino?', acceptedAnswer: { '@type': 'Answer', text: 'Partiamo da Torino e provincia perché ci piace incontrare di persona gli esercenti. Ma lavoriamo benissimo anche a distanza, quindi se sei fuori scrivici lo stesso.' } },
    { '@type': 'Question', name: 'E dopo, se voglio cambiare qualcosa?', acceptedAnswer: { '@type': 'Answer', text: 'Ci scrivi e lo facciamo noi. Col pacchetto Attività il primo anno di modifiche è incluso. Dopo, piccole cifre per intervento — sempre dette prima.' } },
  ],
};

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Mole Digitale',
  url: Astro.site?.href,
  logo: new URL('/apple-touch-icon.png', Astro.site).href,
  email: 'info@moledigitale.it',
  telephone: '+39 366 210 2203',
  areaServed: 'Torino, Italia',
};
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'} />
  <meta name="theme-color" content="#07070c" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <meta name="color-scheme" content="dark" />
  <link rel="canonical" href={canonical} />

  <meta name="geo.region" content="IT-TO" />
  <meta name="geo.placename" content="Torino" />
  <meta name="geo.position" content="45.0703;7.6869" />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="it_IT" />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={ogImage} />

  <script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><defs><linearGradient id='g' x1='0' y1='0' x2='1' y2='1'><stop offset='0' stop-color='%237c5cff'/><stop offset='.55' stop-color='%2322d3ee'/><stop offset='1' stop-color='%23ff6b88'/></linearGradient></defs><rect width='24' height='24' rx='6' fill='url(%23g)'/><g fill='white'><path d='M12 3.2l.55 5.6h-1.1z'/><path d='M11.6 8.8C9.8 9.9 9.3 11.6 10.2 12.9h3.6c.9-1.3.4-3-1.4-4.1z'/><rect x='10.2' y='12.6' width='3.6' height='4.9'/><path d='M8 17.3h8l.45 2.3H7.55z'/></g></svg>" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="alternate" type="application/rss+xml" title="Mole Digitale — Blog" href="/rss.xml" />

  <!-- Analytics privacy-friendly (attivo solo se è impostato il token) -->
  {cfAnalyticsToken && (
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon={JSON.stringify({ token: cfAnalyticsToken })}></script>
  )}
  {clarityId && (
    <script is:inline set:html={`(function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window,document,"clarity","script","${clarityId}");`}></script>
  )}

  <!-- Marca il documento come "JS attivo" prima del paint, per l'hero animato -->
  <script is:inline>document.documentElement.classList.add('js');</script>
</head>
<body>

  <a class="skip-link" href="#main">Salta al contenuto</a>

  <!-- Sprite SVG: gradiente logo + icone riusabili -->
  <svg width="0" height="0" style="position:absolute" aria-hidden="true" focusable="false">
    <defs>
      <linearGradient id="logoGrad" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="#7c5cff"/><stop offset=".55" stop-color="#22d3ee"/><stop offset="1" stop-color="#ff6b88"/>
      </linearGradient>
    </defs>
    <symbol id="ic-pizza" viewBox="0 0 24 24"><path d="M3 6c5-3 13-3 18 0L12 22 3 6z"/><circle cx="10" cy="9" r="1"/><circle cx="13.5" cy="12.5" r="1"/></symbol>
    <symbol id="ic-scissors" viewBox="0 0 24 24"><circle cx="6" cy="6" r="2.5"/><circle cx="6" cy="18" r="2.5"/><path d="M8 7.5l12 9M8 16.5l12-9"/></symbol>
    <symbol id="ic-coffee" viewBox="0 0 24 24"><path d="M4 8h12v5a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4V8z"/><path d="M16 9h2a2.5 2.5 0 0 1 0 5h-2"/><path d="M7 3v2M11 3v2"/></symbol>
    <symbol id="ic-bag" viewBox="0 0 24 24"><path d="M6 8h12l-1 12H7L6 8z"/><path d="M9 8a3 3 0 0 1 6 0"/></symbol>
    <symbol id="ic-sparkle" viewBox="0 0 24 24"><path d="M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8L12 3z"/></symbol>
    <symbol id="ic-wrench" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M12 4v2.5M12 17.5V20M4 12h2.5M17.5 12H20M6.3 6.3l1.8 1.8M15.9 15.9l1.8 1.8M17.7 6.3l-1.8 1.8M8.1 15.9l-1.8 1.8"/></symbol>
    <symbol id="ic-dumbbell" viewBox="0 0 24 24"><path d="M4 9v6M7 7v10M17 7v10M20 9v6M7 12h10"/></symbol>
    <symbol id="ic-tooth" viewBox="0 0 24 24"><path d="M12 5c-2.5-2-7-1.3-7 3 0 3 1 4 1.5 7 .3 2 .4 4 1.5 4s1.1-2.5 1.5-4 .6-1.3 1.5-1.3 1.1-.2 1.5 1.3.6 4 1.5 4 1.2-2 1.5-4c.5-3 1.5-4 1.5-7 0-4.3-4.5-5-7-3z"/></symbol>
    <symbol id="ic-wine" viewBox="0 0 24 24"><path d="M7 4h10l-1 5a4 4 0 0 1-8 0L7 4z"/><path d="M12 13v5M9 21h6"/></symbol>
    <symbol id="ic-croissant" viewBox="0 0 24 24"><path d="M4 16c2-6 14-6 16 0-3-1-6 0-8 0s-5-1-8 0z"/><path d="M4.2 15.5L3 19M19.8 15.5L21 19"/></symbol>
    <symbol id="ic-phone" viewBox="0 0 24 24"><rect x="7" y="3" width="10" height="18" rx="2.5"/><path d="M11 17.5h2"/></symbol>
    <symbol id="ic-bolt" viewBox="0 0 24 24"><path d="M13 3L5 13h6l-1 8 8-10h-6l1-8z"/></symbol>
  </svg>

  <div class="cursor-glow" aria-hidden="true"></div>
  <div class="scroll-progress" aria-hidden="true"><span></span></div>

  <div class="bg-mesh" aria-hidden="true">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
    <div class="grid-overlay"></div>
  </div>
  <div class="grain" aria-hidden="true"></div>

  <!-- NAV -->
  <header class="nav" id="nav">
    <a href="/" class="brand" aria-label="Mole Digitale home">
      <span class="brand-mark">
        <svg viewBox="0 0 24 24" width="30" height="30" aria-hidden="true">
          <rect width="24" height="24" rx="7" fill="url(#logoGrad)"/>
          <g fill="#fff">
            <path d="M12 3.2l.55 5.6h-1.1z"/>
            <path d="M11.6 8.8C9.8 9.9 9.3 11.6 10.2 12.9h3.6c.9-1.3.4-3-1.4-4.1z"/>
            <rect x="10.2" y="12.6" width="3.6" height="4.9"/>
            <path d="M8 17.3h8l.45 2.3H7.55z"/>
          </g>
        </svg>
      </span>
      <span class="brand-name">Mole Digitale</span>
    </a>
    <nav class="nav-links" aria-label="Principale">
      <a href="/#servizi">Servizi</a>
      <a href="/#prezzi">Prezzi</a>
      <a href="/demo">Esempi</a>
      <a href="/blog">Blog</a>
      <a href="/chi-siamo">Chi siamo</a>
    </nav>
    <a href="/preventivo" class="btn btn-primary btn-magnetic nav-cta">Preventivo gratis</a>
    <button class="nav-toggle" aria-label="Apri menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </header>

  <main id="main" tabindex="-1">
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-watermark" aria-hidden="true">MOLE</div>
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="brand">
          <span class="brand-mark">
            <svg viewBox="0 0 24 24" width="28" height="28" aria-hidden="true">
              <rect width="24" height="24" rx="7" fill="url(#logoGrad)"/>
              <g fill="#fff">
                <path d="M12 3.2l.55 5.6h-1.1z"/>
                <path d="M11.6 8.8C9.8 9.9 9.3 11.6 10.2 12.9h3.6c.9-1.3.4-3-1.4-4.1z"/>
                <rect x="10.2" y="12.6" width="3.6" height="4.9"/>
                <path d="M8 17.3h8l.45 2.3H7.55z"/>
              </g>
            </svg>
          </span>
          <span class="brand-name">Mole Digitale</span>
        </a>
        <p>Siti web moderni per gli esercenti di Torino e provincia. A costo ridotto, fatti con cura.</p>
      </div>
      <div class="footer-col">
        <h3>Sito</h3>
        <a href="/#servizi">Servizi</a>
        <a href="/#prezzi">Prezzi</a>
        <a href="/preventivo">Preventivo</a>
        <a href="/demo">Demo</a>
        <a href="/blog">Blog</a>
        <a href="/chi-siamo">Chi siamo</a>
        <a href="/#faq">FAQ</a>
      </div>
      <div class="footer-col">
        <h3>Per settore</h3>
        <a href="/siti-web-ristoranti-torino">Siti per ristoranti</a>
        <a href="/siti-web-bar-torino">Siti per bar</a>
        <a href="/siti-web-parrucchieri-torino">Siti per parrucchieri</a>
        <a href="/siti-web-estetiste-torino">Siti per estetiste</a>
        <a href="/siti-web-officine-torino">Siti per officine</a>
      </div>
      <div class="footer-col">
        <h3>Contatti</h3>
        <a href="https://wa.me/393662102203" target="_blank" rel="noopener">WhatsApp</a>
        <a href="tel:+393662102203">+39 366 210 2203</a>
        <a href="mailto:info@moledigitale.it">info@moledigitale.it</a>
        <span>Torino, Italia</span>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© <span id="year"></span> Mole Digitale · P.IVA 00000000000</span>
      <span class="footer-legal">
        <a href="/privacy">Privacy</a> ·
        <a href="/privacy#cookie">Cookie</a> ·
        Fatto con ⚡ a Torino
      </span>
    </div>
  </footer>

  <!-- WhatsApp flottante (sempre visibile) -->
  <a class="wa-fab" href="https://wa.me/393662102203?text=Ciao!%20Vorrei%20informazioni%20sul%20sito" target="_blank" rel="noopener" aria-label="Scrivici su WhatsApp">
    <svg viewBox="0 0 24 24" width="30" height="30" fill="#fff" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2zm0 18a8 8 0 0 1-4.1-1.1l-.3-.2-2.8.8.7-2.8-.2-.3A8 8 0 1 1 12 20zm4.6-5.9c-.2-.1-1.5-.7-1.7-.8s-.4-.1-.6.1-.6.8-.8 1-.3.2-.5.1a6.5 6.5 0 0 1-1.9-1.2 7.3 7.3 0 0 1-1.4-1.7c-.1-.2 0-.4.1-.5l.4-.4.2-.4a.5.5 0 0 0 0-.4c0-.1-.6-1.4-.8-1.9s-.4-.4-.6-.4h-.5a1 1 0 0 0-.7.3 2.8 2.8 0 0 0-.9 2.1 4.9 4.9 0 0 0 1 2.6 11.2 11.2 0 0 0 4.3 3.8c.6.3 1.1.4 1.5.5a3.5 3.5 0 0 0 1.6.1c.5-.1 1.5-.6 1.7-1.2s.2-1.1.2-1.2-.2-.2-.5-.3z"/></svg>
    <span class="wa-fab-label">Scrivici</span>
  </a>

  <!-- Barra CTA fissa su mobile (sostituisce il FAB su schermi piccoli) -->
  <nav class="mobile-cta" aria-label="Azioni rapide">
    <a class="mc-wa" href="https://wa.me/393662102203?text=Ciao!%20Vorrei%20informazioni%20sul%20sito" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2zm0 18a8 8 0 0 1-4.1-1.1l-.3-.2-2.8.8.7-2.8-.2-.3A8 8 0 1 1 12 20zm4.6-5.9c-.2-.1-1.5-.7-1.7-.8s-.4-.1-.6.1-.6.8-.8 1-.3.2-.5.1a6.5 6.5 0 0 1-1.9-1.2 7.3 7.3 0 0 1-1.4-1.7c-.1-.2 0-.4.1-.5l.4-.4.2-.4a.5.5 0 0 0 0-.4c0-.1-.6-1.4-.8-1.9s-.4-.4-.6-.4h-.5a1 1 0 0 0-.7.3 2.8 2.8 0 0 0-.9 2.1 4.9 4.9 0 0 0 1 2.6 11.2 11.2 0 0 0 4.3 3.8c.6.3 1.1.4 1.5.5a3.5 3.5 0 0 0 1.6.1c.5-.1 1.5-.6 1.7-1.2s.2-1.1.2-1.2-.2-.2-.5-.3z"/></svg> WhatsApp
    </a>
    <a class="mc-prev" href="/preventivo">Preventivo gratis</a>
  </nav>

  <script>import '../scripts/main.js';</script>
</body>
</html>
